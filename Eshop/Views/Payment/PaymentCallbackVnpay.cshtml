@model Eshop.Models.VNPay.PaymentResponseModel

@{
    ViewData["Title"] = "Kết quả thanh toán VNPAY";
}

<div class="container mt-4">
    <h2>Kết quả thanh toán VNPAY</h2>

    @if (Model != null && Model.Success)
    {
        <div class="alert alert-success">
            Thanh toán thành công.
        </div>
    }
    else
    {
        <div class="alert alert-danger">
            Thanh toán thất bại.
        </div>
    }

    <table class="table table-bordered">
        <tr>
            <th>Phương thức</th>
            <td>@Model?.PaymentMethod</td>
        </tr>
        <tr>
            <th>Mã đơn hàng</th>
            <td>@Model?.OrderId</td>
        </tr>
        <tr>
            <th>Mã giao dịch</th>
            <td>@Model?.TransactionId</td>
        </tr>
        <tr>
            <th>Mô tả</th>
            <td>@Model?.OrderDescription</td>
        </tr>
        <tr>
            <th>Mã phản hồi VNPAY</th>
            <td>@Model?.VnPayResponseCode</td>
        </tr>
    </table>

    <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Về trang chủ</a>
</div>