@using Eshop.Models.ViewModel
@model CartItemViewModel

<style>
    /* Canh giữa theo chiều dọc cho table */
    .cart_info table td, .cart_info table th {
        vertical-align: middle !important;
    }

    /* Quantity layout */
    .qty-wrap {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

    /* Nút +/- to hơn */
    .qty-btn {
        width: 42px;
        height: 42px;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
    }

        .qty-btn i {
            font-size: 18px;
        }

    /* Ô số lượng to */
    .qty-input {
        width: 70px;
        height: 42px;
        border: 1px solid #ddd;
        border-radius: 8px;
        text-align: center;
        font-size: 16px;
        background: #fff;
    }

    /* Nút Action to hơn */
    .action-btn {
        height: 42px;
        padding: 0 14px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border-radius: 8px;
    }

        .action-btn i {
            font-size: 16px;
        }
</style>

<section id="cart_items" class="py-4">
    <div class="container">
        <div class="breadcrumbs mb-3">
            <ol class="breadcrumb mb-0">
                <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li class="active">Shopping Cart</li>
            </ol>
        </div>

        @if (Model?.CartItems != null && Model.CartItems.Count > 0)
        {
            <div class="card shadow-sm cart_info">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th style="width:90px;">Item</th>
                                    <th>Product</th>
                                    <th class="text-end" style="width:140px;">Price</th>
                                    <th class="text-center" style="width:240px;">Quantity</th>
                                    <th class="text-end" style="width:160px;">Total</th>
                                    <th class="text-end" style="width:160px;">Action</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var item in Model.CartItems)
                                {
                                    <tr>
                                        <td>
                                            @* Nếu có ảnh thì mở lại *@
                                            @* <img src="~/media/products/@item.Image" class="img-thumbnail" style="width:70px;height:70px;object-fit:cover;" /> *@
                                            <div class="bg-light border rounded d-flex align-items-center justify-content-center"
                                                 style="width:70px;height:70px;">
                                                <i class="fa fa-image text-muted"></i>
                                            </div>
                                        </td>

                                        <td>
                                            <div class="fw-bold">
                                                <a href="#" class="text-decoration-none">@item.ProductName</a>
                                            </div>
                                            <small class="text-muted">SKU: @item.ProductId</small>
                                        </td>

                                        <td class="text-end">
                                            <span class="fw-semibold">@item.Price.ToString("#,##0 VND")</span>
                                        </td>

                                        <td class="text-center">
                                            <div class="qty-wrap">
                                                <a class="btn btn-outline-secondary qty-btn"
                                                   asp-action="Decrease"
                                                   asp-controller="Cart"
                                                   asp-route-id="@item.ProductId"
                                                   title="Decrease">
                                                    <i class="fa fa-minus"></i>
                                                </a>

                                                <input class="qty-input"
                                                       type="text"
                                                       value="@item.Quantity"
                                                       readonly />

                                                <a class="btn btn-outline-secondary qty-btn"
                                                   asp-action="Increase"
                                                   asp-controller="Cart"
                                                   asp-route-id="@item.ProductId"
                                                   title="Increase">
                                                    <i class="fa fa-plus"></i>
                                                </a>
                                            </div>
                                        </td>

                                        <td class="text-end">
                                            <span class="fw-bold">@(item.Quantity* item.Price)</span>
                                        </td>

                                        <td class="text-end">
                                            <a class="btn btn-danger action-btn"
                                               asp-action="Remove"
                                               asp-controller="Cart"
                                               asp-route-id="@item.ProductId"
                                               title="Remove item">
                                                <i class="fa fa-trash"></i>
                                                <span class="d-none d-sm-inline">Remove</span>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="card-footer bg-white">
                    <div class="row g-3 align-items-center">
                        <div class="col-md-6">
                            <a class="btn btn-link text-decoration-none p-0"
                               asp-controller="Home"
                               asp-action="Index">
                                <i class="fa fa-arrow-left me-1"></i> Continue shopping
                            </a>
                        </div>

                        <div class="col-md-6">
                            <div class="d-flex flex-wrap justify-content-md-end align-items-center gap-2">
                                <div class="card p-3">
                                    <p>Tạm tính: <strong>@Model.GrandTotal.ToString("N0") đ</strong></p>
                                    <p>Phí vận chuyển: <strong>@Model.ShippingPrice.ToString("N0") đ</strong></p>

                                    @if (!string.IsNullOrEmpty(Model.CouponCode))
                                    {
                                        <p>Mã giảm giá (@Model.CouponCode): <strong>-@Model.DiscountAmount.ToString("N0") đ</strong></p>
                                    }

                                    <h4>Tổng thanh toán: <strong>@Model.FinalTotal.ToString("N0") đ</strong></h4>
                                </div>

                                @Html.AntiForgeryToken()

                                <div class="form-group">
                                    <label>Tỉnh thành phố</label>
                                    <select class="css_select" id="tinh" name="tinh" title="Chọn Tỉnh Thành">
                                        <option value="0">Tỉnh Thành</option>
                                    </select>
                                </div>

                                <!-- v2 không có quận/huyện -> ẩn bằng JS -->
                                <div class="form-group">
                                    <label>Quận huyện</label>
                                    <select class="css_select" id="quan" name="quan" title="Chọn Quận Huyện">
                                        <option value="0">Quận Huyện</option>
                                    </select>
                                </div>

                                <div class="form-group">
                                    <label>Phường xã</label>
                                    <select class="css_select" id="phuong" name="phuong" title="Chọn Phường Xã">
                                        <option value="0">Phường Xã</option>
                                    </select>
                                </div>
                                <div class="form-group">
                                    <button type="button" class="btn btn-primary btn-add-shipping">
                                        <i class="fa fa-truck me-1"></i> Tính phí vận chuyển
                                    </button>
                                </div>
                                <form asp-action="ApplyCoupon" asp-controller="Cart" method="post" class="mb-3">
                                    @Html.AntiForgeryToken()
                                    <div class="row">
                                        <div class="col-md-6">
                                            <input type="text" name="couponCode" class="form-control" placeholder="Nhập mã giảm giá" />
                                        </div>
                                        <div class="col-md-6 mt-2 mt-md-0">
                                            <button type="submit" class="btn btn-primary">Áp dụng mã</button>
                                            <a asp-action="RemoveCoupon" asp-controller="Cart" class="btn btn-danger">Bỏ mã</a>
                                        </div>
                                    </div>
                                </form>

                                <a class="btn btn-outline-danger"
                                   asp-action="Clear"
                                   asp-controller="Cart">
                                    <i class="fa fa-times me-1"></i> Clear cart
                                </a>
                                @if (User.Identity?.IsAuthenticated == true)
                                {
                                    <a class="btn btn-success"
                                       asp-controller="Checkout"
                                       asp-action="Checkout">
                                        <i class="fa fa-credit-card me-1"></i> Checkout
                                    </a>
                                }
                                else
                                {
                                    <a class="btn btn-outline-primary">
                                        <i class="fa fa-sign-in-alt me-1"></i> Login to Checkout
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-info d-flex align-items-center justify-content-between">
                <div>
                    <strong>Your cart is empty.</strong>
                    <div class="text-muted">Add some products to continue.</div>
                </div>
                <a class="btn btn-primary"
                   asp-controller="Home"
                   asp-action="Index">
                    Start shopping
                </a>
            </div>
        }
    </div>
</section>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // ====== PROXY API trên server của bạn ======
        const API = "/Admin/Shipping";

        function getAntiForgeryToken() {
            return $('input[name="__RequestVerificationToken"]').val();
        }

        $(document).ready(function () {

            // v2 không có quận/huyện -> ẩn dropdown quận
            $("#quan").closest(".form-group").hide();

            // Load tỉnh (qua proxy)
            $.getJSON(`${API}/GetProvincesV2`)
                .done(function (provinces) {
                    $("#tinh").html('<option value="0">Tỉnh Thành</option>');
                    (provinces || []).forEach(p => {
                        $("#tinh").append(`<option value="${p.code}">${p.name}</option>`);
                    });
                })
                .fail(function (xhr) {
                    console.error("GetProvincesV2 failed:", xhr.status, xhr.responseText);
                    Swal.fire("Không load được danh sách Tỉnh/TP!");
                });

            // Chọn tỉnh -> load phường/xã theo tỉnh (v2)
            $("#tinh").on("change", function () {
                const provinceCode = $(this).val();

                $("#phuong").html('<option value="0">Phường Xã</option>');

                if (provinceCode === "0") return;

                $.getJSON(`${API}/GetWardsByProvinceV2?provinceCode=${provinceCode}`)
                    .done(function (pDetail) {
                        const wards = pDetail?.wards || [];
                        wards.forEach(w => {
                            $("#phuong").append(`<option value="${w.code}">${w.name}</option>`);
                        });
                    })
                    .fail(function (xhr) {
                        console.error("GetWardsByProvinceV2 failed:", xhr.status, xhr.responseText);
                        Swal.fire("Không load được danh sách Phường/Xã!");
                    });
            });

            // ====== TÍNH PHÍ VẬN CHUYỂN (POST về Cart) ======
            $(document).on("click", ".btn-add-shipping", function (e) {
                e.preventDefault();

                const tinhCode = $("#tinh").val();
                const phuongCode = $("#phuong").val();

                const tinhName = $("#tinh option:selected").text();
                const phuongName = $("#phuong option:selected").text();

                // v2 không dùng quận/huyện -> gửi rỗng nếu backend vẫn cần param "quan"
                const quanName = "";

                if (tinhCode === "0" || phuongCode === "0") {
                    Swal.fire("Vui lòng chọn Tỉnh/TP và Phường/Xã!");
                    return;
                }

                $.ajax({
                    type: "POST",
                    url: "@Url.Action("GetShipping", "Cart")",
                    headers: {
                        "RequestVerificationToken": getAntiForgeryToken()
                    },
                    data: {
                        tinh: tinhName,
                        quan: quanName,
                        phuong: phuongName,

                    },
                    success: function (result) {
                        // Nếu server trả true/false
                        if (result === true || result?.success === true) {
                            location.reload();
                            return;
                        }

                        // Nếu server trả message
                        if (result?.message) {
                            Swal.fire(result.message);
                            return;
                        }

                        // fallback
                        location.reload();
                    },
                    error: function (xhr) {
                        console.error("GetShipping error:", xhr.status, xhr.responseText);
                        Swal.fire("Đã xảy ra lỗi khi tính phí vận chuyển!");
                    }
                });
            });

        });
    </script>
}