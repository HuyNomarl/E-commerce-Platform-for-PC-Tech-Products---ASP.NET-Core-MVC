@{
    ViewData["Title"] = "Build PC";
    ViewData["BodyClass"] = "page-pc-builder";
}

<style>
    body.page-pc-builder {
        --pc-builder-dock-width: 430px;
        --pc-builder-collapsed-width: 296px;
        --pc-builder-dock-gap: 24px;
    }

    .pc-builder-page {
        background: linear-gradient(180deg, #dbe3ea 0%, #cfd8e2 100%);
        padding: 24px 0 36px;
        min-height: 100vh;
    }

    .pc-builder-wrap {
        max-width: 1540px;
        margin: 0 auto;
        padding: 0 16px;
    }

    .pc-builder-title {
        text-align: center;
        font-size: 26px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .4px;
        color: #0f172a;
        margin-bottom: 22px;
    }

    .pc-builder-topbar,
    .pc-builder-bottombar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        margin-bottom: 18px;
    }

    .btn-refresh-custom {
        background: linear-gradient(180deg, #e45a52, #c93c34);
        color: #fff;
        border: none;
        padding: 11px 18px;
        border-radius: 10px;
        font-weight: 800;
        box-shadow: 0 10px 24px rgba(120, 36, 30, .18);
        transition: transform .18s ease, box-shadow .18s ease;
    }

        .btn-refresh-custom:hover {
            transform: translateY(-1px);
            box-shadow: 0 14px 26px rgba(120, 36, 30, .22);
        }

    .estimate-box {
        font-size: 20px;
        font-weight: 900;
        color: #0f172a;
    }

        .estimate-box .price {
            color: #c0392b;
        }

    .builder-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        background: #f3f6f9;
        border: 1px solid #bcc8d4;
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(15, 23, 42, .07);
    }

        .builder-table tr {
            border-bottom: 1px solid #cfd8e2;
        }

            .builder-table tr:last-child {
                border-bottom: none;
            }

        .builder-table td {
            vertical-align: top;
            padding: 0;
        }

    .slot-col {
        width: 235px;
        background: linear-gradient(180deg, #dbe4ec, #d1dbe5);
        border-right: 1px solid #c7d1db;
        padding: 18px 16px !important;
        font-size: 15px;
        font-weight: 900;
        text-transform: uppercase;
        color: #0f172a;
    }

    .content-col {
        background: #eef3f7;
        padding: 16px 18px !important;
    }

    .empty-slot-wrap {
        min-height: 72px;
        display: flex;
        align-items: center;
    }

    .btn-choose-component {
        background: linear-gradient(180deg, #e07a4d, #c85c32);
        color: #fff;
        border: none;
        border-radius: 12px;
        padding: 12px 16px;
        font-size: 15px;
        font-weight: 800;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        box-shadow: 0 10px 22px rgba(124, 61, 33, .16);
        transition: transform .18s ease, box-shadow .18s ease;
    }

        .btn-choose-component:hover {
            transform: translateY(-1px);
            box-shadow: 0 14px 28px rgba(124, 61, 33, .20);
        }

    .selected-group {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .selected-item {
        display: grid;
        grid-template-columns: 82px 1fr auto;
        gap: 16px;
        align-items: center;
        padding: 14px;
        border: 1px solid #ccd6df;
        border-radius: 14px;
        background: #e8eef4;
    }

    .selected-thumb {
        width: 82px;
        height: 82px;
        object-fit: contain;
        background: #f8fafc;
        border: 1px solid #d4dde6;
        border-radius: 12px;
        padding: 6px;
    }

    .selected-info {
        font-size: 14px;
        line-height: 1.55;
        color: #334155;
    }

    .selected-name {
        font-size: 16px;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 4px;
        line-height: 1.4;
    }

    .selected-sub {
        color: #475569;
    }

    .selected-stock {
        color: #166534;
        font-weight: 800;
    }

    .selected-out {
        color: #b91c1c;
        font-weight: 800;
    }

    .selected-price-side {
        text-align: right;
        min-width: 300px;
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 10px;
        flex-wrap: wrap;
    }

    .unit-price,
    .line-total {
        color: #b9382d;
        font-size: 16px;
        font-weight: 900;
        white-space: nowrap;
    }

    .qty-box {
        display: inline-flex;
        align-items: center;
        border: 1px solid #c7d1db;
        overflow: hidden;
        background: #f8fafc;
        height: 38px;
        border-radius: 10px;
    }

    .qty-btn {
        width: 34px;
        height: 38px;
        border: none;
        background: #dde5ec;
        font-size: 20px;
        line-height: 1;
        font-weight: 800;
        color: #1e293b;
    }

    .qty-input {
        width: 42px;
        height: 38px;
        border: none;
        text-align: center;
        font-weight: 800;
        background: #f8fafc;
        color: #0f172a;
    }

    .item-actions {
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .mini-action-btn {
        border: none;
        background: #dbeafe;
        color: #1d4ed8;
        font-size: 13px;
        font-weight: 800;
        padding: 8px 10px;
        border-radius: 8px;
    }

    .mini-remove-btn {
        background: #fee2e2;
        color: #b91c1c;
    }

    .builder-messages {
        margin-top: 16px;
        padding: 16px 18px;
        background: #eaf0f5;
        border: 1px solid #c2ccd6;
        border-radius: 14px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, .04);
    }

    .builder-message {
        margin-bottom: 8px;
        font-size: 14px;
        line-height: 1.5;
    }

        .builder-message:last-child {
            margin-bottom: 0;
        }

        .builder-message.error {
            color: #991b1b;
            font-weight: 800;
        }

        .builder-message.warning {
            color: #92400e;
            font-weight: 800;
        }

        .builder-message.info {
            color: #1e40af;
        }

    .builder-actions {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
        margin-top: 20px;
    }

    .builder-bottom-btn {
        border: none;
        border-radius: 12px;
        padding: 13px 14px;
        font-weight: 900;
        font-size: 15px;
        color: #fff;
        text-transform: uppercase;
        box-shadow: 0 10px 24px rgba(15, 23, 42, .10);
        transition: transform .18s ease, box-shadow .18s ease;
    }

        .builder-bottom-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 14px 28px rgba(15, 23, 42, .14);
        }

    .btn-darkgreen {
        background: linear-gradient(180deg, #31545b, #223c42);
    }

    .btn-cart-red {
        background: linear-gradient(180deg, #d85a50, #bc3a32);
    }

    .builder-utility-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 18px;
        margin-top: 22px;
    }

    .builder-utility-card {
        background: #e8eef4;
        border: 1px solid #c7d1db;
        border-radius: 16px;
        padding: 18px;
        box-shadow: 0 10px 28px rgba(15, 23, 42, .05);
    }

    .builder-utility-title {
        font-size: 18px;
        font-weight: 900;
        margin-bottom: 8px;
        color: #0f172a;
    }

    .builder-utility-sub {
        color: #475569;
        font-size: 14px;
        margin-bottom: 14px;
        line-height: 1.55;
    }

    .share-search-row {
        display: flex;
        gap: 10px;
        margin-bottom: 12px;
    }

        .share-search-row input,
        .share-note-input {
            width: 100%;
            border: 1px solid #bfcbd7;
            border-radius: 10px;
            padding: 11px 12px;
            font-size: 14px;
            outline: none;
            background: #f4f7fa;
            color: #0f172a;
            transition: border-color .18s ease, box-shadow .18s ease;
        }

            .share-search-row input:focus,
            .share-note-input:focus,
            .build-chatbox-input input:focus,
            .picker-search input:focus {
                border-color: #7aa2c7;
                box-shadow: 0 0 0 4px rgba(59, 130, 246, .10);
            }

    .share-note-input {
        resize: vertical;
        min-height: 94px;
        margin-bottom: 12px;
    }

    .share-search-btn,
    .share-action-btn,
    .share-load-btn,
    .share-download-btn {
        border: none;
        border-radius: 10px;
        font-weight: 800;
    }

    .share-search-btn,
    .share-action-btn {
        background: #2b4349;
        color: #fff;
        padding: 11px 14px;
        white-space: nowrap;
    }

    .share-results,
    .shared-build-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
        min-height: 80px;
    }

    .share-result-item,
    .shared-build-item {
        border: 1px solid #cdd6df;
        border-radius: 12px;
        padding: 14px;
        background: #f0f4f8;
    }

        .share-result-item.active {
            border-color: #3b6b72;
            box-shadow: 0 0 0 3px rgba(59, 107, 114, .10);
            background: #e4edf1;
        }

    .share-result-top,
    .shared-build-top {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        align-items: flex-start;
    }

    .share-result-name,
    .shared-build-name {
        font-size: 15px;
        font-weight: 900;
        color: #0f172a;
    }

    .share-result-meta,
    .shared-build-meta {
        font-size: 13px;
        color: #475569;
        margin-top: 4px;
        line-height: 1.6;
    }

    .share-select-btn {
        border: none;
        border-radius: 10px;
        padding: 8px 12px;
        font-weight: 800;
        background: #d9e1e8;
        color: #0f172a;
        white-space: nowrap;
    }

    .share-result-item.active .share-select-btn {
        background: #355d64;
        color: #fff;
    }

    .shared-build-actions {
        display: flex;
        gap: 8px;
        margin-top: 10px;
        flex-wrap: wrap;
    }

    .share-load-btn {
        background: #c5483f;
        color: #fff;
        padding: 8px 12px;
    }

    .share-download-btn {
        background: #2b4349;
        color: #fff;
        padding: 8px 12px;
    }

    .utility-empty {
        padding: 12px;
        border: 1px dashed #b8c3ce;
        border-radius: 12px;
        color: #52606f;
        background: #edf2f6;
        font-size: 14px;
    }

    .picker-overlay {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, .58);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 1200;
        padding: 18px;
    }

        .picker-overlay.show {
            display: flex;
        }

    .picker-modal {
        width: min(1260px, 100%);
        max-height: 88vh;
        background: #dfe7ee;
        border-radius: 18px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        box-shadow: 0 18px 50px rgba(0,0,0,.26);
    }

    .picker-header {
        background: linear-gradient(180deg, #cf6d45, #b95a34);
        color: #fff;
        padding: 14px 18px;
        font-size: 18px;
        font-weight: 900;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
    }

    .picker-search {
        flex: 1;
        max-width: 760px;
        display: flex;
        gap: 8px;
        align-items: center;
    }

        .picker-search input {
            flex: 1;
            height: 42px;
            border: none;
            border-radius: 10px;
            padding: 0 12px;
            outline: none;
            background: #f4f7fa;
            color: #0f172a;
        }

        .picker-search button,
        .picker-close-btn,
        .picker-confirm-btn {
            border: none;
            border-radius: 10px;
            font-weight: 800;
        }

        .picker-search button {
            height: 42px;
            padding: 0 14px;
            background: #e8eef4;
            color: #0f172a;
        }

    .picker-close-btn {
        background: #e8eef4;
        color: #0f172a;
        padding: 9px 12px;
    }

    .picker-body {
        overflow: auto;
        padding: 16px;
    }

    .picker-layout {
        display: grid;
        grid-template-columns: 320px 1fr;
        gap: 16px;
        min-height: 520px;
    }

    .picker-sidebar {
        background: #dfe7ee;
        border-right: 1px solid #c1ccd7;
        padding-right: 8px;
    }

    .picker-filter-box {
        background: #dfe7ee;
    }

    .picker-filter-title {
        font-size: 15px;
        font-weight: 900;
        text-transform: uppercase;
        border: 1px solid #c1ccd7;
        background: #edf2f6;
        text-align: center;
        padding: 10px 12px;
        border-radius: 12px;
        margin-bottom: 14px;
        color: #0f172a;
    }

    .picker-filter-tools {
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin-bottom: 16px;
    }

    .picker-sort-select {
        height: 40px;
        border: 1px solid #c1ccd7;
        background: #eef3f7;
        padding: 0 10px;
        border-radius: 10px;
        color: #0f172a;
    }

    .picker-inline-check {
        display: flex;
        align-items: center;
        gap: 8px;
        font-weight: 700;
        cursor: pointer;
        color: #1e293b;
    }

    .picker-clear-filter-btn {
        border: none;
        background: #c5483f;
        color: #fff;
        padding: 10px 12px;
        border-radius: 10px;
        font-weight: 800;
    }

    .filter-group {
        margin-bottom: 18px;
    }

    .filter-group-title {
        font-size: 14px;
        font-weight: 900;
        text-transform: uppercase;
        margin-bottom: 10px;
        color: #0f172a;
    }

    .filter-options-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px 18px;
    }

    .filter-option-label {
        display: flex;
        align-items: flex-start;
        gap: 8px;
        cursor: pointer;
        font-size: 13px;
        line-height: 1.4;
        color: #334155;
    }

        .filter-option-label input {
            margin-top: 2px;
        }

    .filter-option-count {
        color: #52606f;
    }

    .picker-content {
        min-width: 0;
    }

    .picker-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .picker-item {
        background: #edf2f6;
        border: 1px solid #c8d2dc;
        border-radius: 14px;
        padding: 14px;
        display: grid;
        grid-template-columns: 36px 92px 1fr auto;
        gap: 14px;
        align-items: center;
        transition: box-shadow .18s ease, transform .18s ease;
    }

        .picker-item:hover {
            box-shadow: 0 10px 24px rgba(15, 23, 42, .08);
            transform: translateY(-1px);
        }

    .picker-check-wrap {
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .picker-check {
        width: 18px;
        height: 18px;
        accent-color: #c75c33;
    }

    .picker-img {
        width: 92px;
        height: 92px;
        object-fit: contain;
        background: #f8fafc;
        border: 1px solid #d1d9e1;
        border-radius: 12px;
        padding: 6px;
    }

    .picker-name {
        font-size: 16px;
        font-weight: 800;
        color: #0f172a;
        line-height: 1.45;
        margin-bottom: 6px;
    }

    .picker-meta {
        font-size: 13px;
        line-height: 1.6;
        color: #475569;
    }

    .picker-price {
        min-width: 150px;
        text-align: right;
        color: #b9382d;
        font-weight: 900;
        font-size: 19px;
        white-space: nowrap;
    }

    .picker-footer {
        padding: 12px 16px;
        background: #d9e1e8;
        border-top: 1px solid #c1ccd7;
        display: flex;
        justify-content: flex-end;
        gap: 10px;
    }

    .picker-confirm-btn {
        background: #c75c33;
        color: #fff;
        padding: 10px 18px;
    }

    .empty-picker {
        background: #edf2f6;
        border: 1px dashed #b9c4cf;
        border-radius: 14px;
        padding: 32px;
        text-align: center;
        color: #52606f;
    }

    .build-chatbox {
        position: fixed;
        right: 20px;
        bottom: 20px;
        width: min(var(--pc-builder-dock-width), calc(100vw - 24px));
        max-height: 78vh;
        background: #dde5ec;
        border: 1px solid #bfcbd7;
        border-radius: 18px;
        box-shadow: 0 22px 50px rgba(15,23,42,.22);
        display: flex;
        flex-direction: column;
        z-index: 1300;
        overflow: hidden;
    }

        .build-chatbox.collapsed {
            width: min(var(--pc-builder-collapsed-width), calc(100vw - 24px));
            max-height: none;
        }

        .build-chatbox.collapsed .build-chatbox-body,
        .build-chatbox.collapsed .build-chatbox-actions,
        .build-chatbox.collapsed .build-chatbox-input {
            display: none;
        }

    .build-chatbox-header {
        background: linear-gradient(135deg, #2c4349, #22363b);
        color: #fff;
        padding: 14px 16px;
        font-weight: 900;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
        position: relative;
    }

    .build-chatbox-header-main {
        min-width: 0;
    }

    .build-chatbox-title {
        font-size: 18px;
        line-height: 1.2;
    }

    .build-chatbox-subtitle {
        font-size: 12px;
        font-weight: 600;
        opacity: .85;
        margin-top: 4px;
        line-height: 1.4;
    }

    .build-chatbox.collapsed .build-chatbox-subtitle {
        display: none;
    }

        .build-chatbox-header::after {
            content: "";
            position: absolute;
            left: 16px;
            right: 16px;
            bottom: 0;
            height: 1px;
            background: rgba(255,255,255,.08);
        }

        .build-chatbox-header button {
            border: none;
            background: rgba(255,255,255,.12);
            color: #fff;
            width: 34px;
            height: 34px;
            border-radius: 10px;
            font-size: 20px;
            font-weight: 800;
            flex: 0 0 auto;
            transition: background .18s ease;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

            .build-chatbox-header button:hover {
                background: rgba(255,255,255,.18);
            }

    .build-chatbox-body {
        padding: 10px !important;
        background: linear-gradient(180deg, #cfd8e1 0%, #c4cfda 100%);
        overflow-y: auto !important;
        overflow-x: hidden !important;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 10px !important;
        min-height: 220px !important;
        max-height: 52vh;
    }

    .chat-message {
        padding: 12px 14px;
        border-radius: 14px;
        font-size: 14px;
        line-height: 1.6;
        max-width: 88% !important;
        white-space: pre-wrap;
        box-shadow: 0 6px 18px rgba(15, 23, 42, .06);
    }

        .chat-message.bot {
            background: #e2e8f0;
            color: #0f172a;
            align-self: flex-start;
        }

        .chat-message.user {
            background: #e9d8d2;
            color: #1e293b;
            align-self: flex-end;
        }

        .chat-message.chat-rich {
            width: 100% !important;
            max-width: 100% !important;
            background: transparent;
            padding: 0 !important;
            margin: 0 !important;
            box-shadow: none;
        }

    .chat-bubble-text {
        background: #e2e8f0;
        border-radius: 14px;
        padding: 9px 11px !important;
        white-space: pre-wrap;
        box-shadow: 0 6px 18px rgba(15, 23, 42, .05);
        font-size: 13px !important;
        line-height: 1.5 !important;
        margin-bottom: 6px !important;
    }

    .chat-hint-box {
        margin-top: 10px;
        background: #efe3d3;
        border: 1px solid #d7b892;
        border-radius: 12px;
        padding: 12px;
    }

    .chat-hint-title {
        font-size: 13px;
        font-weight: 900;
        color: #7c2d12;
        margin-bottom: 6px;
    }

    .chat-hint-item {
        font-size: 13px;
        color: #78350f;
        line-height: 1.5;
    }

        .chat-hint-item + .chat-hint-item {
            margin-top: 4px;
        }

    .chat-product-panel {
        margin-top: 6px !important;
        border: 1px solid #c8d2dc !important;
        border-radius: 15px !important;
        background: #e8eef4 !important;
        overflow: hidden !important;
        box-shadow: 0 10px 24px rgba(15, 23, 42, .08) !important;
    }

    .chat-product-panel-head {
        display: grid !important;
        gap: 3px !important;
        padding: 8px 11px !important;
        background: #dde5ec !important;
        border-bottom: 1px solid #d3dbe3 !important;
    }

    .chat-product-panel-title {
        font-size: 12.5px !important;
        font-weight: 800 !important;
        line-height: 1.25 !important;
        margin: 0 !important;
    }

    .chat-product-panel-sub {
        font-size: 10.5px !important;
        margin-top: 0 !important;
        line-height: 1.35 !important;
        color: #64748b !important;
    }

    .chat-product-list {
        display: grid !important;
        grid-template-columns: 1fr !important;
        gap: 10px !important;
        padding: 9px !important;
        max-height: min(34vh, 220px) !important;
        overflow-y: auto !important;
        overflow-x: hidden !important;
        align-content: start !important;
    }

