<!DOCTYPE html>
@{
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
    var isBackOfficeUser = User.CanAccessBackOffice();
    var canUseCustomerPages = !isBackOfficeUser;
}
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - E-Shopper</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@3.4.1/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.26.17/dist/sweetalert2.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://code.jquery.com/ui/1.14.2/themes/base/jquery-ui.css" />

    <link href="~/css/prettyPhoto.css" rel="stylesheet" />
    <link href="~/css/price-range.css" rel="stylesheet" />
    <link href="~/css/animate.css" rel="stylesheet" />
    <link href="~/css/main.css" rel="stylesheet" />
    <link href="~/css/site-custom.css" rel="stylesheet" />
    <link href="~/css/responsive.css" rel="stylesheet" />

    <link rel="shortcut icon" href="~/images/ico/favicon.ico" />

    <style>
        .tt-header-top .tt-auth-links {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

        .tt-header-top .tt-auth-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 14px;
            border-radius: 999px;
            border: 1px solid rgba(191, 219, 254, 0.18);
            background: rgba(255, 255, 255, 0.08);
            color: #eff6ff !important;
            font-size: 13px;
            font-weight: 700;
            line-height: 1;
            text-decoration: none;
        }

        .tt-header-top .tt-auth-link:hover,
        .tt-header-top .tt-auth-link:focus {
            background: rgba(255, 255, 255, 0.16);
            color: #ffffff !important;
            text-decoration: none;
        }

        .tt-header-top .tt-auth-link-primary {
            background: linear-gradient(135deg, #38bdf8 0%, #2563eb 100%);
            box-shadow: 0 10px 22px rgba(37, 99, 235, 0.26);
        }

        .tt-header-top .tt-auth-link-logout {
            background: rgba(127, 29, 29, 0.24);
            border-color: rgba(254, 202, 202, 0.2);
        }

        .tt-header-top .tt-auth-link span,
        .tt-header-top .tt-auth-link i,
        .tt-header-top .tt-auth-separator {
            color: inherit !important;
        }
    </style>
</head>
<body>
    <partial name="_SupportChatPartial" />

    <header class="tt-header">
        <div class="tt-header-top">
            <div class="container">
                <div class="tt-top-inner">
                    <div class="tt-top-left">
                        <a href="#"><i class="fa fa-map-marker"></i><span>Hệ thống showroom</span></a>
                        <a href="#"><i class="fa fa-phone"></i><span>Bán hàng trực tuyến</span></a>
                        <a href="#"><i class="fa fa-newspaper-o"></i><span>Trang tin công nghệ</span></a>
                        <a href="#"><i class="fa fa-gamepad"></i><span>TƯ VẤN BUILD PC</span></a>
                        <a href="#"><i class="fa fa-download"></i><span>Phần mềm hay</span></a>
                    </div>

                    <div class="tt-top-right tt-auth-links">
                        @if (isAuthenticated)
                        {
                            @if (isBackOfficeUser)
                            {
                                <a asp-area="Admin" asp-controller="Portal" asp-action="Index" class="tt-auth-link">
                                    <i class="fa fa-shield"></i>
                                    <span>Quản trị</span>
                                </a>
                            }
                            else
                            {
                                <a asp-controller="Account" asp-action="UpdateAccount" asp-route-tab="home" class="tt-auth-link">
                                    <i class="fa fa-user-circle-o"></i>
                                    <span>Tài khoản</span>
                                </a>
                            }
                            <span class="tt-auth-separator">|</span>
                            <a asp-controller="Account" asp-action="Logout" class="tt-auth-link tt-auth-link-logout">
                                <i class="fa fa-sign-out"></i>
                                <span>Đăng xuất</span>
                            </a>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Register" class="tt-auth-link">
                                <i class="fa fa-user-plus"></i>
                                <span>Đăng ký</span>
                            </a>
                            <span class="tt-auth-separator">|</span>
                            <a asp-controller="Account" asp-action="Login" class="tt-auth-link tt-auth-link-primary">
                                <i class="fa fa-sign-in"></i>
                                <span>Đăng nhập</span>
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="tt-header-main">
            <div class="container">
                <div class="tt-main-row">
                    <div class="tt-logo-col">
                        <a asp-controller="Home" asp-action="Index" class="tt-logo">
                            <img src="~/images/Logo/bfe68383-fed2-4775-954a-a5ac3c1d5291.png" alt="TTSHOP" />
                        </a>
                    </div>

                    <div class="tt-search-col">
                        <form asp-controller="Product" asp-action="Search" method="post" class="tt-search-form">
                            <select name="categoryId" class="tt-search-select">
                                <option value="">Tất cả danh mục</option>
                            </select>

                            <input type="text" name="searchTerm" class="tt-search-input" placeholder="Tìm kiếm sản phẩm..." />

                            <button type="submit" class="tt-search-btn">
                                <i class="fa fa-search"></i>
                            </button>
                        </form>

                        <div class="tt-quick-links">
                            <a href="#">PC Gaming</a>
                            @if (canUseCustomerPages)
                            {
                                <a asp-controller="Home" asp-action="Wishlist">Yêu thích</a>
                                <a asp-controller="Home" asp-action="Compare">So sánh</a>
                            }
                        </div>
                    </div>

                    <div class="tt-action-col">
                        <a href="#" class="tt-action-item">
                            <div class="tt-action-icon">
                                <i class="fa fa-phone"></i>
                            </div>
                            <div class="tt-action-text">
                                <span>Hotline mua hàng</span>
                                <strong>098.655.2233</strong>
                            </div>
                        </a>

                        <a class="tt-action-item" asp-controller="PcBuilder" asp-action="Index">
                            <div class="tt-action-icon">
                                <i class="fa fa-desktop"></i>
                            </div>
                            <div class="tt-action-text">
                                <span>Xây dựng</span>
                                <strong>Cấu hình PC</strong>
                            </div>
                        </a>

                        <a asp-controller="Cart" asp-action="Index" class="tt-action-item tt-cart-item">
                            <div class="tt-action-icon">
                                <i class="fa fa-shopping-cart"></i>
                            </div>
                            <div class="tt-action-text">
                                <strong>Giỏ hàng</strong>
                            </div>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="tt-header-bottom">
            <div class="container">
                <div class="tt-bottom-row">
                    <div class="tt-category-col">
                        @await Component.InvokeAsync("CategoryMenu")
                    </div>

                    <div class="tt-feature-col">
                        <a href="#" class="tt-feature-item">
                            <i class="fa fa-desktop"></i>
                            <span>PC GAMING</span>
                        </a>

                        <a href="#" class="tt-feature-item">
                            <i class="fa fa-desktop"></i>
                            <span>PC WORKSTATION 2D 3D</span>
                        </a>

                        <a href="#" class="tt-feature-item">
                            <i class="fa fa-desktop"></i>
                            <span>PC AMD GAMING</span>
                        </a>

                        <a href="#" class="tt-feature-item">
                            <i class="fa fa-desktop"></i>
                            <span>PC MINI</span>
                        </a>

                        <a href="#" class="tt-feature-item">
                            <i class="fa fa-desktop"></i>
                            <span>PC VĂN PHÒNG</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <section>
        <div class="container">
            <div class="row">
                @Html.Partial("_NotificationPartial")
                @RenderBody()
            </div>
        </div>
    </section>

    <footer id="footer">
        <partial name="_FooterPartial" />
        <div class="footer-bottom">
            <div class="container">
                <div class="row">
                    <p class="pull-left">Copyright © 2025 E-SHOPPER Inc. All rights reserved.</p>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.26.17/dist/sweetalert2.all.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@3.4.1/dist/js/bootstrap.min.js"></script>

    <script src="~/js/swal-helpers.js"></script>
    <script src="~/js/jquery.scrollUp.min.js"></script>
    <script src="~/js/price-range.js"></script>
    <script src="~/js/jquery.prettyPhoto.js"></script>
    <script src="~/js/main.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script src="~/js/support-chat.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
