                        <style>
                                .support-chat-toggle {
                                    position: fixed;
                                    right: 20px;
                                    bottom: 80px;
                                    width: 55px;
                                    height: 55px;
                                    border-radius: 50%;
                                    background: #fe980f;
                                    color: #fff;
                                    display: flex;
                                    align-items: center;
                                    justify-content: center;
                                    font-size: 24px;
                                    cursor: pointer;
                                    z-index: 9999;
                                    box-shadow: 0 4px 15px rgba(0,0,0,.25);
                                }

                                .support-chat-box {
                                    position: fixed;
                                    right: 20px;
                                    bottom: 145px;
                                    width: 340px;
                                    max-width: calc(100vw - 30px);
                                    background: #fff;
                                    border: 1px solid #ddd;
                                    border-radius: 10px;
                                    box-shadow: 0 8px 25px rgba(0,0,0,.2);
                                    z-index: 9999;
                                    overflow: hidden;
                                }

                                .support-chat-header {
                                    background: #fe980f;
                                    color: #fff;
                                    padding: 12px 15px;
                                    display: flex;
                                    align-items: center;
                                    justify-content: space-between;
                                    font-weight: bold;
                                }

                                .support-chat-close {
                                    background: transparent;
                                    border: none;
                                    color: #fff;
                                    font-size: 22px;
                                    line-height: 1;
                                    cursor: pointer;
                                }

                                .support-chat-messages {
                                    height: 300px;
                                    overflow-y: auto;
                                    padding: 10px;
                                    background: #fafafa;
                                }

                                .support-chat-item {
                                    margin-bottom: 10px;
                                    display: flex;
                                }

                                    .support-chat-item.me {
                                        justify-content: flex-end;
                                    }

                                    .support-chat-item.other {
                                        justify-content: flex-start;
                                    }

                                .support-chat-bubble {
                                    max-width: 78%;
                                    padding: 8px 12px;
                                    border-radius: 12px;
                                    font-size: 13px;
                                    line-height: 1.4;
                                    word-break: break-word;
                                }

                                .support-chat-item.me .support-chat-bubble {
                                    background: #d9edf7;
                                    color: #333;
                                }

                                .support-chat-item.other .support-chat-bubble {
                                    background: #f5f5f5;
                                    color: #333;
                                }

                                .support-chat-time {
                                    display: block;
                                    margin-top: 4px;
                                    font-size: 11px;
                                    color: #777;
                                }

                                .support-chat-input-wrap {
                                    display: flex;
                                    gap: 8px;
                                    padding: 10px;
                                    border-top: 1px solid #eee;
                                    background: #fff;
                                }

                                    .support-chat-input-wrap input {
                                        flex: 1;
                                    }
                        </style>

</head>

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <div id="supportChatToggle" class="support-chat-toggle" title="Chat với admin">
                            <i class="fa fa-comments"></i>
                        </div>

                        <div id="supportChatBox" class="support-chat-box" style="display:none;">
                            <div class="support-chat-header">
                                <span id="supportChatTitle">Hỗ trợ trực tuyến</span>
                                <button type="button" id="supportChatClose" class="support-chat-close">&times;</button>
                            </div>

                            <div id="supportChatMessages" class="support-chat-messages"></div>

                            <div class="support-chat-input-wrap">
                                <input type="text" id="supportChatInput" class="form-control" placeholder="Nhập tin nhắn..." />
                                <button type="button" id="supportChatSend" class="btn btn-danger">Gửi</button>
                            </div>
                        </div>
                    }

