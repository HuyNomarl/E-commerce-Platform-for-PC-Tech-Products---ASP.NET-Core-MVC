@using System.Text.Json
@{
    var notifications = new List<object>();
    var seen = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

    void AddNotification(string type, object? rawMessage, string title)
    {
        var message = rawMessage?.ToString();
        if (string.IsNullOrWhiteSpace(message))
        {
            return;
        }

        var key = $"{type}:{message}";
        if (!seen.Add(key))
        {
            return;
        }

        notifications.Add(new
        {
            type,
            title,
            message
        });
    }

    AddNotification("success", TempData["success"], "Thành công");
    AddNotification("success", TempData["Success"], "Thành công");
    AddNotification("success", TempData["SuccessMessage"], "Thành công");
    AddNotification("error", TempData["error"], "Có lỗi xảy ra");
    AddNotification("error", TempData["Error"], "Có lỗi xảy ra");
    AddNotification("error", TempData["ErrorMessage"], "Có lỗi xảy ra");
}

@if (notifications.Any())
{
    <script id="app-notifications" type="application/json">
        @Html.Raw(JsonSerializer.Serialize(notifications))
    </script>
}
