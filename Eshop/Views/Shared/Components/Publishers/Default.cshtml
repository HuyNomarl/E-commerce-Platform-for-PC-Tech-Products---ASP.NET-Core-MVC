@model IEnumerable<PublisherModel>
@foreach(var item in Model)
{
	<div class="panel panel-default">
		<div class="panel-heading">
			<h4 class="panel-title"><a asp-action="Index" asp-controller="Publisher" asp-route-Slug="@item.Slug">@item.Name</a></h4>
		</div>
	</div>
}	