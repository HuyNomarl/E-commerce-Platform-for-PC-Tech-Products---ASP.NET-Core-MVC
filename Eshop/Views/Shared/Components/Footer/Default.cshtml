@model ContactModel

@{
    var contact = Model ?? new ContactModel
    {
        Name = "Eshop",
        Description = "<p>Eshop đồng hành cùng bạn trong việc chọn linh kiện, thiết bị và cấu hình PC phù hợp cho học tập, làm việc và gaming.</p>",
        Email = string.Empty,
        Phone = string.Empty,
        Map = string.Empty,
        LogoImg = string.Empty
    };

    var companyName = string.IsNullOrWhiteSpace(contact.Name) ? "Eshop" : contact.Name;
    var descriptionHtml = string.IsNullOrWhiteSpace(contact.Description)
        ? "<p>Eshop đồng hành cùng bạn trong việc chọn linh kiện, thiết bị và cấu hình PC phù hợp cho học tập, làm việc và gaming.</p>"
        : contact.Description;

    var logoPath = string.IsNullOrWhiteSpace(contact.LogoImg)
        ? Url.Content("~/images/Logo/bfe68383-fed2-4775-954a-a5ac3c1d5291.png")
        : Url.Content($"~/media/contact/{contact.LogoImg}");

    var rawMapUrl = contact.Map ?? string.Empty;
    var embeddedMapUrl = rawMapUrl;
    if (!string.IsNullOrWhiteSpace(embeddedMapUrl) &&
        embeddedMapUrl.Contains("google.com/maps", StringComparison.OrdinalIgnoreCase) &&
        !embeddedMapUrl.Contains("output=embed", StringComparison.OrdinalIgnoreCase))
    {
        embeddedMapUrl += embeddedMapUrl.Contains('?') ? "&output=embed" : "?output=embed";
    }

    var phoneText = string.IsNullOrWhiteSpace(contact.Phone) ? "Đang cập nhật" : contact.Phone;
    var emailText = string.IsNullOrWhiteSpace(contact.Email) ? "Đang cập nhật" : contact.Email;

    var callHref = string.IsNullOrWhiteSpace(contact.Phone) ? "#" : $"tel:{contact.Phone}";
    var emailHref = string.IsNullOrWhiteSpace(contact.Email) ? "#" : $"mailto:{contact.Email}";
    var mapHref = string.IsNullOrWhiteSpace(rawMapUrl) ? (Url.Action("Contact", "Home") ?? "#") : rawMapUrl;

    var exploreLinks = new[]
    {
        (Text: "Trang chủ", Href: Url.Action("Index", "Home") ?? "#"),
        (Text: "Sản phẩm", Href: Url.Action("Index", "Product") ?? "#"),
        (Text: "Danh mục", Href: Url.Action("Index", "Category") ?? "#"),
        (Text: "Build PC", Href: Url.Action("Index", "PcBuilder") ?? "#"),
        (Text: "Liên hệ", Href: Url.Action("Contact", "Home") ?? "#")
    };

    var supportLinks = new[]
    {
        (Text: "Giỏ hàng", Href: Url.Action("Index", "Cart") ?? "#"),
        (Text: "So sánh sản phẩm", Href: Url.Action("Compare", "Home") ?? "#"),
        (Text: "Danh sách yêu thích", Href: Url.Action("Wishlist", "Home") ?? "#"),
        (Text: "Đăng nhập", Href: Url.Action("Login", "Account") ?? "#"),
        (Text: "Tạo tài khoản", Href: Url.Action("Create", "Account") ?? "#")
    };
}

<footer class="tt-footer">
    <div class="tt-footer-main">
        <div class="container">
            <div class="tt-footer-grid">
                <section class="tt-footer-panel tt-footer-brand-panel" aria-label="Giới thiệu Eshop">
                    <div class="tt-footer-brand-top">
                        <img src="@logoPath" alt="@companyName" class="tt-footer-logo" />
                        <span class="tt-footer-badge">Storefront</span>
                    </div>

                    <div class="tt-footer-description">
                        @Html.Raw(descriptionHtml)
                    </div>

                    <div class="tt-footer-actions">
                        <a href="@callHref" class="tt-footer-action">
                            <i class="fa fa-phone"></i>
                            <span>Gọi ngay</span>
                        </a>
                        <a href="@emailHref" class="tt-footer-action">
                            <i class="fa fa-envelope"></i>
                            <span>Gửi email</span>
                        </a>
                        <a href="@mapHref" class="tt-footer-action" target="_blank" rel="noopener">
                            <i class="fa fa-map-marker"></i>
                            <span>Xem bản đồ</span>
                        </a>
                    </div>
                </section>

                <section class="tt-footer-panel" aria-label="Khám phá">
                    <h2 class="tt-footer-title">Khám phá</h2>
                    <ul class="tt-footer-links">
                        @foreach (var link in exploreLinks)
                        {
                            <li>
                                <a href="@link.Href">
                                    <i class="fa fa-angle-right"></i>
                                    <span>@link.Text</span>
                                </a>
                            </li>
                        }
                    </ul>
                </section>

                <section class="tt-footer-panel" aria-label="Hỗ trợ khách hàng">
                    <h2 class="tt-footer-title">Hỗ trợ</h2>
                    <ul class="tt-footer-links">
                        @foreach (var link in supportLinks)
                        {
                            <li>
                                <a href="@link.Href">
                                    <i class="fa fa-angle-right"></i>
                                    <span>@link.Text</span>
                                </a>
                            </li>
                        }
                    </ul>
                </section>

                <section class="tt-footer-panel tt-footer-contact-panel" aria-label="Thông tin liên hệ">
                    <h2 class="tt-footer-title">Thông tin liên hệ</h2>

                    <ul class="tt-footer-contact-list">
                        <li>
                            <span class="tt-footer-contact-icon"><i class="fa fa-phone"></i></span>
                            <div>
                                <strong>Hotline</strong>
                                <p>@phoneText</p>
                            </div>
                        </li>
                        <li>
                            <span class="tt-footer-contact-icon"><i class="fa fa-envelope"></i></span>
                            <div>
                                <strong>Email</strong>
                                <p>@emailText</p>
                            </div>
                        </li>
                        <li>
                            <span class="tt-footer-contact-icon"><i class="fa fa-map-marker"></i></span>
                            <div>
                                <strong>Bản đồ cửa hàng</strong>
                                <p>
                                    <a href="@mapHref" target="_blank" rel="noopener">Mở Google Maps</a>
                                </p>
                            </div>
                        </li>
                    </ul>
                </section>
            </div>

            @if (!string.IsNullOrWhiteSpace(embeddedMapUrl))
            {
                <section class="tt-footer-map-panel" aria-label="Bản đồ cửa hàng">
                    <div class="tt-footer-map-heading">
                        <div>
                            <span class="tt-footer-eyebrow">Chi nhánh</span>
                            <h2>Vị trí cửa hàng</h2>
                        </div>
                        <a href="@mapHref" target="_blank" rel="noopener">Mở trong Google Maps</a>
                    </div>

                    <div class="tt-footer-map-frame">
                        <iframe src="@embeddedMapUrl"
                                loading="lazy"
                                referrerpolicy="no-referrer-when-downgrade"
                                allowfullscreen>
                        </iframe>
                    </div>
                </section>
            }
        </div>
    </div>

    <div class="tt-footer-bottom">
        <div class="container">
            <div class="tt-footer-bottom-inner">
                <p>Copyright © @DateTime.Now.Year @companyName. All rights reserved.</p>
                <div class="tt-footer-bottom-links">
                    <a href="@(Url.Action("Privacy", "Home") ?? "#")">Chính sách</a>
                    <a href="@(Url.Action("Contact", "Home") ?? "#")">Liên hệ</a>
                </div>
            </div>
        </div>
    </div>
</footer>
