@model Eshop.Models.ViewModels.ProductCatalogPageViewModel

@{
    ViewData["Title"] = Model.Title;
}

@section Styles {
    <style>
        .catalog-page {
            width: 100%;
            padding: 18px 0 26px;
        }

        .catalog-layout {
            display: grid;
            grid-template-columns: 280px minmax(0, 1fr);
            gap: 22px;
            align-items: start;
        }

        .catalog-filter-panel {
            position: sticky;
            top: 16px;
            background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
            border: 1px solid #dde7f2;
            border-radius: 24px;
            box-shadow: 0 18px 42px rgba(15, 23, 42, 0.08);
            overflow: hidden;
        }

        .catalog-filter-head {
            display: flex;
            justify-content: space-between;
            gap: 12px;
            align-items: flex-start;
            padding: 20px 20px 16px;
            background: linear-gradient(135deg, #0f172a 0%, #1d4ed8 100%);
            color: #fff;
        }

        .catalog-filter-caption {
            display: block;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: .12em;
            opacity: .75;
            margin-bottom: 6px;
        }

        .catalog-filter-head h3 {
            margin: 0;
            font-size: 24px;
            font-weight: 800;
        }

        .catalog-filter-reset {
            color: #fff;
            font-size: 12px;
            font-weight: 700;
            text-decoration: none;
            white-space: nowrap;
            border: 1px solid rgba(255,255,255,.28);
            border-radius: 999px;
            padding: 7px 12px;
        }

        .catalog-filter-reset:hover {
            color: #fff;
            text-decoration: none;
            background: rgba(255,255,255,.12);
        }

        .catalog-filter-group {
            padding: 18px 20px;
            border-top: 1px solid #e5edf5;
        }

        .catalog-filter-group h4 {
            margin: 0 0 14px;
            color: #0f172a;
            font-size: 18px;
            font-weight: 800;
        }

        .catalog-filter-option {
            display: flex;
            gap: 10px;
            align-items: flex-start;
            margin: 0 0 12px;
            font-size: 15px;
            color: #1e293b;
            cursor: pointer;
        }

        .catalog-filter-option:last-child {
            margin-bottom: 0;
        }

        .catalog-filter-option input {
            width: 18px;
            height: 18px;
            margin-top: 1px;
            accent-color: #ef4444;
            flex: 0 0 auto;
        }

        .catalog-filter-option span {
            line-height: 1.5;
        }

        .catalog-filter-option small {
            color: #64748b;
            font-size: 13px;
        }

        .catalog-main {
            min-width: 0;
        }

        .catalog-toolbar {
            display: flex;
            justify-content: space-between;
            gap: 18px;
            align-items: end;
            margin-bottom: 18px;
            padding: 24px 26px;
            border-radius: 28px;
            background:
                radial-gradient(circle at top right, rgba(239, 68, 68, 0.14), transparent 34%),
                linear-gradient(135deg, #ffffff 0%, #f8fbff 100%);
            border: 1px solid #e2e8f0;
            box-shadow: 0 18px 36px rgba(15, 23, 42, 0.06);
        }

        .catalog-breadcrumb {
            margin-bottom: 10px;
            color: #64748b;
            font-size: 13px;
        }

        .catalog-breadcrumb a {
            color: #2563eb;
            text-decoration: none;
        }

        .catalog-toolbar h1 {
            margin: 0 0 6px;
            color: #0f172a;
            font-size: 30px;
            font-weight: 800;
            line-height: 1.2;
        }

        .catalog-toolbar p {
            margin: 0;
            color: #64748b;
            font-size: 15px;
        }

        .catalog-sort {
            min-width: 220px;
        }

        .catalog-sort label {
            display: block;
            margin: 0 0 8px;
            color: #334155;
            font-size: 13px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .06em;
        }

        .catalog-sort .form-control {
            height: 46px;
            border-radius: 14px;
            border-color: #cbd5e1;
            box-shadow: none;
            font-size: 15px;
            font-weight: 600;
        }

        .catalog-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
            gap: 18px;
        }

        .catalog-card {
            display: flex;
            flex-direction: column;
            min-height: 100%;
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 22px;
            overflow: hidden;
            box-shadow: 0 12px 26px rgba(15, 23, 42, 0.05);
            transition: transform .22s ease, box-shadow .22s ease;
        }

        .catalog-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 34px rgba(15, 23, 42, 0.1);
        }

        .catalog-card-media {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 18px;
            min-height: 210px;
            background:
                radial-gradient(circle at top, rgba(96, 165, 250, 0.18), transparent 40%),
                #fff;
            border-bottom: 1px solid #edf2f7;
        }

        .catalog-card-image {
            width: 100%;
            height: 170px;
            object-fit: contain;
        }

        .catalog-card-placeholder {
            width: 100%;
            min-height: 170px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #94a3b8;
            background: #f8fafc;
            border-radius: 18px;
            font-size: 28px;
        }

        .catalog-card-body {
            display: flex;
            flex-direction: column;
            flex: 1;
            padding: 16px 16px 18px;
        }

        .catalog-card-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-bottom: 12px;
        }

        .catalog-card-meta span {
            display: inline-flex;
            align-items: center;
            padding: 5px 10px;
            border-radius: 999px;
            background: #eff6ff;
            color: #1d4ed8;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .04em;
        }

        .catalog-card-title {
            color: #0f172a;
            text-decoration: none;
            font-size: 17px;
            font-weight: 700;
            line-height: 1.45;
            min-height: 50px;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            margin-bottom: 12px;
        }

        .catalog-card-title:hover {
            color: #dc2626;
            text-decoration: none;
        }

        .catalog-card-price {
            color: #dc2626;
            font-size: 30px;
            font-weight: 800;
            line-height: 1.1;
            margin-bottom: 8px;
        }

        .catalog-card-price-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 8px;
            margin-bottom: 16px;
            min-height: 22px;
        }

        .catalog-card-old-price {
            color: #94a3b8;
            font-size: 14px;
            text-decoration: line-through;
        }

        .catalog-card-discount {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 52px;
            height: 24px;
            padding: 0 10px;
            border-radius: 999px;
            background: #ef4444;
            color: #fff;
            font-size: 12px;
            font-weight: 800;
        }

        .catalog-card-footer {
            margin-top: auto;
        }

        .catalog-card-action-row {
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            gap: 10px;
            align-items: center;
        }

        .catalog-card-cart {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            width: 100%;
            min-height: 46px;
            border: 1px solid #1d4ed8;
            border-radius: 999px;
            background: #fff;
            color: #0f172a;
            font-size: 13px;
            font-weight: 800;
            text-transform: uppercase;
            padding: 0 14px 0 8px;
            transition: all .2s ease;
        }

        .catalog-card-cart:hover {
            background: #1d4ed8;
            color: #fff;
        }

        .catalog-card-cart-icon {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: #1d4ed8;
            color: #fff;
            flex: 0 0 auto;
            transition: all .2s ease;
        }

        .catalog-card-cart:hover .catalog-card-cart-icon {
            background: #fff;
            color: #1d4ed8;
        }

        .catalog-card-stock {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 46px;
            padding: 0 14px;
            border-radius: 999px;
            background: #dcfce7;
            color: #15803d;
            font-size: 13px;
            font-weight: 700;
            white-space: nowrap;
        }

        .catalog-card-mini-actions {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 8px;
            margin-top: 12px;
        }

        .catalog-card-mini-actions .btn {
            border-radius: 999px;
            border-color: #dbe4ef;
            background: #fff;
            color: #334155;
            font-size: 12px;
            font-weight: 700;
            padding: 9px 12px;
        }

        .catalog-card-mini-actions .btn:hover {
            border-color: #2563eb;
            color: #1d4ed8;
            background: #eff6ff;
        }

        .catalog-empty {
            padding: 42px 32px;
            text-align: center;
            border: 1px dashed #cbd5e1;
            border-radius: 24px;
            background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
            color: #475569;
        }

        .catalog-empty i {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 72px;
            height: 72px;
            margin-bottom: 16px;
            border-radius: 50%;
            background: #eff6ff;
            color: #2563eb;
            font-size: 28px;
        }

        .catalog-empty h3 {
            margin: 0 0 8px;
            color: #0f172a;
            font-size: 24px;
            font-weight: 800;
        }

        .catalog-empty p {
            margin: 0 0 18px;
            font-size: 15px;
        }

        @@media (max-width: 991px) {
            .catalog-layout {
                grid-template-columns: 1fr;
            }

            .catalog-filter-panel {
                position: static;
            }

            .catalog-toolbar {
                flex-direction: column;
                align-items: stretch;
            }

            .catalog-sort {
                min-width: 0;
            }
        }

        @@media (max-width: 767px) {
            .catalog-page {
                padding: 12px 0 20px;
            }

            .catalog-toolbar {
                padding: 18px;
                border-radius: 22px;
            }

            .catalog-toolbar h1 {
                font-size: 24px;
            }

            .catalog-grid {
                grid-template-columns: 1fr;
            }

            .catalog-card-action-row {
                grid-template-columns: 1fr;
            }

            .catalog-card-mini-actions {
                grid-template-columns: 1fr;
            }
        }
    </style>
}

<div class="col-sm-12">
    <div class="catalog-page">
        <div class="catalog-layout">
            <aside class="catalog-sidebar">
                <partial name="_CatalogFilterSidebarPartial" model="Model.Sidebar" />
            </aside>

            <section class="catalog-main">
                <div class="catalog-toolbar">
                    <div>
                        <div class="catalog-breadcrumb">
                            <a asp-controller="Home" asp-action="Index">Trang chủ</a> / @Model.BreadcrumbLabel / @Model.Title
                        </div>
                        <h1>@Model.Title</h1>
                        <p>@Model.SummaryText</p>
                    </div>

                    <div class="catalog-sort">
                        <label for="catalogSortSelect">Sắp xếp</label>
                        <select id="catalogSortSelect" name="sort_by" form="catalogFilterForm" class="form-control">
                            <option value="newest" selected="@(Model.SortBy == "newest")">Mới nhất</option>
                            <option value="price_asc" selected="@(Model.SortBy == "price_asc")">Giá tăng dần</option>
                            <option value="price_desc" selected="@(Model.SortBy == "price_desc")">Giá giảm dần</option>
                            <option value="name_asc" selected="@(Model.SortBy == "name_asc")">Tên A - Z</option>
                            <option value="name_desc" selected="@(Model.SortBy == "name_desc")">Tên Z - A</option>
                        </select>
                    </div>
                </div>

                @Html.AntiForgeryToken()

                @if (Model.Products.Any())
                {
                    <div class="catalog-grid">
                        @foreach (var product in Model.Products)
                        {
                            <partial name="_CatalogProductCardPartial" model="product" />
                        }
                    </div>
                }
                else
                {
                    <div class="catalog-empty">
                        <i class="fa fa-search"></i>
                        <h3>Không tìm thấy sản phẩm phù hợp</h3>
                        <p>Hãy bỏ bớt một vài bộ lọc hoặc quay lại danh mục gốc để xem thêm sản phẩm khác.</p>
                        <a href="@Model.Sidebar.ClearFiltersUrl" class="btn btn-primary">Xem lại toàn bộ danh sách</a>
                    </div>
                }
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const form = document.getElementById('catalogFilterForm');
            const sortSelect = document.getElementById('catalogSortSelect');

            if (form) {
                document.querySelectorAll('.js-filter-autosubmit').forEach(function (input) {
                    input.addEventListener('change', function () {
                        form.submit();
                    });
                });
            }

            if (form && sortSelect) {
                sortSelect.addEventListener('change', function () {
                    form.submit();
                });
            }

            function showFeedback(icon, title, text) {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({ icon: icon, title: title, text: text });
                } else {
                    alert(text);
                }
            }

            function getToken() {
                const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
                return tokenInput ? tokenInput.value : '';
            }

            function postSimple(url, data, successText) {
                $.ajax({
                    url: url,
                    type: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    data: Object.assign({}, data, { __RequestVerificationToken: getToken() }),
                    success: function (response) {
                        if (response && typeof response.totalItems !== 'undefined') {
                            window.updateCartBadge(response.totalItems);
                        }

                        showFeedback('success', 'Thành công', response && response.message ? response.message : successText);
                    },
                    error: function (xhr) {
                        const message = xhr.responseJSON && xhr.responseJSON.message
                            ? xhr.responseJSON.message
                            : (xhr.responseText || 'Không thể thực hiện thao tác này.');
                        showFeedback('error', 'Có lỗi xảy ra', message);
                    }
                });
            }

            $('.js-catalog-add-to-cart').on('click', function () {
                postSimple('@Url.Action("Add", "Cart")', {
                    ProductId: $(this).data('product-id'),
                    Quantity: 1
                }, 'Đã thêm vào giỏ hàng.');
            });

            $('.js-catalog-add-wishlist').on('click', function () {
                postSimple('@Url.Action("AddWishlist", "Home")', {
                    productId: $(this).data('product-id')
                }, 'Đã thêm vào yêu thích.');
            });

            $('.js-catalog-add-compare').on('click', function () {
                postSimple('@Url.Action("AddCompare", "Home")', {
                    productId: $(this).data('product-id')
                }, 'Đã thêm vào so sánh.');
            });
        })();
    </script>
}
