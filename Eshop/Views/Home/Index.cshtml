@using System.Linq
@model Eshop.Models.ViewModels.HomeIndexViewModel

@{
    ViewData["Title"] = "Home Page";
    var canUseWishlistAndCompare = User.CanUseWishlistAndCompare();

    var productList = (Model?.Products ?? new List<Eshop.Models.ProductModel>())
        .OrderByDescending(x => x.Quantity > 0)
        .ThenByDescending(x => x.Sold)
        .ThenByDescending(x => x.Id)
        .ToList();


    Func<string?, int> getCategoryPriority = name =>
    {
        if (string.IsNullOrWhiteSpace(name)) return 999;

        var n = name.Trim().ToLowerInvariant();

        if (n.Contains("pc gaming") || n.Contains("máy tính chơi game")) return 1;
        if (n.Contains("pc đồ họa") || n.Contains("pc workstation")) return 2;
        if (n.Contains("pc văn phòng")) return 3;
        if (n.Contains("pc")) return 4;
        if (n.Contains("laptop gaming")) return 5;
        if (n.Contains("laptop")) return 6;
        if (n.Contains("cpu")) return 7;
        if (n.Contains("mainboard") || n.Contains("bo mạch chủ")) return 8;
        if (n.Contains("ram")) return 9;
        if (n.Contains("ssd") || n.Contains("hdd")) return 10;
        if (n.Contains("vga") || n.Contains("card màn hình")) return 11;
        if (n.Contains("psu") || n.Contains("nguồn")) return 12;
        if (n.Contains("case")) return 13;
        if (n.Contains("tản nhiệt")) return 14;
        if (n.Contains("màn hình")) return 15;
        return 100;
    };

    var hotProducts = productList.Take(15).ToList();

    var categoryGroups = productList
        .Where(x => x.Category != null)
        .GroupBy(x => new
        {
            CategoryId = x.Category.Id,
            CategoryName = x.Category.Name
        })
        .Select(g => new
        {
            CategoryId = g.Key.CategoryId,
            CategoryName = g.Key.CategoryName,
            Priority = getCategoryPriority(g.Key.CategoryName),
            Products = g
                .OrderByDescending(x => x.Quantity > 0)
                .ThenByDescending(x => x.Sold)
                .ThenByDescending(x => x.Id)
                .ToList()
        })
        .OrderBy(x => x.Priority)
        .ThenByDescending(x => x.Products.Count)
        .ThenBy(x => x.CategoryName)
        .ToList();

    var recommendedProducts = (Model?.RecommendedProducts ?? new List<Eshop.Models.ProductModel>())
        .OrderByDescending(x => x.Quantity > 0)
        .ThenByDescending(x => x.Sold)
        .ThenByDescending(x => x.Id)
        .ToList();
}

<style>
    .home-page-wrapper {
        width: 100%;
        padding: 10px 0 22px;
    }

    .section-block {
        margin-bottom: 18px;
        background: #f3f3f3;
        border-radius: 12px;
        overflow: hidden;
        padding: 0;
    }

    .section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        min-height: 54px;
    }

    .section-title-ribbon {
        position: relative;
        display: inline-flex;
        align-items: center;
        background: #ff5a2c;
        color: #fff;
        font-size: 16px;
        font-weight: 800;
        line-height: 1;
        text-transform: uppercase;
        padding: 14px 26px 14px 14px;
    }

        .section-title-ribbon:after {
            content: "";
            position: absolute;
            top: 0;
            right: -30px;
            width: 0;
            height: 0;
            border-top: 27px solid #004d5a;
            border-bottom: 27px solid transparent;
            border-left: 30px solid transparent;
        }

    .section-link {
        color: #003b57;
        font-size: 14px;
        font-weight: 700;
        text-decoration: none;
        padding-right: 14px;
    }

        .section-link:hover {
            color: #ff5a2c;
            text-decoration: none;
        }

    .deal-hot-section {
        background: linear-gradient(135deg, #5c7dfb 0%, #59d3ff 55%, #efa3ef 100%);
        padding: 12px;
        border-radius: 12px;
    }

    .deal-hot-title {
        margin: 0 0 10px;
        font-size: 26px;
        line-height: 1.1;
        font-weight: 900;
        text-transform: uppercase;
        color: #ffef1e;
        -webkit-text-stroke: 1px #d45500;
        text-shadow: 2px 2px 0 #d45500;
    }

    .deal-carousel-box {
        position: relative;
        background: rgba(255,255,255,.16);
        border-radius: 10px;
        padding: 10px 44px;
        overflow: hidden;
    }

    .deal-carousel-viewport {
        overflow: hidden;
        width: 100%;
    }

    .deal-carousel-track {
        display: flex;
        gap: 14px;
        transition: transform .35s ease;
        will-change: transform;
    }

    .deal-col {
        flex: 0 0 calc((100% - 42px) / 4);
        min-width: calc((100% - 42px) / 4);
        width: calc((100% - 42px) / 4);
    }

    .products-scroll-wrap {
        position: relative;
        padding: 14px 42px;
        overflow: hidden;
    }

    .products-scroll {
        display: flex;
        gap: 14px;
        overflow-x: hidden;
        overflow-y: hidden;
        scroll-behavior: smooth;
        padding: 2px 0 4px;
        scrollbar-width: none;
        width: 100%;
    }

        .products-scroll::-webkit-scrollbar {
            display: none;
        }

    .category-col {
        flex: 0 0 calc((100% - 42px) / 4);
        min-width: calc((100% - 42px) / 4);
        width: calc((100% - 42px) / 4);
    }

    .product-card {
        background: #fff;
        border: 1px solid #e1e1e1;
        border-radius: 8px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        min-height: 338px;
        height: 100%;
        transition: all .2s ease;
    }

        .product-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 18px rgba(0,0,0,.06);
        }

    .product-thumb-wrap {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        height: 165px;
        padding: 10px;
        background: #fff;
        border-bottom: 1px solid #f1f1f1;
    }

    .product-thumb {
        width: 100%;
        height: 100%;
        object-fit: contain;
        display: block;
    }

    .thumb-placeholder {
        width: 100%;
        height: 100%;
        min-height: 120px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #999;
        background: #fafafa;
    }

    .product-body {
        display: flex;
        flex-direction: column;
        flex: 1;
        padding: 10px 12px 12px;
    }

    .product-name {
        font-size: 14px;
        line-height: 1.35;
        font-weight: 600;
        color: #222;
        min-height: 38px;
        max-height: 38px;
        overflow: hidden;
        margin-bottom: 8px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }

        .product-name:hover {
            color: #ff5a2c;
        }

    .price-current {
        font-size: 16px;
        line-height: 1.2;
        font-weight: 800;
        color: #e60000;
        margin-bottom: 4px;
    }

    .price-old-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
        min-height: 22px;
        margin-bottom: 10px;
    }

    .price-old {
        color: #8f8f8f;
        font-size: 12px;
        text-decoration: line-through;
        line-height: 1.2;
    }

    .discount-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #ef0000;
        color: #fff;
        font-size: 11px;
        font-weight: 700;
        border-radius: 4px;
        min-width: 44px;
        height: 22px;
        padding: 0 8px;
        white-space: nowrap;
    }

    .product-footer {
        margin-top: auto;
    }

    .product-action-row {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 8px;
        align-items: center;
    }

    .btn-cart-main {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: flex-start;
        gap: 8px;
        width: 100%;
        height: 42px;
        min-height: 42px;
        max-height: 42px;
        margin: 0;
        padding: 0 12px 0 6px;
        border: 1.5px solid #2d4ac8;
        border-radius: 22px;
        background: #fff;
        color: #111;
        font-size: 10px;
        font-weight: 800;
        line-height: 1;
        text-transform: uppercase;
        text-align: left;
        white-space: nowrap;
        box-sizing: border-box;
        appearance: none;
        -webkit-appearance: none;
        outline: none;
        box-shadow: none;
        transform: none;
        top: 0;
        vertical-align: middle;
        overflow: hidden;
        transition: color .25s ease, border-color .25s ease;
    }

        .btn-cart-main::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 0;
            height: 100%;
            background: #2d4ac8;
            transition: width .35s ease;
            z-index: 0;
        }

        .btn-cart-main:hover::before,
        .btn-cart-main:focus::before {
            width: 100%;
        }

        .btn-cart-main:hover,
        .btn-cart-main:focus {
            color: #fff;
            border-color: #2d4ac8;
            text-decoration: none;
        }

        .btn-cart-main > * {
            position: relative;
            z-index: 1;
        }

    .cart-icon-box {
        width: 30px;
        height: 30px;
        min-width: 30px;
        max-width: 30px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 16px;
        background: #2d4ac8;
        color: #fff;
        font-size: 13px;
        line-height: 1;
        flex-shrink: 0;
        transition: background .25s ease, color .25s ease;
    }

    .btn-cart-main:hover .cart-icon-box,
    .btn-cart-main:focus .cart-icon-box {
        background: #fff;
        color: #2d4ac8;
    }

    .cart-label {
        display: flex;
        align-items: center;
        height: 100%;
        min-width: 0;
        flex: 1 1 auto;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        line-height: 1;
    }

    .btn-cart-main:disabled,
    .btn-cart-main.disabled {
        border-color: #d4d4d4;
        background: #f7f7f7;
        color: #a0a0a0;
        cursor: not-allowed;
    }

        .btn-cart-main:disabled::before,
        .btn-cart-main.disabled::before {
            display: none;
        }

        .btn-cart-main:disabled .cart-icon-box,
        .btn-cart-main.disabled .cart-icon-box {
            background: #d0d0d0;
            color: #fff;
        }

    .stock-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        height: 42px;
        min-width: 88px;
        margin: 0;
        padding: 0 12px;
        border-radius: 22px;
        background: #dff3e4;
        color: #228b45;
        font-size: 12px;
        font-weight: 600;
        line-height: 1;
        white-space: nowrap;
        box-sizing: border-box;
        align-self: center;
    }

        .stock-badge.out {
            background: #ffe5e5;
            color: #d62828;
        }

    .mini-actions {
        display: flex;
        gap: 8px;
        margin-top: 10px;
    }

        .mini-actions .btn {
            flex: 1;
            height: 34px;
            border-radius: 18px;
            border: 1px solid #d8d8d8;
            background: #fff;
            color: #333;
            font-size: 12px;
            padding: 0 10px;
        }

            .mini-actions .btn:hover {
                border-color: #2d4ac8;
                color: #2d4ac8;
                background: #f8faff;
            }

    .deal-nav,
    .scroll-nav {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        width: 34px;
        height: 34px;
        border: 0;
        border-radius: 50%;
        background: rgba(255,255,255,.95);
        color: #222;
        box-shadow: 0 2px 8px rgba(0,0,0,.10);
        z-index: 5;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

        .deal-nav:hover,
        .scroll-nav:hover {
            background: #fff;
        }

        .deal-prev,
        .scroll-nav.prev {
            left: 4px;
        }

        .deal-next,
        .scroll-nav.next {
            right: 4px;
        }

        .scroll-nav.hidden {
            display: none;
        }

    @@media (max-width: 1199px) {
        .deal-col,
        .category-col {
            width: calc((100% - 28px) / 3);
            min-width: calc((100% - 28px) / 3);
            flex-basis: calc((100% - 28px) / 3);
        }
    }

    @@media (max-width: 991px) {
        .deal-carousel-box {
            padding: 10px 40px;
        }

        .products-scroll-wrap {
            padding: 14px 38px;
        }

        .deal-col,
        .category-col {
            width: calc((100% - 14px) / 2);
            min-width: calc((100% - 14px) / 2);
            flex-basis: calc((100% - 14px) / 2);
        }

        .product-card {
            min-height: 330px;
        }

        .product-thumb-wrap {
            height: 155px;
        }

        .btn-cart-main {
            font-size: 10px;
        }

        .stock-badge {
            min-width: 82px;
            font-size: 11px;
        }
    }

    @@media (max-width: 767px) {
        .home-page-wrapper {
            padding: 8px 0 18px;
        }

        .deal-hot-section {
            padding: 8px;
        }

        .deal-hot-title {
            font-size: 20px;
        }

        .section-title-ribbon {
            font-size: 14px;
            padding: 12px 18px 12px 12px;
        }

            .section-title-ribbon:after {
                right: -24px;
                border-top: 24px solid #004d5a;
                border-bottom: 24px solid transparent;
                border-left: 24px solid transparent;
            }

        .deal-carousel-box {
            padding: 8px;
        }

        .products-scroll-wrap {
            padding: 10px;
        }

        .deal-col,
        .category-col {
            width: calc(85% - 4px);
            min-width: calc(85% - 4px);
            flex-basis: calc(85% - 4px);
        }

        .product-card {
            min-height: 320px;
        }

        .product-thumb-wrap {
            height: 150px;
            padding: 8px;
        }

        .product-name {
            font-size: 14px;
        }

        .product-action-row {
            grid-template-columns: minmax(0, 1fr) auto;
            gap: 6px;
        }

        .btn-cart-main {
            height: 40px;
            min-height: 40px;
            max-height: 40px;
            font-size: 9.5px;
            padding: 0 10px 0 6px;
            gap: 6px;
        }

        .cart-icon-box {
            width: 28px;
            height: 28px;
            min-width: 28px;
            max-width: 28px;
            font-size: 12px;
        }

        .stock-badge {
            height: 40px;
            min-width: 76px;
            padding: 0 10px;
            font-size: 11px;
        }

        .mini-actions {
            flex-direction: column;
        }

        .deal-nav,
        .scroll-nav {
            display: none !important;
        }
    }
</style>

<div class="col-sm-12 home-page-wrapper">
    <partial name="_SliderPartial" model="Model?.Sliders" />

    <div id="homeCatalog"></div>

    @if (hotProducts.Any())
    {
        <div class="section-block deal-hot-section">
            <h2 class="deal-hot-title">Deal hot mỗi ngày</h2>

            <div class="deal-carousel-box">
                <button type="button" class="deal-nav deal-prev" id="hotDealPrev">
                    <i class="fa fa-chevron-left"></i>
                </button>

                <div class="deal-carousel-viewport">
                    <div class="deal-carousel-track" id="hotDealTrack">
                        @foreach (var item in hotProducts)
                        {
                            var oldPrice = item.Price * 1.08m;
                            var discountPercent = oldPrice > 0
                                ? Math.Round((oldPrice - item.Price) / oldPrice * 100)
                                : 0;
                            var imageSrc = ProductImageHelper.ResolveProductImage(item);

                            <div class="deal-col">
                                <div class="product-card">
                                    <a asp-action="Details" asp-controller="Product" asp-route-Id="@item.Id" class="product-thumb-wrap">
                                        @if (!string.IsNullOrWhiteSpace(imageSrc))
                                        {
                                            <img src="@imageSrc" class="product-thumb" alt="@item.Name" />
                                        }
                                        else
                                        {
                                            <div class="thumb-placeholder">
                                                <i class="fa fa-image"></i>
                                            </div>
                                        }
                                    </a>

                                    <div class="product-body">
                                        <a asp-action="Details" asp-controller="Product" asp-route-Id="@item.Id" style="text-decoration:none;">
                                            <div class="product-name">@item.Name</div>
                                        </a>

                                        <div class="price-current">@item.Price.ToString("#,##0")đ</div>

                                        <div class="price-old-row">
                                            <div class="price-old">@oldPrice.ToString("#,##0")đ</div>
                                            <div class="discount-badge">-@discountPercent%</div>
                                        </div>

                                        <div class="product-footer">
                                            <div class="product-action-row">
                                                @if (item.Quantity > 0)
                                                {
                                                    <button type="button" class="btn-cart-main add-to-cart" data-product_id="@item.Id">
                                                        <span class="cart-icon-box">
                                                            <i class="fa fa-shopping-cart"></i>
                                                        </span>
                                                        <span class="cart-label">THÊM VÀO GIỎ</span>
                                                    </button>
                                                    <span class="stock-badge">Còn hàng</span>
                                                }
                                                else
                                                {
                                                    <button type="button" class="btn-cart-main" disabled>
                                                        <span class="cart-icon-box">
                                                            <i class="fa fa-shopping-cart"></i>
                                                        </span>
                                                        <span class="cart-label">Hết hàng</span>
                                                    </button>
                                                    <span class="stock-badge out">Hết hàng</span>
                                                }
                                            </div>

                                            @if (canUseWishlistAndCompare)
                                            {
                                                <div class="mini-actions">
                                                    <button type="button" class="btn add-btn-wishlist" data-product_id="@item.Id">Yêu thích</button>
                                                    <button type="button" class="btn add-btn-compare" data-product_id="@item.Id">So sánh</button>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <button type="button" class="deal-nav deal-next" id="hotDealNext">
                    <i class="fa fa-chevron-right"></i>
                </button>
            </div>
        </div>
    }

    @if (recommendedProducts.Any())
    {
        <div class="section-block">
            <div class="section-header">
                <div class="section-title-ribbon">Gợi ý cho bạn</div>
            </div>

            <div class="products-scroll-wrap">
                <div class="products-scroll" id="recommendedScroll">
                    @foreach (var item in recommendedProducts)
                    {
                        var oldPrice = item.Price * 1.08m;
                        var discountPercent = oldPrice > 0
                            ? Math.Round((oldPrice - item.Price) / oldPrice * 100)
                            : 0;
                        var imageSrc = ProductImageHelper.ResolveProductImage(item);

                        <div class="category-col">
                            <div class="product-card">
                                <a asp-action="Details" asp-controller="Product" asp-route-Id="@item.Id" class="product-thumb-wrap">
                                    @if (!string.IsNullOrWhiteSpace(imageSrc))
                                    {
                                        <img src="@imageSrc" class="product-thumb" alt="@item.Name" />
                                    }
                                    else
                                    {
                                        <div class="thumb-placeholder">
                                            <i class="fa fa-image"></i>
                                        </div>
                                    }
                                </a>

                                <div class="product-body">
                                    <a asp-action="Details" asp-controller="Product" asp-route-Id="@item.Id" style="text-decoration:none;">
                                        <div class="product-name">@item.Name</div>
                                    </a>

                                    <div class="price-current">@item.Price.ToString("#,##0")đ</div>

                                    <div class="price-old-row">
                                        <div class="price-old">@oldPrice.ToString("#,##0")đ</div>
                                        <div class="discount-badge">-@discountPercent%</div>
                                    </div>

                                    <div class="product-footer">
                                        <div class="product-action-row">
                                            @if (item.Quantity > 0)
                                            {
                                                <button type="button" class="btn-cart-main add-to-cart" data-product_id="@item.Id">
                                                    <span class="cart-icon-box">
                                                        <i class="fa fa-shopping-cart"></i>
                                                    </span>
                                                    <span class="cart-label">THÊM VÀO GIỎ</span>
                                                </button>
                                                <span class="stock-badge">Còn hàng</span>
                                            }
                                            else
                                            {
                                                <button type="button" class="btn-cart-main" disabled>
                                                    <span class="cart-icon-box">
                                                        <i class="fa fa-shopping-cart"></i>
                                                    </span>
                                                    <span class="cart-label">Hết hàng</span>
                                                </button>
                                                <span class="stock-badge out">Hết hàng</span>
                                            }
                                        </div>

                                        @if (canUseWishlistAndCompare)
                                        {
                                            <div class="mini-actions">
                                                <button type="button" class="btn add-btn-wishlist" data-product_id="@item.Id">Yêu thích</button>
                                                <button type="button" class="btn add-btn-compare" data-product_id="@item.Id">So sánh</button>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    @for (int i = 0; i < categoryGroups.Count; i++)
    {
        var category = categoryGroups[i];
        var scrollId = "categoryScroll_" + i;
        var prevId = "categoryPrev_" + i;
        var nextId = "categoryNext_" + i;

        <div class="section-block">
            <div class="section-header">
                <div class="section-title-ribbon">@category.CategoryName</div>
                <a asp-controller="Product" asp-action="Category" asp-route-id="@category.CategoryId" class="section-link">Xem tất cả »</a>
            </div>

            <div class="products-scroll-wrap">
                <button type="button" class="scroll-nav prev hidden" id="@prevId">
                    <i class="fa fa-chevron-left"></i>
                </button>

                <div class="products-scroll" id="@scrollId">
                    @foreach (var item in category.Products)
                    {
                        var oldPrice = item.Price * 1.08m;
                        var discountPercent = oldPrice > 0
                            ? Math.Round((oldPrice - item.Price) / oldPrice * 100)
                            : 0;
                        var imageSrc = ProductImageHelper.ResolveProductImage(item);

                        <div class="category-col">
                            <div class="product-card">
                                <a asp-action="Details" asp-controller="Product" asp-route-Id="@item.Id" class="product-thumb-wrap">
                                    @if (!string.IsNullOrWhiteSpace(imageSrc))
                                    {
                                        <img src="@imageSrc" class="product-thumb" alt="@item.Name" />
                                    }
                                    else
                                    {
                                        <div class="thumb-placeholder">
                                            <i class="fa fa-image"></i>
                                        </div>
                                    }
                                </a>

                                <div class="product-body">
                                    <a asp-action="Details" asp-controller="Product" asp-route-Id="@item.Id" style="text-decoration:none;">
                                        <div class="product-name">@item.Name</div>
                                    </a>

                                    <div class="price-current">@item.Price.ToString("#,##0")đ</div>

                                    <div class="price-old-row">
                                        <div class="price-old">@oldPrice.ToString("#,##0")đ</div>
                                        <div class="discount-badge">-@discountPercent%</div>
                                    </div>

                                    <div class="product-footer">
                                        <div class="product-action-row">
                                            @if (item.Quantity > 0)
                                            {
                                                <button type="button" class="btn-cart-main add-to-cart" data-product_id="@item.Id">
                                                    <span class="cart-icon-box">
                                                        <i class="fa fa-shopping-cart"></i>
                                                    </span>
                                                    <span class="cart-label">THÊM VÀO GIỎ</span>
                                                </button>
                                                <span class="stock-badge">Còn hàng</span>
                                            }
                                            else
                                            {
                                                <button type="button" class="btn-cart-main" disabled>
                                                    <span class="cart-icon-box">
                                                        <i class="fa fa-shopping-cart"></i>
                                                    </span>
                                                    <span class="cart-label">Hết hàng</span>
                                                </button>
                                                <span class="stock-badge out">Hết hàng</span>
                                            }
                                        </div>

                                        @if (canUseWishlistAndCompare)
                                        {
                                            <div class="mini-actions">
                                                <button type="button" class="btn add-btn-wishlist" data-product_id="@item.Id">Yêu thích</button>
                                                <button type="button" class="btn add-btn-compare" data-product_id="@item.Id">So sánh</button>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <button type="button" class="scroll-nav next hidden" id="@nextId">
                    <i class="fa fa-chevron-right"></i>
                </button>
            </div>
        </div>
    }
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script>
        $(document).ready(function () {
            function setupDealCarousel() {
                var $track = $('#hotDealTrack');
                var $prev = $('#hotDealPrev');
                var $next = $('#hotDealNext');
                var $box = $('.deal-carousel-box');

                if (!$track.length) return;

                var currentIndex = 0;
                var autoTimer = null;

                function getVisibleCount() {
                    var width = window.innerWidth;
                    if (width < 768) return 1;
                    if (width < 992) return 2;
                    if (width < 1200) return 3;
                    return 4;
                }

                function getStepWidth() {
                    var $first = $track.find('.deal-col').first();
                    return $first.length ? $first.outerWidth(true) : 0;
                }

                function getMaxIndex() {
                    var total = $track.find('.deal-col').length;
                    var visible = getVisibleCount();
                    return Math.max(0, total - visible);
                }

                function updateCarousel(animate) {
                    var stepWidth = getStepWidth();
                    var translateX = currentIndex * stepWidth;

                    if (!animate) {
                        $track.css('transition', 'none');
                        $track.css('transform', 'translateX(-' + translateX + 'px)');
                        $track[0].offsetHeight;
                        $track.css('transition', 'transform .35s ease');
                    } else {
                        $track.css('transform', 'translateX(-' + translateX + 'px)');
                    }

                    var maxIndex = getMaxIndex();
                    $prev.prop('disabled', currentIndex <= 0);
                    $next.prop('disabled', currentIndex >= maxIndex);
                }

                function nextSlide() {
                    var maxIndex = getMaxIndex();
                    currentIndex = currentIndex < maxIndex ? currentIndex + 1 : 0;
                    updateCarousel(true);
                }

                function prevSlide() {
                    var maxIndex = getMaxIndex();
                    currentIndex = currentIndex > 0 ? currentIndex - 1 : maxIndex;
                    updateCarousel(true);
                }

                function startAuto() {
                    stopAuto();
                    autoTimer = setInterval(function () {
                        nextSlide();
                    }, 2800);
                }

                function stopAuto() {
                    if (autoTimer) {
                        clearInterval(autoTimer);
                        autoTimer = null;
                    }
                }

                $next.on('click', nextSlide);
                $prev.on('click', prevSlide);

                $box.on('mouseenter', stopAuto);
                $box.on('mouseleave', startAuto);

                $(window).on('resize', function () {
                    var maxIndex = getMaxIndex();
                    if (currentIndex > maxIndex) currentIndex = maxIndex;
                    updateCarousel(false);
                });

                updateCarousel(false);
                startAuto();
            }

            function setupHorizontalScroll(scrollSelector, prevSelector, nextSelector) {
                var $scroll = $(scrollSelector);
                var $prev = $(prevSelector);
                var $next = $(nextSelector);

                if (!$scroll.length) return;

                function getStep() {
                    var firstCard = $scroll.find('.category-col').first();
                    if (!firstCard.length) return 280;
                    return firstCard.outerWidth(true);
                }

                function updateButtons() {
                    var el = $scroll.get(0);
                    if (!el) return;

                    var maxScroll = el.scrollWidth - el.clientWidth;

                    if (maxScroll <= 5) {
                        $prev.addClass('hidden');
                        $next.addClass('hidden');
                        return;
                    }

                    $prev.removeClass('hidden');
                    $next.removeClass('hidden');

                    if (el.scrollLeft <= 5) $prev.addClass('hidden');
                    if (el.scrollLeft >= maxScroll - 5) $next.addClass('hidden');
                }

                $prev.on('click', function () {
                    $scroll.stop().animate({
                        scrollLeft: $scroll.scrollLeft() - getStep()
                    }, 320);
                });

                $next.on('click', function () {
                    $scroll.stop().animate({
                        scrollLeft: $scroll.scrollLeft() + getStep()
                    }, 320);
                });

                $scroll.on('scroll', updateButtons);
                $(window).on('resize', updateButtons);

                updateButtons();
            }

            setupDealCarousel();

            $('[id^="categoryScroll_"]').each(function () {
                var id = $(this).attr('id').replace('categoryScroll_', '');
                setupHorizontalScroll('#categoryScroll_' + id, '#categoryPrev_' + id, '#categoryNext_' + id);
            });

                    $('.add-to-cart').click(function () {
            var productId = $(this).data('product_id');
            var token = $('input[name="__RequestVerificationToken"]').val();

            $.ajax({
                url: '@Url.Action("Add", "Cart")',
                type: 'POST',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                },
                data: {
                    ProductId: productId,
                    Quantity: 1,
                    __RequestVerificationToken: token
                },
                success: function (response) {
                     if (response && typeof response.totalItems !== 'undefined') {
                        window.updateCartBadge(response.totalItems);
                     }

                    Swal.fire({
                        icon: "success",
                        title: "Thành công",
                        text: response && response.message ? response.message : "Đã thêm vào giỏ hàng!"
                    });
                },
                error: function (xhr) {
                    var response = xhr.responseJSON;
                    Swal.fire({
                        icon: "error",
                        title: "Oops...",
                        text: (response && response.message) || xhr.responseText || ("Lỗi (" + xhr.status + ")")
                    });
                }
            });
        });

            $('.add-btn-wishlist').click(function () {
                var productId = $(this).data('product_id');
                var token = $('input[name="__RequestVerificationToken"]').val();

                $.ajax({
                    url: '@Url.Action("AddWishlist", "Home")',
                    type: 'POST',
                    data: {
                        productId: productId,
                        __RequestVerificationToken: token
                    },
                    success: function (response) {
                        Swal.fire({
                            icon: "success",
                            title: "Thành công",
                            text: response && response.message ? response.message : "Đã thêm vào yêu thích!"
                        });
                    },
                    error: function (xhr) {
                        var response = xhr.responseJSON;
                        Swal.fire({
                            icon: "error",
                            title: "Oops...",
                            text: (response && response.message) || xhr.responseText || ("Lỗi (" + xhr.status + ")")
                        });
                    }
                });
            });

            $('.add-btn-compare').click(function () {
                var productId = $(this).data('product_id');
                var token = $('input[name="__RequestVerificationToken"]').val();

                $.ajax({
                    url: '@Url.Action("AddCompare", "Home")',
                    type: 'POST',
                    data: {
                        productId: productId,
                        __RequestVerificationToken: token
                    },
                    success: function (response) {
                        Swal.fire({
                            icon: "success",
                            title: "Thành công",
                            text: response && response.message ? response.message : "Đã thêm vào so sánh!"
                        });
                    },
                    error: function (xhr) {
                        var response = xhr.responseJSON;
                        Swal.fire({
                            icon: "error",
                            title: "Oops...",
                            text: (response && response.message) || xhr.responseText || ("Lỗi (" + xhr.status + ")")
                        });
                    }
                });
            });
        });
    </script>
}
