@using System.Linq
@model IEnumerable<Eshop.Models.ProductModel>

@{
    ViewData["Title"] = "Home Page";

    var productList = Model?.ToList() ?? new List<Eshop.Models.ProductModel>();

    var hotSlides = productList
        .Take(15)
        .Select((item, index) => new { item, index })
        .GroupBy(x => x.index / 5)
        .Select(g => g.Select(x => x.item).ToList())
        .ToList();

    var categoryGroups = productList
        .Where(x => x.Category != null)
        .GroupBy(x => new
        {
            CategoryId = x.Category.Id,
            CategoryName = x.Category.Name
        })
        .Select(g => new
        {
            CategoryId = g.Key.CategoryId,
            CategoryName = g.Key.CategoryName,
            Products = g.ToList()
        })
        .ToList();


    var recommendedProducts = ViewBag.RecommendedProducts as List<Eshop.Models.ProductModel>
    ?? new List<Eshop.Models.ProductModel>();
}

<link rel="stylesheet" href="~/css/home-index.css" />

<div class="col-sm-12 home-page-wrapper">

    @if (recommendedProducts.Any())
    {
        <div class="section-block">
            <div class="section-header">
                <div class="section-title-ribbon">Gợi ý cho bạn</div>
            </div>

            <div class="products-scroll-wrap">
                <div class="products-scroll" style="overflow-x:auto;">
                    @foreach (var item in recommendedProducts)
                    {
                        var oldPrice = item.Price * 1.08m;
                        var discountPercent = oldPrice > 0
                            ? Math.Round((oldPrice - item.Price) / oldPrice * 100)
                            : 0;

                        <div class="category-col">
                            <div class="product-card">
                                <a asp-action="Details" asp-controller="Product" asp-route-Id="@item.Id" class="product-thumb-wrap">
                                    @if (!string.IsNullOrWhiteSpace(item.Image))
                                    {
                                        var imageSrc = item.Image.StartsWith("http://") || item.Image.StartsWith("https://")
                                            ? item.Image
                                            : Url.Content("~/media/products/" + item.Image);

                                        <img src="@imageSrc"
                                             class="product-thumb"
                                             alt="@item.Name" />
                                    }
                                    else
                                    {
                                        <div class="thumb thumb-placeholder">
                                            <i class="fa fa-image"></i>
                                        </div>
                                    }
                                </a>

                                <div class="product-body">
                                    <a asp-action="Details" asp-controller="Product" asp-route-Id="@item.Id" style="text-decoration:none;">
                                        <div class="product-name">@item.Name</div>
                                    </a>

                                    <div class="price-current">@item.Price.ToString("#,##0")đ</div>

                                    <div class="price-old-row">
                                        <div class="price-old">@oldPrice.ToString("#,##0")đ</div>
                                        <div class="discount-badge">-@discountPercent%</div>
                                    </div>

                                    <div class="product-footer">
                                        <div class="product-action-row">
                                            @if (item.Quantity > 0)
                                            {
                                                <button type="button" class="btn btn-cart-main add-to-cart" data-product_id="@item.Id">
                                                    <span class="cart-icon-box">
                                                        <i class="fa fa-shopping-cart"></i>
                                                    </span>
                                                    <span class="cart-label">THÊM VÀO GIỎ</span>
                                                </button>
                                                <span class="stock-badge">Còn hàng</span>
                                            }
                                            else
                                            {
                                                <button type="button" class="btn btn-cart-main" disabled>
                                                    <span class="cart-icon-box">
                                                        <i class="fa fa-shopping-cart"></i>
                                                    </span>
                                                    <span class="cart-label">HẾT HÀNG</span>
                                                </button>
                                                <span class="stock-badge out">Hết hàng</span>
                                            }
                                        </div>

                                        @if (User.IsCustomerOnly())
                                        {
                                            <div class="mini-actions">
                                                <button class="btn add-btn-wishlist" data-product_id="@item.Id">Yêu thích</button>
                                                <button class="btn add-btn-compare" data-product_id="@item.Id">So sánh</button>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }




    @if (hotSlides.Any())
    {
        <div class="section-block deal-hot-section">
            <h2 class="deal-hot-title">Deal hot mỗi ngày - khuyến mãi liền tay</h2>

            <div class="deal-carousel-box">
                <div id="hotDealCarousel" class="carousel slide" data-ride="carousel" data-interval="2600">
                    <div class="carousel-inner carousel-inner-custom">
                        @for (int i = 0; i < hotSlides.Count; i++)
                        {
                            var slide = hotSlides[i];

                            <div class="item @(i == 0 ? "active" : "")">
                                <div class="slide-row">
                                    @foreach (var item in slide)
                                    {
                                        var oldPrice = item.Price * 1.08m;
                                        var discountPercent = oldPrice > 0
                                            ? Math.Round((oldPrice - item.Price) / oldPrice * 100)
                                            : 0;

                                        <div class="deal-col">
                                            <div class="product-card">
                                                <a asp-action="Details" asp-controller="Product" asp-route-Id="@item.Id" class="product-thumb-wrap">
                                                    <img class="product-thumb" src="~/media/products/@item.Image" alt="@item.Name" />
                                                </a>

                                                <div class="product-body">
                                                    <a asp-action="Details" asp-controller="Product" asp-route-Id="@item.Id" style="text-decoration:none;">
                                                        <div class="product-name">@item.Name</div>
                                                    </a>

                                                    <div class="price-current">@item.Price.ToString("#,##0")đ</div>

                                                    <div class="price-old-row">
                                                        <div class="price-old">@oldPrice.ToString("#,##0")đ</div>
                                                        <div class="discount-badge">-@discountPercent%</div>
                                                    </div>

                                                    <div class="product-footer">
                                                        <div class="product-action-row">
                                                            @if (item.Quantity > 0)
                                                            {
                                                                <button type="button" class="btn-cart-main add-to-cart" data-product_id="@item.Id">
                                                                    <span class="cart-icon-box">
                                                                        <i class="fa fa-shopping-cart"></i>
                                                                    </span>
                                                                    <span class="cart-label">THÊM VÀO GIỎ</span>
                                                                </button>
                                                                <span class="stock-badge">Còn hàng</span>
                                                            }
                                                            else
                                                            {
                                                                <button type="button" class="btn-cart-main" disabled>
                                                                    <span class="cart-icon-box">
                                                                        <i class="fa fa-shopping-cart"></i>
                                                                    </span>
                                                                    <span class="cart-label">HẾT HÀNG</span>
                                                                </button>
                                                                <span class="stock-badge out">Hết hàng</span>
                                                            }
                                                        </div>

                                                        @if (User.IsCustomerOnly())
                                                        {
                                                            <div class="mini-actions">
                                                                <button class="btn add-btn-wishlist" data-product_id="@item.Id">Yêu thích</button>
                                                                <button class="btn add-btn-compare" data-product_id="@item.Id">So sánh</button>
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>

                    @if (hotSlides.Count > 1)
                    {
                        <a class="left carousel-control" href="#hotDealCarousel" data-slide="prev">
                            <span class="glyphicon glyphicon-chevron-left"></span>
                        </a>
                        <a class="right carousel-control" href="#hotDealCarousel" data-slide="next">
                            <span class="glyphicon glyphicon-chevron-right"></span>
                        </a>
                    }
                </div>
            </div>
        </div>
    }

    @for (int i = 0; i < categoryGroups.Count; i++)
    {
        var category = categoryGroups[i];
        var scrollId = "categoryScroll_" + i;
        var prevId = "categoryPrev_" + i;
        var nextId = "categoryNext_" + i;

        <div class="section-block">
            <div class="section-header">
                <div class="section-title-ribbon">@category.CategoryName</div>
                <a href="#" class="section-link">Xem tất cả &raquo;</a>
            </div>

            <div class="products-scroll-wrap">
                <button type="button" class="scroll-nav prev hidden" id="@prevId">
                    <i class="fa fa-chevron-left"></i>
                </button>

                <div class="products-scroll" id="@scrollId">
                    @foreach (var item in category.Products)
                    {
                        var oldPrice = item.Price * 1.08m;
                        var discountPercent = oldPrice > 0
                            ? Math.Round((oldPrice - item.Price) / oldPrice * 100)
                            : 0;

                        <div class="category-col">
                            <div class="product-card">
                                <a asp-action="Details" asp-controller="Product" asp-route-Id="@item.Id" class="product-thumb-wrap">
                                    @if (!string.IsNullOrWhiteSpace(item.Image))
                                    {
                                        var imageSrc = item.Image.StartsWith("http://") || item.Image.StartsWith("https://")
                                            ? item.Image
                                            : Url.Content("~/media/products/" + item.Image);

                                        <img src="@imageSrc"
                                             class="product-thumb"
                                             alt="@item.Name" />
                                    }
                                    else
                                    {
                                        <div class="thumb thumb-placeholder">
                                            <i class="fa fa-image"></i>
                                        </div>
                                    }
                                </a>

                                <div class="product-body">
                                    <a asp-action="Details" asp-controller="Product" asp-route-Id="@item.Id" style="text-decoration:none;">
                                        <div class="product-name">@item.Name</div>
                                    </a>

                                    <div class="price-current">@item.Price.ToString("#,##0")đ</div>

                                    <div class="price-old-row">
                                        <div class="price-old">@oldPrice.ToString("#,##0")đ</div>
                                        <div class="discount-badge">-@discountPercent%</div>
                                    </div>

                                    <div class="product-footer">
                                        <div class="product-action-row">
                                            @if (item.Quantity > 0)
                                            {
                                                <button type="button" class="btn btn-cart-main add-to-cart" data-product_id="@item.Id">
                                                    <span class="cart-icon-box">
                                                        <i class="fa fa-shopping-cart"></i>
                                                    </span>
                                                    <span class="cart-label">THÊM VÀO GIỎ</span>
                                                </button>
                                                <span class="stock-badge">Còn hàng</span>
                                            }
                                            else
                                            {
                                                <button type="button" class="btn btn-cart-main" disabled>
                                                    <span class="cart-icon-box">
                                                        <i class="fa fa-shopping-cart"></i>
                                                    </span>
                                                    <span class="cart-label">HẾT HÀNG</span>
                                                </button>
                                                <span class="stock-badge out">Hết hàng</span>
                                            }
                                        </div>

                                        @if (User.IsCustomerOnly())
                                        {
                                            <div class="mini-actions">
                                                <button class="btn add-btn-wishlist" data-product_id="@item.Id">Yêu thích</button>
                                                <button class="btn add-btn-compare" data-product_id="@item.Id">So sánh</button>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <button type="button" class="scroll-nav next hidden" id="@nextId">
                    <i class="fa fa-chevron-right"></i>
                </button>
            </div>
        </div>
    }
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script>
        $(document).ready(function () {
            if ($('#hotDealCarousel').length) {
                $('#hotDealCarousel').carousel({
                    interval: 2600,
                    pause: "hover"
                });
            }

            function setupHorizontalScroll(scrollSelector, prevSelector, nextSelector) {
                var $scroll = $(scrollSelector);
                var $prev = $(prevSelector);
                var $next = $(nextSelector);

                if (!$scroll.length) return;

                function getStep() {
                    var firstCard = $scroll.find('.category-col').first();
                    if (!firstCard.length) return 300;
                    return firstCard.outerWidth(true) * 2;
                }

                function updateButtons() {
                    var el = $scroll.get(0);
                    if (!el) return;

                    var maxScroll = el.scrollWidth - el.clientWidth;

                    if (maxScroll <= 5) {
                        $prev.addClass('hidden');
                        $next.addClass('hidden');
                        return;
                    }

                    $prev.removeClass('hidden');
                    $next.removeClass('hidden');

                    if (el.scrollLeft <= 5) {
                        $prev.addClass('hidden');
                    }

                    if (el.scrollLeft >= maxScroll - 5) {
                        $next.addClass('hidden');
                    }
                }

                $prev.on('click', function () {
                    $scroll.animate({
                        scrollLeft: $scroll.scrollLeft() - getStep()
                    }, 320);
                });

                $next.on('click', function () {
                    $scroll.animate({
                        scrollLeft: $scroll.scrollLeft() + getStep()
                    }, 320);
                });

                $scroll.on('scroll', updateButtons);
                $(window).on('resize', updateButtons);

                updateButtons();
            }

            $('[id^="categoryScroll_"]').each(function () {
                var id = $(this).attr('id').replace('categoryScroll_', '');
                setupHorizontalScroll('#categoryScroll_' + id, '#categoryPrev_' + id, '#categoryNext_' + id);
            });

            $('.add-to-cart').click(function () {
                var productId = $(this).data('product_id');
                var token = $('input[name="__RequestVerificationToken"]').val();

                $.ajax({
                    url: '@Url.Action("Add", "Cart")',
                    type: 'POST',
                    data: {
                        id: productId,
                        __RequestVerificationToken: token
                    },
                    success: function () {
                        Swal.fire({
                            icon: "success",
                            title: "Thành công",
                            text: "Đã thêm vào giỏ hàng!"
                        });
                    },
                    error: function (xhr) {
                        Swal.fire({
                            icon: "error",
                            title: "Oops...",
                            text: "Có lỗi xảy ra! (" + xhr.status + ")"
                        });
                    }
                });
            });

            $('.add-btn-wishlist').click(function () {
                var productId = $(this).data('product_id');
                var token = $('input[name="__RequestVerificationToken"]').val();

                $.ajax({
                    url: '@Url.Action("AddWishlist", "Home")',
                    type: 'POST',
                    data: {
                        productId: productId,
                        __RequestVerificationToken: token
                    },
                    success: function (response) {
                        Swal.fire({
                            icon: "success",
                            title: "Thành công",
                            text: response && response.message ? response.message : "Đã thêm vào yêu thích!"
                        });
                    },
                    error: function (xhr) {
                        var response = xhr.responseJSON;
                        Swal.fire({
                            icon: "error",
                            title: "Oops...",
                            text: (response && response.message) || xhr.responseText || ("Lỗi (" + xhr.status + ")")
                        });
                    }
                });
            });

            $('.add-btn-compare').click(function () {
                var productId = $(this).data('product_id');
                var token = $('input[name="__RequestVerificationToken"]').val();

                $.ajax({
                    url: '@Url.Action("AddCompare", "Home")',
                    type: 'POST',
                    data: {
                        productId: productId,
                        __RequestVerificationToken: token
                    },
                    success: function (response) {
                        Swal.fire({
                            icon: "success",
                            title: "Thành công",
                            text: response && response.message ? response.message : "Đã thêm vào so sánh!"
                        });
                    },
                    error: function (xhr) {
                        var response = xhr.responseJSON;
                        Swal.fire({
                            icon: "error",
                            title: "Oops...",
                            text: (response && response.message) || xhr.responseText || ("Lỗi (" + xhr.status + ")")
                        });
                    }
                });
            });
        });
    </script>
}
