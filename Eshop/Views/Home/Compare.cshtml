@using Eshop.Views.ViewModels
@model List<CompareItemVM>

@{
    ViewData["title"] = "List Compare";
}

<h3>List Compare</h3>

<table class="table" id="myTable">
    <thead>
        <tr>
            <th>Compare Id</th>
            <th>Product Name</th>
            <th>Product Description</th>
            <th>Product Price</th>
            <th>Product Image</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <th scope="row">@item.Compare.Id</th>

                <td>@item.Product.Name</td>
                <td>@item.Product.Description</td>
                <td>@item.Product.Price</td>

                <td>
                    <img src="~/media/products/@item.Product.Image" width="100" height="80" />
                </td>

                <td>
                    <a asp-action="DeleteCompare"
                       asp-controller="Home"
                       asp-route-id="@item.Compare.Id"
                       class="btn btn-primary confirmDeletion">
                        Delete
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
