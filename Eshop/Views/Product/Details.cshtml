                            <img src="~/media/products/@Model.ProductDetail.Image" alt="@Model.ProductDetail.Name" />
                        </div>
                    </div>
                </div>

                <div class="col-sm-6">
                    <div class="product-information" style="padding-top:0;">
                        <h2 class="product-title-custom">@Model.ProductDetail.Name</h2>

                        <div class="price-box-custom">
                            <div class="price-current" id="displayFinalPrice">@basePrice.ToString("#,##0 đ")</div>
                            <div class="price-note">
                                Giá gốc:
                                <strong id="displayBasePrice">@basePrice.ToString("#,##0 đ")</strong>
                                <span id="displayUpgradePrice" style="margin-left:12px;">
                                    Nâng cấp: +0 đ
                                </span>
                            </div>
                        </div>

                        <div class="product-meta-custom">
                            <p><b>Tình trạng:</b> @(Model.ProductDetail.Quantity > 0 ? "Còn hàng" : "Hết hàng")</p>
                            <p><b>Nhà xuất bản:</b> @Model.ProductDetail.Publisher?.Name</p>
                            <p><b>Thể loại:</b> @Model.ProductDetail.Category?.Name</p>
                        </div>

                        <div class="desc-box-custom">
                            <div class="section-head-custom">Mô tả sản phẩm</div>
                            <div class="section-body-custom product-desc-html">
                                @Html.Raw(Model.ProductDetail.Description)
                            </div>
                        </div>

                        <form asp-action="Add" asp-controller="Cart" method="post" id="productAddToCartForm">
                            @Html.AntiForgeryToken()

                            <input type="hidden" asp-for="ProductId" value="@Model.ProductDetail.Id" />

                            @if (hasUpgradeOptions)
                            {
                                <div class="upgrade-box-custom">
                                    <div class="section-head-custom">Upgrade</div>
                                    <div class="section-body-custom">
                                        @for (int i = 0; i < optionGroups.Count; i++)
                                        {
                                            var group = optionGroups[i];
                                            var activeOptions = group.OptionValues
                                                .Where(x => x.Status == 1)
                                                .OrderBy(x => x.SortOrder)
                                                .ToList();

                                            var defaultOption = activeOptions.FirstOrDefault(x => x.IsDefault) ?? activeOptions.FirstOrDefault();

                                            <div class="upgrade-row">
                                                <div class="upgrade-label">@group.Name</div>
                                                <div class="upgrade-options">
                                                    <input type="hidden" name="SelectedOptions[@i].GroupId" value="@group.Id" />

                                                    @for (int j = 0; j < activeOptions.Count; j++)
                                                    {
                                                        var option = activeOptions[j];
                                                        var optionId = $"group_{group.Id}_option_{option.Id}";
                                                        var isChecked = defaultOption != null && defaultOption.Id == option.Id;

                                                        <input type="radio"
                                                               id="@optionId"
                                                               class="upgrade-option-input option-price-input"
                                                               name="SelectedOptions[@i].ValueId"
                                                               value="@option.Id"
                                                               data-price="@option.AdditionalPrice"
                                                        @(isChecked ? "checked" : "") />

                                                        <label for="@optionId" class="upgrade-option-label">
                                                            @option.Value
                                                            <small>
                                                                @(option.AdditionalPrice > 0
                                                                    ? "+" + option.AdditionalPrice.ToString("#,##0 đ")
                                                                    : "+0 đ")
                                                            </small>
                                                        </label>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }

                            <div class="cart-box-custom">
                                <div class="final-price-box">
                                    <div class="final-price-label">Giá tạm tính</div>
                                    <div class="final-price-value" id="displayFinalPriceBottom">@basePrice.ToString("#,##0 đ")</div>
                                </div>

                                <div class="qty-wrap-custom">
                                    <label for="Quantity">Số lượng:</label>
                                    <input asp-for="Quantity" type="number" min="1" class="qty-input-custom" />
                                </div>

                                @if (Model.ProductDetail.Quantity > 0)
                                {
                                    <button type="submit" class="btn-add-cart-custom">
                                        <i class="fa fa-shopping-cart"></i> Thêm vào giỏ hàng
                                    </button>
                                }
                                else
                                {
                                    <button type="button" class="stock-out-btn" disabled>
                                        <i class="fa fa-shopping-cart"></i> Hết hàng
                                    </button>
                                }
                            </div>
                        </form>

                        <a href="#">
                            <img src="~/images/product-details/share.png" class="share img-responsive" alt="" />
                        </a>
                    </div>
                </div>
            </div>
