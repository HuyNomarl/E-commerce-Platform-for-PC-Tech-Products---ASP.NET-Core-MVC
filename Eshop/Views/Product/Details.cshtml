@model Eshop.Models.ViewModels.ProductDetailViewModel

@{
    var optionGroups = Model.ProductDetail.OptionGroups?
        .Where(g => g.OptionValues != null && g.OptionValues.Any(v => v.Status == 1))
        .ToList()
        ?? new List<Eshop.Models.ProductOptionGroupModel>();

    var hasUpgradeOptions = optionGroups.Any();
    var basePrice = Model.ProductDetail.Price;
}

<style>
    .product-detail-wrap {
        background: #fff;
        padding: 15px;
    }

    .product-gallery-main {
        border: 1px solid #eee;
        padding: 10px;
        margin-bottom: 12px;
        background: #fff;
    }

        .product-gallery-main img {
            width: 100%;
            height: auto;
            object-fit: cover;
        }

    .thumb-list {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .thumb-item {
        width: 92px;
        height: 72px;
        border: 1px solid #ddd;
        padding: 4px;
        cursor: pointer;
        background: #fff;
    }

        .thumb-item.active,
        .thumb-item:hover {
            border-color: #fe980f;
        }

        .thumb-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .product-title-custom {
        font-size: 30px;
        font-weight: 700;
        line-height: 1.3;
        margin-bottom: 12px;
        color: #222;
    }

    .price-box-custom {
        background: #ff6a00;
        color: #fff;
        border-radius: 8px;
        padding: 16px 20px;
        margin-bottom: 15px;
    }

    .price-current {
        font-size: 38px;
        font-weight: 700;
        line-height: 1;
        margin-bottom: 6px;
    }

    .price-note {
        font-size: 13px;
        opacity: 0.95;
    }

    .product-meta-custom {
        margin-bottom: 15px;
        padding: 10px 0 5px 0;
        border-bottom: 1px dashed #ddd;
    }

        .product-meta-custom p {
            margin-bottom: 8px;
            font-size: 15px;
        }

    .desc-box-custom,
    .upgrade-box-custom {
        border: 1px solid #ddd;
        border-radius: 6px;
        margin-bottom: 18px;
        background: #fff;
    }

    .section-head-custom {
        padding: 12px 16px;
        border-bottom: 1px solid #e5e5e5;
        font-size: 22px;
        font-weight: 700;
        color: #d91c24;
        text-transform: uppercase;
    }

    .section-body-custom {
        padding: 14px 16px;
    }

    .product-desc-html ul {
        padding-left: 18px;
        margin-bottom: 0;
    }

    .product-desc-html li {
        margin-bottom: 6px;
    }

    .upgrade-row {
        display: flex;
        align-items: flex-start;
        gap: 15px;
        padding: 10px 0;
        border-bottom: 1px dashed #ececec;
    }

        .upgrade-row:last-child {
            border-bottom: none;
        }

    .upgrade-label {
        width: 120px;
        min-width: 120px;
        font-size: 21px;
        font-weight: 700;
        color: #222;
        padding-top: 8px;
    }

    .upgrade-options {
        flex: 1;
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .upgrade-option-input {
        display: none;
    }

    .upgrade-option-label {
        display: inline-block;
        padding: 10px 16px;
        border: 1px solid #cfcfcf;
        border-radius: 7px;
        background: #fff;
        color: #444;
        cursor: pointer;
        transition: all 0.2s ease;
        font-size: 15px;
        font-weight: 500;
        position: relative;
        min-width: 135px;
        text-align: center;
    }

        .upgrade-option-label small {
            display: block;
            margin-top: 4px;
            font-size: 12px;
            color: #888;
        }

    .upgrade-option-input:checked + .upgrade-option-label {
        border-color: #ff5a36;
        color: #ff5a36;
        background: #fff7f4;
        box-shadow: 0 0 0 1px #ff5a36 inset;
    }

        .upgrade-option-input:checked + .upgrade-option-label::after {
            content: "✓";
            position: absolute;
            right: 6px;
            bottom: 3px;
            font-size: 12px;
            color: #fff;
            background: #ff5a36;
            width: 18px;
            height: 18px;
            text-align: center;
            line-height: 18px;
            border-radius: 3px 0 6px 0;
        }

    .cart-box-custom {
        border: 1px solid #e5e5e5;
        border-radius: 6px;
        padding: 16px;
        margin-bottom: 20px;
    }

    .qty-wrap-custom {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 15px;
    }

        .qty-wrap-custom label {
            margin-bottom: 0;
            font-weight: 700;
            font-size: 17px;
        }

    .qty-input-custom {
        width: 110px;
        height: 42px;
        border: 1px solid #ccc;
        border-radius: 5px;
        padding: 6px 10px;
    }

    .final-price-box {
        margin-bottom: 15px;
        padding: 12px 14px;
        background: #fff7ed;
        border: 1px dashed #fe980f;
        border-radius: 6px;
    }

    .final-price-label {
        font-size: 14px;
        color: #666;
        margin-bottom: 3px;
    }

    .final-price-value {
        font-size: 30px;
        font-weight: 700;
        color: #fe980f;
    }

    .btn-add-cart-custom {
        background: #fe980f;
        color: #fff;
        border: none;
        border-radius: 6px;
        padding: 12px 22px;
        font-size: 16px;
        font-weight: 700;
    }

        .btn-add-cart-custom:hover {
            background: #e68900;
            color: #fff;
        }

    .stock-out-btn {
        background: #888;
        color: #fff;
        border: none;
        border-radius: 6px;
        padding: 12px 22px;
        font-size: 16px;
        font-weight: 700;
        cursor: not-allowed;
    }

    @@media (max-width: 991px) {
        .upgrade-row {
            flex-direction: column;
        }

        .upgrade-label {
            width: 100%;
            min-width: unset;
            padding-top: 0;
        }

        .product-title-custom {
            font-size: 24px;
        }

        .price-current {
            font-size: 30px;
        }
    }
</style>

<div class="row">
    <div class="col-sm-3">
        @Html.Partial("_SidebarPartial")
    </div>

    <div class="col-sm-9 padding-right">
        <div class="product-detail-wrap">
