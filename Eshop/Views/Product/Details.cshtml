                        </div>

                        <div class="thumb-item" data-image="@Url.Content("~/media/products/" + Model.ProductDetail.Image)">
                            <img src="~/media/products/@Model.ProductDetail.Image" alt="@Model.ProductDetail.Name" />
                        </div>

