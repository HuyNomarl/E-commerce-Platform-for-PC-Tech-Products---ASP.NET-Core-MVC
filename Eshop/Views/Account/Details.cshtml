@model Eshop.Models.ViewModels.UserOrderDetailViewModel

@{
    ViewData["Title"] = "Chi tiết đơn hàng";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-1">Chi tiết đơn hàng</h3>
            <p class="text-muted mb-0">Thông tin giao hàng, thanh toán và các sản phẩm trong đơn</p>
        </div>

        <a asp-controller="Account" asp-action="History" class="btn btn-secondary">
            Quay lại
        </a>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-lg-6">
                    <p class="mb-2"><strong>Mã đơn hàng:</strong> @Model.OrderCode</p>
                    <p class="mb-2"><strong>Tài khoản:</strong> @Model.UserName</p>
                    <p class="mb-2"><strong>Ngày đặt:</strong> @Model.CreatedTime.ToString("dd/MM/yyyy HH:mm")</p>
                    <p class="mb-2"><strong>Người nhận:</strong> @(string.IsNullOrWhiteSpace(Model.FullName) ? "-" : Model.FullName)</p>
                    <p class="mb-2"><strong>Số điện thoại:</strong> @(string.IsNullOrWhiteSpace(Model.Phone) ? "-" : Model.Phone)</p>
                    <p class="mb-0"><strong>Email:</strong> @(string.IsNullOrWhiteSpace(Model.Email) ? "-" : Model.Email)</p>
                </div>

                <div class="col-lg-6">
                    <p class="mb-2">
                        <strong>Trạng thái:</strong>
                        <span class="badge @OrderDisplayHelper.GetBootstrapBadgeClass(Model.Status)">
                            @OrderDisplayHelper.GetStatusLabel(Model.Status)
                        </span>
                    </p>
                    <p class="mb-2">
                        <strong>Phương thức thanh toán:</strong>
                        <span class="@OrderDisplayHelper.GetPaymentMethodBadgeClass(Model.PaymentMethod)">
                            @OrderDisplayHelper.GetPaymentMethodLabel(Model.PaymentMethod)
                        </span>
                    </p>
                    <p class="mb-2"><strong>Địa chỉ giao hàng:</strong> @(string.IsNullOrWhiteSpace(Model.Address) ? "-" : Model.Address)</p>
                    <p class="mb-0"><strong>Ghi chú:</strong> @(string.IsNullOrWhiteSpace(Model.Note) ? "Không có" : Model.Note)</p>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <h5 class="mb-3">Danh sách sản phẩm</h5>

            <table class="table table-bordered table-hover align-middle">
                <thead>
                    <tr>
                        <th>Sản phẩm</th>
                        <th class="text-end">Đơn giá</th>
                        <th class="text-center">Số lượng</th>
                        <th class="text-end">Thành tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.OrderDetails != null && Model.OrderDetails.Any())
                    {
                        foreach (var item in Model.OrderDetails)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@item.ProductName</div>
                                    @if (!string.IsNullOrWhiteSpace(item.BuildName) || !string.IsNullOrWhiteSpace(item.ComponentType))
                                    {
                                        <div class="small text-muted">
                                            @(string.IsNullOrWhiteSpace(item.BuildName) ? item.ComponentType : item.BuildName)
                                            @if (!string.IsNullOrWhiteSpace(item.BuildName) && !string.IsNullOrWhiteSpace(item.ComponentType))
                                            {
                                                <span> - @item.ComponentType</span>
                                            }
                                        </div>
                                    }
                                </td>
                                <td class="text-end">@item.Price.ToString("N0") đ</td>
                                <td class="text-center">@item.Quantity</td>
                                <td class="text-end">@item.LineTotal.ToString("N0") đ</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted">Không có sản phẩm nào trong đơn.</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <th colspan="3" class="text-end">Tạm tính</th>
                        <th class="text-end">@Model.SubTotal.ToString("N0") đ</th>
                    </tr>
                    <tr>
                        <th colspan="3" class="text-end">Giảm giá</th>
                        <th class="text-end">-@Model.DiscountAmount.ToString("N0") đ</th>
                    </tr>
                    <tr>
                        <th colspan="3" class="text-end">Phí vận chuyển</th>
                        <th class="text-end">@Model.ShippingCost.ToString("N0") đ</th>
                    </tr>
                    <tr>
                        <th colspan="3" class="text-end">Tổng cộng</th>
                        <th class="text-end text-danger">@Model.TotalAmount.ToString("N0") đ</th>
                    </tr>
                </tfoot>
            </table>

            @if (Model.CanCancel)
            {
                <form method="post"
                      asp-controller="Account"
                      asp-action="CancelOrder"
                      id="cancelOrderForm"
                      data-swal-confirm
                      data-swal-title="Hủy đơn hàng?"
                      data-swal-text="Sau khi hủy đơn sẽ không thể hoàn tác."
                      data-swal-confirm-text="Có, hủy đơn"
                      data-swal-cancel-text="Không">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="orderCode" value="@Model.OrderCode" />

                    <button type="submit" class="btn btn-danger">
                        Hủy đơn hàng
                    </button>
                </form>
            }
        </div>
    </div>
</div>

<style>
    .payment-badge {
        display: inline-flex;
        align-items: center;
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
        border: 1px solid transparent;
    }

    .payment-badge-cod {
        background: #ecfdf5;
        color: #047857;
        border-color: #a7f3d0;
    }

    .payment-badge-vnpay {
        background: #eff6ff;
        color: #1d4ed8;
        border-color: #bfdbfe;
    }

    .payment-badge-momo {
        background: #fdf2f8;
        color: #be185d;
        border-color: #fbcfe8;
    }

    .payment-badge-bank {
        background: #eef2ff;
        color: #4338ca;
        border-color: #c7d2fe;
    }

    .payment-badge-default {
        background: #f3f4f6;
        color: #374151;
        border-color: #d1d5db;
    }
</style>
