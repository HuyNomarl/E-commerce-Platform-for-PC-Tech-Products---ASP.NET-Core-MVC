@model IEnumerable<Eshop.Models.ViewModels.OrderHistoryViewModel>

@{
    ViewData["Title"] = "Lịch sử đơn hàng";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-1">Lịch sử đơn hàng</h3>
            <p class="text-muted mb-0">Theo dõi trạng thái, thanh toán và tổng tiền của các đơn đã đặt</p>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <table class="table table-striped table-hover align-middle mb-0" id="orderHistoryTable">
                <thead>
                    <tr>
                        <th>Mã đơn hàng</th>
                        <th>Ngày đặt</th>
                        <th>Trạng thái</th>
                        <th>Thanh toán</th>
                        <th>Phí vận chuyển</th>
                        <th>Tổng tiền</th>
                        <th style="width: 220px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@item.OrderCode</td>
                                <td>@item.CreatedTime.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    <span class="badge @OrderDisplayHelper.GetBootstrapBadgeClass(item.Status)">
                                        @OrderDisplayHelper.GetStatusLabel(item.Status)
                                    </span>
                                </td>
                                <td>
                                    <span class="@OrderDisplayHelper.GetPaymentMethodBadgeClass(item.PaymentMethod)">
                                        @OrderDisplayHelper.GetPaymentMethodLabel(item.PaymentMethod)
                                    </span>
                                </td>
                                <td>@item.ShippingCost.ToString("N0") đ</td>
                                <td class="fw-semibold text-danger">@item.TotalAmount.ToString("N0") đ</td>
                                <td>
                                    <a asp-controller="Account"
                                       asp-action="Details"
                                       asp-route-orderCode="@item.OrderCode"
                                       class="btn btn-sm btn-primary">
                                        Xem chi tiết
                                    </a>

                                    @if (item.CanCancel)
                                    {
                                        <form id="cancel-@item.OrderCode"
                                              method="post"
                                              asp-controller="Account"
                                              asp-action="CancelOrder"
                                              class="d-inline-block"
                                              data-swal-confirm
                                              data-swal-title="Hủy đơn hàng?"
                                              data-swal-text="Sau khi hủy đơn sẽ không thể hoàn tác."
                                              data-swal-confirm-text="Có, hủy đơn"
                                              data-swal-cancel-text="Không">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="orderCode" value="@item.OrderCode" />
                                            <button type="submit" class="btn btn-sm btn-danger">
                                                Hủy đơn
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-sm btn-secondary" disabled>
                                            Không thể hủy
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                Bạn chưa có đơn hàng nào.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .payment-badge {
        display: inline-flex;
        align-items: center;
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
        border: 1px solid transparent;
    }

    .payment-badge-cod {
        background: #ecfdf5;
        color: #047857;
        border-color: #a7f3d0;
    }

    .payment-badge-vnpay {
        background: #eff6ff;
        color: #1d4ed8;
        border-color: #bfdbfe;
    }

    .payment-badge-momo {
        background: #fdf2f8;
        color: #be185d;
        border-color: #fbcfe8;
    }

    .payment-badge-bank {
        background: #eef2ff;
        color: #4338ca;
        border-color: #c7d2fe;
    }

    .payment-badge-default {
        background: #f3f4f6;
        color: #374151;
        border-color: #d1d5db;
    }
</style>

@section Scripts {
    <script>
        if (typeof DataTable !== 'undefined') {
            new DataTable('#orderHistoryTable');
        }
    </script>
}
