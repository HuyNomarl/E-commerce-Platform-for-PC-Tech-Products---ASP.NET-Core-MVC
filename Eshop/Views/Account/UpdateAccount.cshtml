@model Eshop.Models.ViewModels.AccountDashboardViewModel

@{
    ViewData["Title"] = "Tài khoản";
}

<link rel="stylesheet" href="~/css/account-dashboard.css" />

<div class="col-sm-12">
    <div class="account-breadcrumb">
        <a asp-controller="Home" asp-action="Index">Trang chủ</a>
        <span>›</span>
        <span>Tài khoản</span>
    </div>

    <div class="account-wrapper">
        <div class="account-sidebar">
            <div class="account-user-box">
                <div class="account-avatar">
                    <i class="fa fa-user"></i>
                </div>
                <div class="account-user-info">
                    <div class="account-label">Tài khoản</div>
                    <div class="account-name">@Model.User?.UserName</div>
                </div>
            </div>

            <ul class="account-menu">
                <li>
                    <a asp-controller="Account" asp-action="UpdateAccount" asp-route-tab="profile"
                           class="@(Model.ActiveTab == "profile" ? "active" : "")">
                        <i class="fa fa-user-circle-o"></i> Thông tin tài khoản
                    </a>
                </li>
                <li>
                    <a asp-controller="Account" asp-action="UpdateAccount" asp-route-tab="orders"
                           class="@(Model.ActiveTab == "orders" ? "active" : "")">
                        <i class="fa fa-file-text-o"></i> Quản lý đơn hàng
                    </a>
                </li>
                <li>
                    <a asp-controller="Account" asp-action="UpdateAccount" asp-route-tab="password"
                           class="@(Model.ActiveTab == "password" ? "active" : "")">
                        <i class="fa fa-lock"></i> Thay đổi mật khẩu
                    </a>
                </li>
                <li>
                    <a asp-controller="Account" asp-action="Logout">
                        <i class="fa fa-power-off"></i> Đăng xuất
                    </a>
                </li>
            </ul>
        </div>

        <div class="account-content">
            @if (Model.ActiveTab == "home")
            {
                <div class="account-panel">
                    <p>Bạn đang ở trang tài khoản. Vui lòng chọn các mục bên trái/bên trên để xem thông tin.</p>
                </div>
            }
            else if (Model.ActiveTab == "profile")
            {
                <div class="account-panel">
                    <h3>Thông tin tài khoản</h3>
                    <hr />

                    <form asp-controller="Account" asp-action="UpdateInfoAccount" method="post">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="form-group">
                            <label>Tên đăng nhập</label>
                            <input asp-for="User.UserName" class="form-control" />
                            <span asp-validation-for="User.UserName" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label>Email</label>
                            <input asp-for="User.Email" class="form-control" />
                            <span asp-validation-for="User.Email" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label>Địa chỉ</label>
                            <input asp-for="User.Address" class="form-control" />
                            <span asp-validation-for="User.Address" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label>Số điện thoại</label>
                            <input asp-for="User.PhoneNumber" class="form-control" />
                            <span asp-validation-for="User.PhoneNumber" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-danger">Cập nhật thông tin</button>
                    </form>
                </div>
            }
            else if (Model.ActiveTab == "orders")
            {
                <div class="account-panel">
                    <h3>Quản lý đơn hàng</h3>
                    <hr />

                    @if (Model.Orders != null && Model.Orders.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-bordered table-striped">
                                <thead>
                                    <tr>
                                        <th>Mã đơn</th>
                                        <th>Ngày tạo</th>
                                        <th>Trạng thái</th>
                                        <th>Tổng tiền</th>
                                        <th>Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in Model.Orders)
                                    {
                                        <tr>
                                            <td>@order.OrderCode</td>
                                            <td>@order.CreatedTime.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td>
                                                @{
                                                    string statusText = order.Status switch
                                                    {
                                                        1 => "Chờ xác nhận",
                                                        2 => "Đã xác nhận",
                                                        3 => "Đang giao",
                                                        4 => "Hoàn thành",
                                                        5 => "Thất bại",
                                                        6 => "Đã hủy",
                                                        _ => "Không xác định"
                                                    };
                                                }
                                                @statusText
                                            </td>
                                            <td>@order.TotalAmount.ToString("#,##0") đ</td>
                                            <td>
                                                <a asp-controller="Account"
                                                       asp-action="Details"
                                                       asp-route-orderCode="@order.OrderCode"
                                                       class="btn btn-info btn-sm">
                                                    Chi tiết
                                                </a>

                                                @if (order.Status == 1)
                                                {
                                                    <form asp-controller="Account"
                                                          asp-action="CancelOrder"
                                                          method="post"
                                                          style="display:inline-block;">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="orderCode" value="@order.OrderCode" />
                                                        <button type="submit" class="btn btn-danger btn-sm"
                                                                onclick="return confirm('Bạn có chắc muốn hủy đơn hàng này?')">
                                                            Hủy đơn
                                                        </button>
                                                    </form>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p>Bạn chưa có đơn hàng nào.</p>
                    }
                </div>
            }
            else if (Model.ActiveTab == "password")
            {
                <div class="account-panel">
                    <h3>Thay đổi mật khẩu</h3>
                    <hr />

                    <form asp-controller="Account" asp-action="ChangePassword" method="post">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="form-group">
                            <label>Mật khẩu hiện tại</label>
                            <input asp-for="ChangePassword.CurrentPassword" class="form-control" />
                            <span asp-validation-for="ChangePassword.CurrentPassword" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label>Mật khẩu mới</label>
                            <input asp-for="ChangePassword.NewPassword" class="form-control" />
                            <span asp-validation-for="ChangePassword.NewPassword" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label>Xác nhận mật khẩu mới</label>
                            <input asp-for="ChangePassword.ConfirmNewPassword" class="form-control" />
                            <span asp-validation-for="ChangePassword.ConfirmNewPassword" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-danger">Đổi mật khẩu</button>
                    </form>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}