@model AppUserModel

@{
    ViewData["Title"] = "Update Account";
}
<section id="form">
    <!--form-->
    <div class="container">
        <div class="row">
            <div class="col-sm-8 col-sm-offset-1">
                <div class="signup-form">
                    <!--sign up form-->
                    <h2>Thay đổi thông tin</h2>
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <form asp-action="UpdateInfoAccount" asp-controller="Account">
                        <div class="form-group">
                            <label>UserName</label>
                            <input asp-for="UserName" class="form-control" />
                            <span asp-validation-for="UserName" class="text-danger" />
                        </div>

                        <div class="form-group">
                            <label>Email</label>
                            <input asp-for="Email" readonly required class="form-control" />
                            <span asp-validation-for="Email" class="text-danger" />
                        </div>

                        <div class="form-group">
                            <label>Phone</label>
                            <input asp-for="PhoneNumber" class="form-control" />
                            <span asp-validation-for="PhoneNumber" class="text-danger" />
                        </div>

                        @* <div class="form-group">
                            <label>Old Password</label>
                            <input type="text" readonly value="@Model.PasswordHash" class="form-control" />
                            <span asp-validation-for="PasswordHash" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label>New Password</label>
                            <input asp-for="PasswordHash" readonly required class="form-control" />
                            <span asp-validation-for="PasswordHash" class="text-danger"></span>
                        </div> *@

                        @* <span>
							<input type="checkbox" class="checkbox">
							Keep me signed in
						</span> *@

                        <button class="btn btn-default">Create</button>
                    </form>
                </div><!--/sign up form-->
            </div>
        </div>
    </div>
</section><!--/form-->
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}