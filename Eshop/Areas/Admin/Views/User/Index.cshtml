@model IEnumerable<AdminUserListItemViewModel>

@{
    ViewData["Title"] = "Quản lý người dùng";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h4 class="mb-1">Người dùng</h4>
        <div class="text-muted small">Bao gồm cả tài khoản đăng ký thường và đăng nhập qua Google.</div>
    </div>

    <a asp-area="Admin" asp-controller="User" asp-action="Create" class="btn btn-primary">
        <i class="fa fa-plus-circle me-1"></i> Thêm user
    </a>
</div>

<div class="table-responsive">
    <table class="table table-bordered table-striped align-middle">
        <thead>
            <tr>
                <th>Id</th>
                <th>User Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Role</th>
                <th>Đăng nhập</th>
                <th>Trạng thái</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var user in Model)
                {
                    <tr>
                        <td><code>@user.Id</code></td>
                        <td>@user.UserName</td>
                        <td>@(string.IsNullOrWhiteSpace(user.Email) ? "-" : user.Email)</td>
                        <td>@(string.IsNullOrWhiteSpace(user.PhoneNumber) ? "-" : user.PhoneNumber)</td>
                        <td>
                            <span class="badge bg-info text-dark">@user.RoleName</span>
                        </td>
                        <td>@user.AuthMethods</td>
                        <td>
                            @if (user.IsCurrentUser)
                            {
                                <span class="badge bg-dark">Tài khoản hiện tại</span>
                            }
                            else if (user.HasPassword)
                            {
                                <span class="badge bg-success">Hoạt động</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">External only</span>
                            }
                        </td>
                        <td class="text-center">
                            <a asp-action="Edit"
                               asp-controller="User"
                               asp-route-id="@user.Id"
                               class="btn btn-sm btn-primary">
                                Edit
                            </a>

                            @if (!user.IsCurrentUser)
                            {
                                <form asp-action="Delete"
                                      asp-controller="User"
                                      asp-route-id="@user.Id"
                                      method="post"
                                      class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-danger confirmDeletion">
                                        Delete
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="text-center">Chưa có người dùng nào.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
