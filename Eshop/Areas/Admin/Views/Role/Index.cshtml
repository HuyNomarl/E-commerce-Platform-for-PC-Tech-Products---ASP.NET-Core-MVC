@using Microsoft.AspNetCore.Identity
@model IEnumerable<IdentityRole>

@{
    ViewData["title"] = "Role Index";
}

<div class="row g-3 role-index-page">
    <div class="col-12">
        <div class="d-flex align-items-start align-items-md-center justify-content-between gap-2 flex-column flex-md-row">
            <div>
                <h4 class="mb-1">Vai trò</h4>
                <div class="small page-subtitle">Quản lý danh sách vai trò trong hệ thống</div>
            </div>

            <a asp-area="Admin"
                   asp-action="Create"
                   asp-controller="Role"
                   class="icon-btn icon-add"
                   title="Thêm vai trò">
                <i class="fa fa-plus-circle"></i>
            </a>
        </div>
    </div>

    <div class="col-12">
        <div class="card-soft table-card">
            <div class="table-toolbar">
                <div>
                    <div class="section-title mb-0">Danh sách vai trò</div>
                    <div class="section-subtitle">Xem, chỉnh sửa và quản lý các vai trò người dùng</div>
                </div>

                <div class="toolbar-right">
                    <div class="search-box">
                        <span class="search-icon">
                            <i class="fa fa-search"></i>
                        </span>
                        <input type="text" id="tableSearch" class="form-control" placeholder="Tìm kiếm vai trò..." />
                    </div>

                    <span class="total-badge">
                        Tổng: <span id="totalRows">@Model.Count()</span>
                    </span>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table role-table" id="myTable">
                    <thead>
                        <tr>
                            <th style="width: 260px;">Mã vai trò</th>
                            <th>Tên vai trò</th>
                            <th style="width: 160px;" class="text-right">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                var isSystemRole = RoleNames.IsSystemRole(item.Name);
                                <tr>
                                    <td>
                                        <span class="code-pill">@item.Id</span>
                                    </td>

                                    <td>
                                        <div class="cell-main">@RoleNames.GetDisplayName(item.Name)</div>
                                        <div class="cell-sub">
                                            @(isSystemRole
                                                ? RoleNames.GetDescription(item.Name)
                                                : "Role trong hệ thống")
                                        </div>
                                    </td>

                                    <td class="text-right">
                                        <div class="action-group">
                                            @if (!isSystemRole)
                                            {
                                                <a asp-area="Admin"
                                                       asp-action="Edit"
                                                       asp-controller="Role"
                                                       asp-route-id="@item.Id"
                                                       class="icon-btn icon-edit"
                                                       title="Sửa">
                                                    <i class="fa fa-pencil-square-o"></i>
                                                </a>

                                                <form asp-area="Admin"
                                                      asp-action="Delete"
                                                      asp-controller="Role"
                                                      asp-route-id="@item.Id"
                                                      method="post"
                                                      class="delete-form d-inline">
                                                    @Html.AntiForgeryToken()

                                                    <button type="submit"
                                                            class="icon-btn icon-delete js-delete"
                                                            data-name="@item.Name"
                                                            title="Xóa">
                                                        <i class="fa fa-trash"></i>
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <span class="badge bg-dark">System</span>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="empty-cell text-center">
                                    <div class="empty-wrap">
                                        <i class="fa fa-folder-open-o empty-icon"></i>
                                        <div>Chưa có vai trò nào.</div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .role-index-page .page-subtitle {
        opacity: .75;
    }

    .card-soft {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.05);
    }

    .table-card {
        overflow: hidden;
    }

    .table-toolbar {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 16px;
        padding: 22px 22px 0 22px;
        flex-wrap: wrap;
    }

    .section-title {
        font-size: 20px;
        font-weight: 700;
        color: #111827;
        margin-bottom: 4px;
    }

    .section-subtitle {
        color: #6b7280;
        font-size: 13px;
        margin-bottom: 18px;
    }

    .toolbar-right {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .search-box {
        position: relative;
        min-width: 260px;
    }

        .search-box .form-control {
            height: 42px;
            border-radius: 12px;
            padding-left: 40px;
            border: 1px solid #d1d5db;
            box-shadow: none;
        }

    .search-icon {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: #6b7280;
        z-index: 2;
    }

    .total-badge {
        display: inline-flex;
        align-items: center;
        border: 1px solid #d1d5db;
        background: #f9fafb;
        color: #374151;
        border-radius: 999px;
        padding: 8px 14px;
        font-size: 13px;
        font-weight: 600;
    }

    .role-table {
        margin-bottom: 0;
    }

        .role-table thead th {
            background: #f8fafc;
            color: #374151;
            font-weight: 700;
            border-bottom: 1px solid #e5e7eb !important;
            vertical-align: middle !important;
            padding: 14px 12px !important;
        }

        .role-table tbody td {
            vertical-align: middle !important;
            padding: 14px 12px !important;
            border-top: 1px solid #eef2f7 !important;
        }

        .role-table tbody tr:hover {
            background: #fafafa;
        }

    .code-pill {
        display: inline-block;
        max-width: 220px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        padding: 6px 12px;
        border-radius: 999px;
        background: #111827;
        color: #fff;
        font-size: 12px;
        font-weight: 700;
    }

    .cell-main {
        font-weight: 700;
        color: #111827;
    }

    .cell-sub {
        font-size: 12px;
        color: #6b7280;
        margin-top: 2px;
    }

    .action-group {
        display: inline-flex;
        justify-content: flex-end;
        gap: 8px;
        flex-wrap: wrap;
    }

    .icon-btn {
        width: 38px;
        height: 38px;
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid #e5e7eb;
        background: #fff;
        text-decoration: none !important;
        transition: all .2s ease;
        padding: 0;
    }

        .icon-btn:hover {
            background: #f3f4f6;
            border-color: #d1d5db;
        }

    .icon-add {
        width: 44px;
        height: 44px;
        border-radius: 14px;
        color: #16a34a;
    }

    .icon-edit {
        color: #f59e0b;
    }

    .icon-delete {
        color: #ef4444;
    }

    .empty-cell {
        padding: 40px 20px !important;
    }

    .empty-wrap {
        color: #6b7280;
    }

    .empty-icon {
        font-size: 28px;
        margin-bottom: 8px;
        display: block;
    }

    div.dt-container .dt-search {
        display: none;
    }

    div.dt-container .dt-layout-row {
        padding: 12px 16px;
    }

    @@media (max-width: 767px) {
        .table-toolbar {
            padding: 18px 18px 0 18px;
            flex-direction: column;
            align-items: stretch;
        }

        .search-box {
            min-width: 100%;
        }

        .toolbar-right {
            width: 100%;
        }

        .code-pill {
            max-width: 160px;
        }
    }
</style>

@section Scripts {
    <script>
        $(document).on("click", ".js-delete", function (e) {
            e.preventDefault();

            const btn = this;
            const form = btn.closest("form");
            const roleName = btn.getAttribute("data-name") || "";

            const swalWithBootstrapButtons = Swal.mixin({
                customClass: {
                    confirmButton: "btn btn-success",
                    cancelButton: "btn btn-danger"
                },
                buttonsStyling: false
            });

            swalWithBootstrapButtons.fire({
                title: "Bạn có chắc không?",
                text: roleName
                    ? `Bạn chắc chắn muốn xóa vai trò "${roleName}"? Bạn không thể hoàn tác!`
                    : "Bạn không thể hoàn tác!",
                icon: "warning",
                showCancelButton: true,
                confirmButtonText: "Xóa",
                cancelButtonText: "Hủy",
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    form.submit();
                } else if (result.dismiss === Swal.DismissReason.cancel) {
                    swalWithBootstrapButtons.fire({
                        title: "Đã hủy",
                        text: "Vai trò vẫn an toàn.",
                        icon: "error"
                    });
                }
            });
        });
    </script>

    <script>
        const table = new DataTable('#myTable', {
            layout: {
                topStart: { buttons: ['copy', 'csv', 'excel', 'pdf', 'print'] },
                topEnd: null
            }
        });

        const searchInput = document.getElementById('tableSearch');
        if (searchInput) {
            searchInput.addEventListener('keyup', function () {
                table.search(this.value).draw();
            });
        }

        table.on('draw', function () {
            const info = table.page.info();
            const totalEl = document.getElementById('totalRows');
            if (totalEl) {
                totalEl.textContent = info.recordsDisplay;
            }
        });
    </script>
}
