@using Microsoft.AspNetCore.Identity
@model IEnumerable<IdentityRole>
@{
    ViewData["title"] = "Role Index";
}

<h3>Role Index View</h3>
<a asp-area="Admin" asp-action="Create" asp-controller="Role" class="btn btn-success">Add Role</a>

<table class="table" id="myTable">
    <thead>
        <tr>
            <th scope="col">Id</th>
            <th scope="col">Role Name</th>
            <th scope="col">Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <th scope="row">@item.Id</th>
                <td>@item.Name</td>
                <td class="d-flex gap-2">
                    <a asp-area="Admin"
                       asp-action="Edit"
                       asp-controller="Role"
                       asp-route-id="@item.Id"
                       class="btn btn-primary">
                        Edit
                    </a>

                    <form asp-area="Admin"
                          asp-action="Delete"
                          asp-controller="Role"
                          asp-route-id="@item.Id"
                          method="post"
                          class="delete-form"
                          style="display:inline;">
                        @Html.AntiForgeryToken()

                        <button type="submit"
                                class="btn btn-danger js-delete"
                                data-name="@item.Name">
                            Delete
                        </button>
                    </form>

                </td>
            </tr>
        }
    </tbody>
</table>
@section Scripts {
    <script>
        // Bắt click nút delete
        $(document).on("click", ".js-delete", function (e) {
          e.preventDefault();

          const btn = this;
          const form = btn.closest("form");
          const roleName = btn.getAttribute("data-name") || "";

          const swalWithBootstrapButtons = Swal.mixin({
            customClass: {
              confirmButton: "btn btn-success",
              cancelButton: "btn btn-danger"
            },
            buttonsStyling: false
          });

          swalWithBootstrapButtons.fire({
            title: "Are you sure?",
            text: roleName
              ? `Bạn chắc chắn muốn xóa vai trò "${roleName}"? Bạn không thể hoàn tác!`
              : "Bạn không thể hoàn tác!",
            icon: "warning",
            showCancelButton: true,
            confirmButtonText: "Yes, delete it!",
            cancelButtonText: "No, cancel!",
            reverseButtons: true
          }).then((result) => {
            if (result.isConfirmed) {
              form.submit(); // submit thật để server xử lý xóa
            } else if (result.dismiss === Swal.DismissReason.cancel) {
              swalWithBootstrapButtons.fire({
                title: "Cancelled",
                text: "Vai trò vẫn an toàn 🙂",
                icon: "error"
              });
            }
          });
        });
    </script>
    <script>
        new DataTable('#myTable', {
          layout: {
            topStart: { buttons: ['copy', 'csv', 'excel', 'pdf', 'print'] }
          }
        });
    </script>

}

