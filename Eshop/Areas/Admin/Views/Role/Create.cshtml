@model AdminRoleUpsertViewModel

@{
    ViewData["Title"] = "Tạo vai trò";
}

<div class="admin-ui-page admin-ui-page--blue">
    <section class="admin-ui-hero">
        <div class="admin-ui-hero__content">
            <span class="admin-ui-hero__eyebrow">Roles</span>
            <h4>Tạo vai trò</h4>
            <p class="admin-ui-hero__desc">
                Thêm vai trò mới cho hệ thống với một form ngắn gọn hơn nhưng vẫn rõ ràng cho luồng phân quyền quản trị.
            </p>
            <div class="admin-ui-hero__meta">
                <span class="admin-ui-chip">Vai trò tùy chỉnh</span>
                <span class="admin-ui-chip">Không trùng role hệ thống</span>
                <span class="admin-ui-chip">Không đổi logic phân quyền</span>
            </div>
        </div>

        <a asp-action="Index" class="admin-ui-back">
            <i class="fa fa-arrow-left"></i>
            Quay lại danh sách
        </a>
    </section>

    <div class="row g-3 role-create-page">
    <div class="col-12">
        <div class="d-flex align-items-start align-items-md-center justify-content-between gap-2 flex-column flex-md-row">
            <div>
                <h4 class="mb-1">Tạo vai trò</h4>
                <div class="small page-subtitle">Thêm vai trò mới để phân quyền quản trị hoặc vận hành.</div>
            </div>

            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="fa fa-arrow-left me-1"></i> Quay lại
            </a>
        </div>
    </div>

    <div class="col-12 col-xl-8">
        <div class="card-soft form-card">
            <div class="card-body-custom">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="form-col">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name"
                               class="form-control input-soft"
                               placeholder="Ví dụ: RegionalManager, AccountingStaff..." />
                        <span asp-validation-for="Name" class="text-danger small d-block mt-1"></span>
                        <div class="form-note">
                            Không dùng tên trùng với vai trò hệ thống như `Admin`, `Customer`, `OrderStaff`...
                        </div>
                    </div>

                    <div class="form-actions mt-4">
                        <button type="submit" class="btn btn-accent">
                            <i class="fa fa-plus-circle me-1"></i> Tạo vai trò
                        </button>

                        <a asp-action="Index" class="btn btn-outline-secondary">
                            Quay lại danh sách
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
</div>

<style>
    .role-create-page .page-subtitle {
        opacity: .75;
    }

    .card-soft {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.05);
    }

    .form-card {
        overflow: hidden;
    }

    .card-body-custom {
        padding: 24px;
    }

    .form-col {
        margin-bottom: 20px;
    }

    .form-label {
        display: block;
        margin-bottom: 8px;
        font-weight: 700;
        color: #111827;
    }

    .input-soft {
        border-radius: 12px;
        border: 1px solid #d1d5db;
        box-shadow: none;
        min-height: 44px;
        background: #fff;
    }

        .input-soft:focus {
            border-color: #86b7fe;
            box-shadow: 0 0 0 3px rgba(13, 110, 253, .12);
        }

    .form-note {
        margin-top: 8px;
        font-size: 12px;
        color: #6b7280;
    }

    .form-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .btn-accent {
        background: #111827;
        border: 1px solid #111827;
        color: #fff;
        border-radius: 12px;
        padding: 10px 18px;
        font-weight: 600;
    }

        .btn-accent:hover,
        .btn-accent:focus {
            color: #fff;
            background: #0f172a;
            border-color: #0f172a;
        }

    .btn-outline-secondary {
        border-radius: 12px;
        padding: 10px 18px;
    }

    .text-danger.small {
        font-size: 12px;
    }

    @@media (max-width: 767px) {
        .card-body-custom {
            padding: 16px;
        }
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
