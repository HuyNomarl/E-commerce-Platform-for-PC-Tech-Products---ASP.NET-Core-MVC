@using Microsoft.AspNetCore.Identity
@model IdentityRole

@{
    ViewData["Title"] = "Create Role";
}

<div class="row g-3 role-create-page">
    <div class="col-12">
        <div class="d-flex align-items-start align-items-md-center justify-content-between gap-2 flex-column flex-md-row">
            <div>
                <h4 class="mb-1">Tạo vai trò</h4>
                <div class="small page-subtitle">Nhập thông tin vai trò và tạo mới</div>
            </div>

            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="fa-solid fa-arrow-left me-1"></i> Quay lại
            </a>
        </div>
    </div>

    <div class="col-12 col-xl-8">
        <div class="card card-soft shadow-sm border-0">
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Name" class="form-label">Tên vai trò</label>
                            <input asp-for="Name" class="form-control bg-transparent" placeholder="Ví dụ: Admin, Manager, Staff..." />
                            <span asp-validation-for="Name" class="text-danger small d-block mt-1"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4 flex-wrap">
                        <button type="submit" class="btn btn-accent">
                            <i class="fa-solid fa-circle-plus me-1"></i> Tạo vai trò
                        </button>

                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="fa-solid fa-arrow-left me-1"></i> Quay lại danh sách
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .role-create-page .page-subtitle {
        opacity: .75;
    }

    .card-soft {
        background: var(--main-extra-bg, #fff);
        border: 1px solid var(--border-color, #dee2e6);
        border-radius: 1rem;
        color: var(--font-color, inherit);
    }

        .card-soft .form-control,
        .card-soft .form-select {
            border-radius: .75rem;
            min-height: 46px;
            border: 1px solid var(--border-color, #ced4da);
        }

            .card-soft .form-control:focus,
            .card-soft .form-select:focus {
                box-shadow: 0 0 0 .15rem rgba(13, 110, 253, .15);
                border-color: #86b7fe;
            }

    .btn-accent {
        background: var(--main-color, #0d6efd);
        border: 1px solid var(--hover-border-color, #0d6efd);
        color: var(--dark, #fff);
        border-radius: .75rem;
        padding: .625rem 1rem;
    }

        .btn-accent:hover {
            filter: brightness(1.05);
            color: var(--dark, #fff);
        }

    .btn-outline-secondary {
        border-radius: .75rem;
        padding: .625rem 1rem;
    }

    .text-danger.small {
        font-size: .875rem;
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}