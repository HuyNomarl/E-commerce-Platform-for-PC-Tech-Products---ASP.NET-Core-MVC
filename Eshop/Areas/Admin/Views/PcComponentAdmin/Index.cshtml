@using System.Globalization
@model IEnumerable<Eshop.Models.ProductModel>

@{
    ViewData["Title"] = "Quản lý linh kiện PC";
    var productList = Model?.ToList() ?? new List<Eshop.Models.ProductModel>();

    var componentTypes = productList
        .Select(x => Convert.ToString(x.ComponentType))
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Distinct()
        .OrderBy(x => x)
        .ToList();

    var publishers = productList
        .Where(x => x.Publisher != null && !string.IsNullOrWhiteSpace(x.Publisher.Name))
        .Select(x => x.Publisher!.Name)
        .Distinct()
        .OrderBy(x => x)
        .ToList();

    var categories = productList
        .Where(x => x.Category != null && !string.IsNullOrWhiteSpace(x.Category.Name))
        .Select(x => x.Category!.Name)
        .Distinct()
        .OrderBy(x => x)
        .ToList();
}

<div class="row g-3 product-index-page">
    <!-- Header -->
    <div class="col-12">
        <div class="d-flex align-items-start align-items-md-center justify-content-between gap-2 flex-column flex-md-row">
            <div>
                <h4 class="mb-1">Linh kiện PC</h4>
                <div class="small page-subtitle">Quản lý danh sách linh kiện PC</div>
            </div>

            <a asp-area="Admin"
                   asp-controller="PcComponentAdmin"
                   asp-action="Create"
                   class="icon-btn icon-add"
                   title="Thêm linh kiện">
                <i class="fa fa-plus-circle"></i>
            </a>
        </div>
    </div>

    <!-- Alert -->
    @if (TempData["success"] != null)
    {
        <div class="col-12">
            <div class="alert alert-success custom-alert mb-0">
                @TempData["success"]
            </div>
        </div>
    }

    @if (TempData["error"] != null)
    {
        <div class="col-12">
            <div class="alert alert-danger custom-alert mb-0">
                @TempData["error"]
            </div>
        </div>
    }

    <!-- Toolbar -->
    <div class="col-12">
        <div class="card-soft toolbar-card">
            <div class="toolbar-inner">
                <div class="toolbar-left">
                    <div class="search-box">
                        <span class="search-icon">
                            <i class="fa fa-search"></i>
                        </span>
                        <input type="text" id="tableSearch" class="form-control" placeholder="Tìm theo tên linh kiện..." />
                    </div>
                </div>

                <div class="toolbar-right">
                    <span class="total-badge">
                        Tổng: <span id="totalRows">@productList.Count</span>
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- Advanced Filter -->
    <div class="col-12">
        <div class="card-soft filter-card">
            <div class="filter-top">
                <div class="filter-title">
                    <i class="fa fa-filter"></i>
                    <span>Bộ lọc nâng cao</span>
                </div>

                <button type="button" id="resetFilters" class="btn-reset-filter">
                    Xóa bộ lọc
                </button>
            </div>

            <div class="row g-3">
                <div class="col-12 col-md-6 col-lg-2">
                    <label class="filter-label">Loại linh kiện</label>
                    <select id="filterComponentType" class="form-select filter-control">
                        <option value="">Tất cả</option>
                        @foreach (var type in componentTypes)
                        {
                            <option value="@type">@type</option>
                        }
                    </select>
                </div>

                <div class="col-12 col-md-6 col-lg-2">
                    <label class="filter-label">Hãng</label>
                    <select id="filterPublisher" class="form-select filter-control">
                        <option value="">Tất cả</option>
                        @foreach (var publisher in publishers)
                        {
                            <option value="@publisher">@publisher</option>
                        }
                    </select>
                </div>

                <div class="col-12 col-md-6 col-lg-2">
                    <label class="filter-label">Danh mục</label>
                    <select id="filterCategory" class="form-select filter-control">
                        <option value="">Tất cả</option>
                        @foreach (var category in categories)
                        {
                            <option value="@category">@category</option>
                        }
                    </select>
                </div>

                <div class="col-12 col-md-6 col-lg-2">
                    <label class="filter-label">Tồn kho</label>
                    <select id="filterStock" class="form-select filter-control">
                        <option value="">Tất cả</option>
                        <option value="in">Còn hàng</option>
                        <option value="out">Hết hàng</option>
                    </select>
                </div>

                <div class="col-12 col-md-6 col-lg-2">
                    <label class="filter-label">Giá từ</label>
                    <input type="text" id="filterMinPrice" class="form-control filter-control" placeholder="Ví dụ: 1000000" />
                </div>

                <div class="col-12 col-md-6 col-lg-2">
                    <label class="filter-label">Giá đến</label>
                    <input type="text" id="filterMaxPrice" class="form-control filter-control" placeholder="Ví dụ: 5000000" />
                </div>
            </div>
        </div>
    </div>

    <!-- Table -->
    <div class="col-12">
        <div class="card-soft table-card">
            <div class="table-responsive">
                <table class="table product-table" id="myTable">
                    <thead>
                        <tr>
                            <th style="width: 100px;">Mã LK</th>
                            <th style="width: 110px;">Ảnh</th>
                            <th>Tên linh kiện</th>
                            <th style="width: 140px;">Loại</th>
                            <th style="width: 140px;">Hãng</th>
                            <th style="width: 140px;">Danh mục</th>
                            <th style="width: 150px;">Giá</th>
                            <th style="width: 110px;">Tồn kho</th>
                            <th style="width: 170px;" class="text-right">Thao tác</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (productList.Any())
                        {
                            @foreach (var item in productList)
                            {
                                <tr>
                                    <td>
                                        <span class="code-pill">P@item.Id</span>
                                    </td>

                                    <td>
                                        <div class="thumb-wrap">
                                            @if (!string.IsNullOrWhiteSpace(item.Image))
                                            {
                                                var imageSrc = item.Image.StartsWith("http://") || item.Image.StartsWith("https://")
                                                    ? item.Image
                                                    : Url.Content("~/media/products/" + item.Image);

                                                <img src="@imageSrc"
                                                     class="thumb"
                                                     alt="@item.Name" />
                                            }
                                            else
                                            {
                                                <div class="thumb thumb-placeholder">
                                                    <i class="fa fa-image"></i>
                                                </div>
                                            }
                                        </div>
                                    </td>

                                    <td>
                                        <div class="name-cell">
                                            <div class="name-main">@item.Name</div>
                                            <div class="name-sub text-muted">
                                                Danh mục: @(item.Category?.Name ?? "-")
                                            </div>
                                        </div>
                                    </td>

                                    <td>
                                        <span class="unit-badge">
                                            @(string.IsNullOrWhiteSpace(item.ComponentType?.ToString()) ? "-" : item.ComponentType.ToString())
                                        </span>
                                    </td>

                                    <td>
                                        <span class="unit-badge">
                                            @(item.Publisher?.Name ?? "-")
                                        </span>
                                    </td>

                                    <td>
                                        <span class="unit-badge">
                                            @(item.Category?.Name ?? "-")
                                        </span>
                                    </td>

                                    <td>
                                        <span class="price-text">@string.Format(new CultureInfo("vi-VN"), "{0:N0} ₫", item.Price)</span>
                                    </td>

                                    <td>
                                        <span class="qty-badge">@item.Quantity</span>
                                    </td>

                                    <td class="text-right">
                                        <div class="action-group">
                                            <a asp-area="Admin"
                                                   asp-controller="PcComponentAdmin"
                                                   asp-action="Edit"
                                                   asp-route-id="@item.Id"
                                                   class="icon-btn icon-edit"
                                                   title="Chỉnh sửa">
                                                <i class="fa fa-pencil-square-o"></i>
                                            </a>

                                            <form asp-area="Admin"
                                                  asp-controller="PcComponentAdmin"
                                                  asp-action="Delete"
                                                  asp-route-id="@item.Id"
                                                  method="post"
                                                  class="d-inline-block m-0"
                                                  onsubmit="return confirm('Bạn có chắc muốn xóa linh kiện này không?');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit"
                                                        class="icon-btn icon-delete"
                                                        title="Xóa">
                                                    <i class="fa fa-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="9" class="text-center py-5">
                                    <div class="empty-state">
                                        <i class="fa fa-folder-open-o empty-icon"></i>
                                        <div>Không có linh kiện nào.</div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .product-index-page .page-subtitle {
        opacity: .75;
    }

    .card-soft {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.05);
    }

    .custom-alert {
        border-radius: 16px;
        border: 1px solid transparent;
    }

    .toolbar-card,
    .filter-card {
        padding: 16px 18px;
    }

    .toolbar-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
    }

    .toolbar-left {
        flex: 1;
        min-width: 260px;
    }

    .toolbar-right {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .search-box {
        position: relative;
        max-width: 420px;
    }

        .search-box .form-control {
            height: 42px;
            border-radius: 12px;
            padding-left: 40px;
            border: 1px solid #d1d5db;
            box-shadow: none;
        }

            .search-box .form-control:focus,
            .filter-control:focus {
                border-color: #9ca3af;
                box-shadow: none;
            }

    .search-icon {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: #6b7280;
        z-index: 2;
    }

    .total-badge {
        display: inline-flex;
        align-items: center;
        border: 1px solid #d1d5db;
        background: #f9fafb;
        color: #374151;
        border-radius: 999px;
        padding: 8px 14px;
        font-size: 13px;
        font-weight: 600;
    }

    .filter-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 14px;
        flex-wrap: wrap;
    }

    .filter-title {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 15px;
        font-weight: 700;
        color: #111827;
    }

    .filter-label {
        display: block;
        margin-bottom: 6px;
        font-size: 12px;
        font-weight: 700;
        color: #374151;
    }

    .filter-control {
        height: 42px;
        border-radius: 12px;
        border: 1px solid #d1d5db;
        box-shadow: none;
    }

    .btn-reset-filter {
        border: 1px solid #d1d5db;
        background: #fff;
        color: #374151;
        border-radius: 12px;
        height: 42px;
        padding: 0 14px;
        font-size: 13px;
        font-weight: 600;
        transition: all .2s ease;
    }

        .btn-reset-filter:hover {
            background: #f3f4f6;
            border-color: #cbd5e1;
        }

    .table-card {
        overflow: hidden;
    }

    .product-table {
        margin-bottom: 0;
    }

        .product-table thead th {
            background: #f8fafc;
            color: #374151;
            font-weight: 700;
            border-bottom: 1px solid #e5e7eb !important;
            vertical-align: middle !important;
            padding: 14px 12px !important;
            white-space: nowrap;
        }

        .product-table tbody td {
            vertical-align: middle !important;
            padding: 14px 12px !important;
            border-top: 1px solid #eef2f7 !important;
        }

        .product-table tbody tr:hover {
            background: #fafafa;
        }

    .code-pill {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 999px;
        background: #111827;
        color: #fff;
        font-size: 12px;
        font-weight: 700;
    }

    .thumb-wrap {
        display: flex;
        align-items: center;
    }

    .thumb {
        width: 84px;
        height: 64px;
        object-fit: cover;
        border-radius: 12px;
        border: 1px solid #e5e7eb;
        background: #f9fafb;
    }

    .thumb-placeholder {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #9ca3af;
        font-size: 20px;
    }

    .name-main {
        font-weight: 700;
        color: #111827;
        margin-bottom: 4px;
    }

    .name-sub {
        font-size: 12px;
        line-height: 1.45;
        max-width: 260px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .qty-badge,
    .unit-badge {
        display: inline-flex;
        align-items: center;
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 600;
        border: 1px solid #dbe3ee;
        background: #f8fafc;
        color: #374151;
    }

    .price-text {
        font-weight: 700;
        color: #111827;
        white-space: nowrap;
    }

    .action-group {
        display: inline-flex;
        justify-content: flex-end;
        align-items: center;
        gap: 8px;
        flex-wrap: nowrap;
    }

    .icon-btn {
        width: 38px;
        height: 38px;
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid #e5e7eb;
        background: #fff;
        text-decoration: none !important;
        transition: all .2s ease;
        padding: 0;
        line-height: 1;
    }

        .icon-btn:hover {
            background: #f3f4f6;
            border-color: #d1d5db;
        }

        .icon-btn i {
            pointer-events: none;
        }

    .icon-add {
        width: 44px;
        height: 44px;
        border-radius: 14px;
        color: #16a34a;
    }

    .icon-edit {
        color: #f59e0b;
    }

    .icon-delete {
        color: #ef4444;
    }

    .empty-state {
        color: #6b7280;
    }

    .empty-icon {
        font-size: 28px;
        display: block;
        margin-bottom: 10px;
    }

    div.dt-container .dt-layout-row {
        padding: 12px 16px;
    }

    @@media (max-width: 991px) {
        .name-sub {
            max-width: 180px;
        }
    }

    @@media (max-width: 767px) {
        .toolbar-inner,
        .filter-top {
            flex-direction: column;
            align-items: stretch;
        }

        .toolbar-left,
        .search-box {
            max-width: 100%;
        }

        .action-group {
            flex-wrap: wrap;
        }

        .btn-reset-filter {
            width: 100%;
        }
    }
</style>

@section Scripts {
    <script>
        const table = new DataTable('#myTable', {
            layout: {
                topStart: { buttons: ['copy', 'csv', 'excel', 'pdf', 'print'] }
            }
        });

        const searchInput = document.getElementById('tableSearch');
        const totalEl = document.getElementById('totalRows');

        const filterComponentType = document.getElementById('filterComponentType');
        const filterPublisher = document.getElementById('filterPublisher');
        const filterCategory = document.getElementById('filterCategory');
        const filterStock = document.getElementById('filterStock');
        const filterMinPrice = document.getElementById('filterMinPrice');
        const filterMaxPrice = document.getElementById('filterMaxPrice');
        const resetFiltersBtn = document.getElementById('resetFilters');

        function parseNumber(value) {
            if (!value) return 0;
            const cleaned = value.toString().replace(/[^\d\-]/g, '');
            return cleaned ? parseInt(cleaned, 10) : 0;
        }

        DataTable.ext.search.push(function (settings, data, dataIndex) {
            if (settings.nTable.id !== 'myTable') return true;

            const rowComponentType = (data[3] || '').trim();
            const rowPublisher = (data[4] || '').trim();
            const rowCategory = (data[5] || '').trim();
            const rowPrice = parseNumber(data[6]);
            const rowQty = parseNumber(data[7]);

            const selectedType = (filterComponentType?.value || '').trim();
            const selectedPublisher = (filterPublisher?.value || '').trim();
            const selectedCategory = (filterCategory?.value || '').trim();
            const selectedStock = (filterStock?.value || '').trim();
            const minPrice = parseNumber(filterMinPrice?.value);
            const maxPrice = parseNumber(filterMaxPrice?.value);

            if (selectedType && rowComponentType !== selectedType) return false;
            if (selectedPublisher && rowPublisher !== selectedPublisher) return false;
            if (selectedCategory && rowCategory !== selectedCategory) return false;

            if (selectedStock === 'in' && rowQty <= 0) return false;
            if (selectedStock === 'out' && rowQty > 0) return false;

            if ((filterMinPrice?.value || '').trim() !== '' && rowPrice < minPrice) return false;
            if ((filterMaxPrice?.value || '').trim() !== '' && rowPrice > maxPrice) return false;

            return true;
        });

        if (searchInput) {
            searchInput.addEventListener('keyup', function () {
                table.search(this.value).draw();
            });
        }

        [
            filterComponentType,
            filterPublisher,
            filterCategory,
            filterStock
        ].forEach(el => {
            if (el) {
                el.addEventListener('change', function () {
                    table.draw();
                });
            }
        });

        [
            filterMinPrice,
            filterMaxPrice
        ].forEach(el => {
            if (el) {
                el.addEventListener('input', function () {
                    table.draw();
                });
            }
        });

        if (resetFiltersBtn) {
            resetFiltersBtn.addEventListener('click', function () {
                if (searchInput) searchInput.value = '';
                if (filterComponentType) filterComponentType.value = '';
                if (filterPublisher) filterPublisher.value = '';
                if (filterCategory) filterCategory.value = '';
                if (filterStock) filterStock.value = '';
                if (filterMinPrice) filterMinPrice.value = '';
                if (filterMaxPrice) filterMaxPrice.value = '';

                table.search('').draw();
            });
        }

        table.on('draw', function () {
            const info = table.page.info();
            if (totalEl) {
                totalEl.textContent = info.recordsDisplay;
            }
        });
    </script>
}