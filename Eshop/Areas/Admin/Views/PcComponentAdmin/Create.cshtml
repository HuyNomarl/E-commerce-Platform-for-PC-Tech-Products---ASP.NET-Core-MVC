@model Eshop.Areas.Admin.Models.ViewModels.PcComponentCreateViewModel
@using Eshop.Models.Enums
@using System.Text.Json
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "Thêm linh kiện PC";

    var existingSpecsJson = JsonSerializer.Serialize(
        Model.Specifications?.Select(x => new
        {
            specificationDefinitionId = x.SpecificationDefinitionId,
            valueText = x.ValueText,
            valueNumber = x.ValueNumber,
            valueBool = x.ValueBool,
            valueJson = x.ValueJson
        }) ?? Enumerable.Empty<object>()
    );
}

<div class="row g-3 product-create-page">
    <div class="col-12">
        <div class="d-flex align-items-start align-items-md-center justify-content-between gap-2 flex-column flex-md-row">
            <a asp-area="Admin"
                   asp-controller="PcComponentAdmin"
                   asp-action="Index"
                   class="btn btn-outline-secondary">
                <i class="fa fa-arrow-left me-1"></i> Quay lại
            </a>
        </div>
    </div>

    <form asp-area="Admin"
          asp-controller="PcComponentAdmin"
          asp-action="Create"
          method="post"
          enctype="multipart/form-data"
          class="col-12">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <input asp-for="PrimaryImageSource" type="hidden" value="new" />
        <input asp-for="PrimaryNewImageIndex" type="hidden" id="PrimaryNewImageIndex" />
        <input asp-for="WidgetImagesJson" type="hidden" id="WidgetImagesJson" />

        <div class="row g-3">
            <div class="col-12 col-xl-8">
                <div class="card-soft form-card mb-3">
                    <div class="card-body-custom">
                        <div class="section-heading mb-3">Thông tin chung</div>

                        <div class="row form-grid">
                            <div class="col-12 col-md-8 form-col">
                                <label asp-for="Product.Name" class="form-label">Tên linh kiện</label>
                                <input asp-for="Product.Name" class="form-control input-soft" placeholder="Nhập tên linh kiện" />
                                <span asp-validation-for="Product.Name" class="text-danger small d-block mt-1"></span>
                            </div>

                            <div class="col-12 col-md-4 form-col">
                                <label asp-for="Product.ComponentType" class="form-label">Loại linh kiện</label>
                                <select asp-for="Product.ComponentType"
                                        class="form-select input-soft"
                                        asp-items="Html.GetEnumSelectList<PcComponentType>()"
                                        id="Product_ComponentType">
                                    <option value="">-- Chọn loại linh kiện --</option>
                                </select>
                                <span asp-validation-for="Product.ComponentType" class="text-danger small d-block mt-1"></span>
                            </div>

                            <div class="col-12 form-col">
                                <label asp-for="Product.Description" class="form-label">Mô tả</label>
                                <textarea asp-for="Product.Description"
                                          rows="5"
                                          class="form-control input-soft textarea-soft"
                                          placeholder="Nhập mô tả linh kiện"></textarea>
                                <span asp-validation-for="Product.Description" class="text-danger small d-block mt-1"></span>
                            </div>

                            <div class="col-12 col-md-4 form-col">
                                <label asp-for="Product.Price" class="form-label">Giá</label>
                                <input asp-for="Product.Price" class="form-control input-soft" placeholder="Nhập giá linh kiện" />
                                <span asp-validation-for="Product.Price" class="text-danger small d-block mt-1"></span>
                            </div>

                            <div class="col-12 col-md-4 form-col">
                                <label asp-for="Product.Quantity" class="form-label">Số lượng</label>
                                <input asp-for="Product.Quantity" class="form-control input-soft" placeholder="Nhập số lượng" />
                                <span asp-validation-for="Product.Quantity" class="text-danger small d-block mt-1"></span>
                            </div>

                            <div class="col-12 col-md-4 form-col">
                                <label asp-for="Product.PublisherId" class="form-label">Thương hiệu</label>
                                <select asp-for="Product.PublisherId" asp-items="Model.Publishers" class="form-select input-soft">
                                    <option value="">-- Chọn thương hiệu --</option>
                                </select>
                                <span asp-validation-for="Product.PublisherId" class="text-danger small d-block mt-1"></span>
                            </div>

                            <div class="col-12 col-md-6 form-col">
                                <label asp-for="Product.CategoryId" class="form-label">Danh mục</label>
                                <select asp-for="Product.CategoryId" asp-items="Model.Categories" class="form-select input-soft">
                                    <option value="">-- Chọn danh mục --</option>
                                </select>
                                <span asp-validation-for="Product.CategoryId" class="text-danger small d-block mt-1"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-soft form-card mb-3">
                    <div class="card-body-custom">
                        <div class="section-heading mb-3">Ảnh linh kiện</div>

                        <div class="d-flex gap-2 flex-wrap mb-2">
                            <button type="button" class="btn btn-outline-primary" id="btnAddCreateImages">
                                <i class="fa fa-image me-1"></i> Thêm ảnh
                            </button>
                        </div>

                        <span asp-validation-for="WidgetImagesJson" class="text-danger small d-block mt-1"></span>

                        <div class="small helper-text mt-2">
                            Chọn 1 ảnh làm đại diện, các ảnh còn lại là ảnh phụ.
                        </div>

                        <div id="create-image-list" class="image-row mt-3"></div>
                    </div>
                </div>

                <div class="card-soft form-card">
                    <div class="card-body-custom">
                        <div class="section-heading mb-3">Thông số kỹ thuật</div>

                        <div class="alert alert-info soft-alert">
                            Với field JSON, ví dụ nhập:
                            <code>["ATX","M-ATX","ITX"]</code>
                        </div>

                        <div id="specification-container">
                            <div class="text-muted">Vui lòng chọn loại linh kiện để hiển thị thông số kỹ thuật.</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-4">
                <div class="card-soft form-card sticky-action-card">
                    <div class="card-body-custom">
                        <div class="section-heading mb-3">Thao tác</div>

                        <div class="action-box">
                            <button type="submit" class="btn btn-accent w-100">
                                <i class="fa fa-save me-1"></i> Lưu linh kiện
                            </button>

                            <a asp-area="Admin"
                                   asp-controller="PcComponentAdmin"
                                   asp-action="Index"
                                   class="btn btn-outline-secondary w-100">
                                Quay lại danh sách
                            </a>
                        </div>

                        <div class="action-note mt-3">
                            Hãy kiểm tra lại loại linh kiện, ảnh đại diện và thông số kỹ thuật trước khi lưu.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<style>
    .card-soft {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.05);
    }

    .form-card {
        overflow: hidden;
    }

    .card-body-custom {
        padding: 24px;
    }

    .section-heading {
        font-size: 16px;
        font-weight: 700;
        color: #111827;
        padding-bottom: 10px;
        border-bottom: 1px solid #eef2f7;
    }

    .form-grid {
        margin-left: -10px;
        margin-right: -10px;
    }

    .form-col {
        padding-left: 10px;
        padding-right: 10px;
        margin-bottom: 20px;
    }

    .form-label {
        display: block;
        margin-bottom: 8px;
        font-weight: 700;
        color: #111827;
    }

    .input-soft {
        border-radius: 12px;
        border: 1px solid #d1d5db;
        box-shadow: none;
        min-height: 44px;
        background: #fff;
    }

        .input-soft:focus {
            border-color: #86b7fe;
            box-shadow: 0 0 0 3px rgba(13, 110, 253, .12);
        }

    .textarea-soft {
        min-height: 120px;
        resize: vertical;
    }

    .helper-text {
        color: #6b7280;
    }

    .text-danger.small {
        font-size: 12px;
    }

    .btn-accent {
        background: #111827;
        border: 1px solid #111827;
        color: #fff;
        border-radius: 12px;
        padding: 10px 18px;
        font-weight: 600;
    }

        .btn-accent:hover,
        .btn-accent:focus {
            color: #fff;
            background: #0f172a;
            border-color: #0f172a;
        }

    .btn-outline-secondary,
    .btn-outline-primary {
        border-radius: 12px;
        padding: 10px 18px;
    }

    .action-box {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .action-note {
        font-size: 13px;
        color: #6b7280;
        line-height: 1.6;
    }

    .sticky-action-card {
        position: sticky;
        top: 20px;
    }

    .image-row {
        display: flex;
        flex-wrap: nowrap;
        gap: 16px;
        overflow-x: auto;
        padding-bottom: 8px;
    }

    .image-card {
        min-width: 220px;
        max-width: 220px;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        background: #fff;
        padding: 12px;
        flex: 0 0 auto;
        box-shadow: 0 4px 16px rgba(15, 23, 42, 0.04);
    }

    .image-thumb-wrap {
        width: 100%;
        height: 180px;
        border-radius: 12px;
        overflow: hidden;
        background: #f8f9fa;
        border: 1px solid #edf0f2;
    }

    .image-thumb {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .image-meta {
        margin-top: 10px;
    }

    .image-title {
        font-weight: 600;
        font-size: 14px;
        margin-bottom: 6px;
        color: #111827;
    }

    .image-actions {
        margin-top: 10px;
    }

    .image-empty {
        padding: 16px;
        border: 1px dashed #ced4da;
        border-radius: 12px;
        color: #6c757d;
        background: #fafafa;
        min-width: 320px;
    }

    .soft-alert {
        border-radius: 12px;
        margin-bottom: 16px;
    }

    .spec-card {
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 14px;
        background: #f9fafb;
        margin-bottom: 14px;
    }

        .spec-card .spec-title {
            font-weight: 700;
            color: #111827;
            margin-bottom: 8px;
        }

    @@media (max-width: 1199px) {
        .sticky-action-card {
            position: static;
            top: unset;
        }
    }

    @@media (max-width: 767px) {
        .card-body-custom {
            padding: 16px;
        }

        .image-card {
            min-width: 200px;
            max-width: 200px;
        }

        .image-empty {
            min-width: 260px;
        }
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="https://upload-widget.cloudinary.com/latest/global/all.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
        const list = document.getElementById("create-image-list");
        const btnAdd = document.getElementById("btnAddCreateImages");
        const primaryIndexInput = document.getElementById("PrimaryNewImageIndex");
        const widgetImagesInput = document.getElementById("WidgetImagesJson");

        const componentTypeSelect = document.getElementById("Product_ComponentType");
        const specContainer = document.getElementById("specification-container");
        const getDefinitionsUrl = '@Url.Action("GetDefinitions", "PcComponentAdmin", new { area = "Admin" })';

        const existingSpecs = @Html.Raw(existingSpecsJson);
        const initialImages = @Html.Raw(string.IsNullOrWhiteSpace(Model.WidgetImagesJson) ? "[]" : Model.WidgetImagesJson);
        const initialPrimaryIndex = @(Model.PrimaryNewImageIndex.HasValue? Model.PrimaryNewImageIndex.Value.ToString() : "-1");

        let images = Array.isArray(initialImages)
        ? initialImages.map(x => ({
        id: uid(),
        publicId: x.publicId || x.PublicId || "",
        url: x.url || x.Url || "",
        resourceType: x.resourceType || x.ResourceType || "image",
        originalFileName: x.originalFileName || x.OriginalFileName || ""
        }))
        : [];

        let primaryId = (initialPrimaryIndex >= 0 && initialPrimaryIndex < images.length)
        ? images[initialPrimaryIndex].id
        : (images.length ? images[0].id : null);

        function uid() {
        if (window.crypto && crypto.randomUUID) return crypto.randomUUID();
        return "img_" + Date.now() + "_" + Math.random().toString(36).substring(2, 10);
        }

        function escapeHtml(value) {
        return String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#39;");
        }

        function syncHidden() {
        widgetImagesInput.value = JSON.stringify(
        images.map(x => ({
        publicId: x.publicId,
        url: x.url,
        resourceType: x.resourceType,
        originalFileName: x.originalFileName
        }))
        );

        const primaryIndex = images.findIndex(x => x.id === primaryId);
        primaryIndexInput.value = primaryIndex >= 0 ? primaryIndex : "";
        }

        function ensurePrimary() {
        if (!images.length) {
        primaryId = null;
        return;
        }

        if (!images.some(x => x.id === primaryId)) {
        primaryId = images[0].id;
        }
        }

        function renderImages() {
        ensurePrimary();
        syncHidden();

        if (!images.length) {
        list.innerHTML = `<div class="image-empty">Chưa có ảnh nào. Bấm <strong>Thêm ảnh</strong> để mở Cloudinary Widget.</div>`;
        return;
        }

        list.innerHTML = images.map((item, index) => `
        <div class="image-card">
        <div class="image-thumb-wrap">
        <img src="${escapeHtml(item.url)}" class="image-thumb" alt="preview-${index}" />
        </div>

        <div class="image-meta">
        <div class="image-title">Ảnh ${index + 1}</div>

        <div class="form-check">
        <input class="form-check-input js-create-primary"
        type="radio"
        name="createPrimaryPreview"
        value="${escapeHtml(item.id)}"
        ${item.id === primaryId ? "checked" : ""}>
        <label class="form-check-label">Đặt làm ảnh đại diện</label>
        </div>

        <div class="image-actions">
        <button type="button"
        class="btn btn-outline-danger btn-sm w-100 js-create-delete"
        data-id="${escapeHtml(item.id)}">
        Xóa
        </button>
        </div>
        </div>
        </div>
        `).join("");
        }

        renderImages();

        if (window.cloudinary) {
        const widget = cloudinary.createUploadWidget(
        {
        cloudName: "dd120zgwr",
        uploadPreset: "ml_default",
        multiple: true,
        maxFiles: 20,
        resourceType: "image",
        clientAllowedFormats: ["jpg", "jpeg", "png", "webp"],
        sources: ["url", "camera", "google_drive", "dropbox", "local"],
        defaultSource: "url"
        },
        function (error, result) {
        if (error) {
        console.error(error);
        return;
        }

        if (result && result.event === "success") {
        images.push({
        id: uid(),
        publicId: result.info.public_id,
        url: result.info.secure_url,
        resourceType: result.info.resource_type || "image",
        originalFileName: result.info.original_filename || ""
        });

        if (!primaryId && images.length) {
        primaryId = images[0].id;
        }

        renderImages();
        }
        }
        );

        btnAdd.addEventListener("click", function () {
        widget.open();
        });
        } else {
        console.error("Cloudinary widget chưa load.");
        btnAdd.disabled = true;
        }

        list.addEventListener("click", function (e) {
        const btnDelete = e.target.closest(".js-create-delete");
        if (!btnDelete) return;

        const id = btnDelete.dataset.id;
        images = images.filter(x => x.id !== id);

        if (primaryId === id) {
        primaryId = images.length ? images[0].id : null;
        }

        renderImages();
        });

        list.addEventListener("change", function (e) {
        if (!e.target.classList.contains("js-create-primary")) return;

        primaryId = e.target.value;
        renderImages();
        });

        function findOldSpec(defId) {
        return existingSpecs.find(x =>
        Number(x.specificationDefinitionId) === Number(defId)
        );
        }

        function buildSpecInput(spec, index, oldSpec) {
        const dataTypeValue = typeof spec.dataType === "string"
        ? spec.dataType.toLowerCase()
        : Number(spec.dataType);

        if (dataTypeValue === 1 || dataTypeValue === "text") {
        return `<input class="form-control input-soft" name="Specifications[${index}].ValueText" value="${escapeHtml(oldSpec?.valueText ?? "")}" />`;
        }

        if (dataTypeValue === 2 || dataTypeValue === "number") {
        return `<input type="number" step="0.01" class="form-control input-soft" name="Specifications[${index}].ValueNumber" value="${escapeHtml(oldSpec?.valueNumber ?? "")}" />`;
        }

        if (dataTypeValue === 3 || dataTypeValue === "boolean" || dataTypeValue === "bool") {
        const boolValue = oldSpec?.valueBool;
        const selectedTrue = boolValue === true || boolValue === "true" ? "selected" : "";
        const selectedFalse = boolValue === false || boolValue === "false" ? "selected" : "";

        return `
        <select class="form-select input-soft" name="Specifications[${index}].ValueBool">
        <option value="">-- Chọn --</option>
        <option value="true" ${selectedTrue}>Có</option>
        <option value="false" ${selectedFalse}>Không</option>
        </select>
        `;
        }

        if (dataTypeValue === 4 || dataTypeValue === "json") {
        return `<textarea rows="3" class="form-control input-soft textarea-soft" name="Specifications[${index}].ValueJson">${escapeHtml(oldSpec?.valueJson ?? "")}</textarea>`;
        }

        return `<input class="form-control input-soft" name="Specifications[${index}].ValueText" value="${escapeHtml(oldSpec?.valueText ?? "")}" />`;
        }

        async function loadSpecifications() {
        if (!componentTypeSelect || !specContainer) return;

        const componentType = componentTypeSelect.value;
        specContainer.innerHTML = "";

        if (!componentType) {
        specContainer.innerHTML = `<div class="text-muted">Vui lòng chọn loại linh kiện để hiển thị thông số kỹ thuật.</div>`;
        return;
        }

        try {
        const response = await fetch(`${getDefinitionsUrl}?componentType=${encodeURIComponent(componentType)}`, {
        method: "GET",
        headers: {
        "X-Requested-With": "XMLHttpRequest"
        }
        });

        if (!response.ok) {
        throw new Error(`Lỗi HTTP: ${response.status}`);
        }

        const rawText = await response.text();
        let specs;

        try {
        specs = JSON.parse(rawText);
        } catch (jsonError) {
        console.error("Response không phải JSON hợp lệ:", rawText);
        throw new Error("Dữ liệu trả về không hợp lệ.");
        }

        if (!Array.isArray(specs) || specs.length === 0) {
        specContainer.innerHTML = `<div class="alert alert-warning mb-0">Loại linh kiện này chưa có bộ thông số.</div>`;
        return;
        }

        specContainer.innerHTML = specs.map((item, index) => {
        const spec = {
        id: item.id ?? item.Id,
        name: item.name ?? item.Name,
        code: item.code ?? item.Code,
        dataType: item.dataType ?? item.DataType,
        unit: item.unit ?? item.Unit ?? "",
        isRequired: item.isRequired ?? item.IsRequired ?? false
        };

        const oldSpec = findOldSpec(spec.id);
        const inputHtml = buildSpecInput(spec, index, oldSpec);

        return `
        <div class="spec-card">
        <div class="spec-title">
        ${escapeHtml(spec.name)}
        ${spec.unit ? ` (${escapeHtml(spec.unit)})` : ""}
        ${spec.isRequired ? '<span class="text-danger">*</span>' : ''}
        </div>

        <input type="hidden" name="Specifications[${index}].SpecificationDefinitionId" value="${escapeHtml(spec.id)}" />
        <input type="hidden" name="Specifications[${index}].Name" value="${escapeHtml(spec.name)}" />
        <input type="hidden" name="Specifications[${index}].Code" value="${escapeHtml(spec.code)}" />
        <input type="hidden" name="Specifications[${index}].DataType" value="${escapeHtml(spec.dataType)}" />
        <input type="hidden" name="Specifications[${index}].Unit" value="${escapeHtml(spec.unit)}" />

        ${inputHtml}
        </div>
        `;
        }).join("");

        if (window.jQuery && $.validator && $.validator.unobtrusive) {
        $.validator.unobtrusive.parse(specContainer);
        }
        }
        catch (error) {
        console.error("Lỗi loadSpecifications:", error);
        specContainer.innerHTML = `<div class="alert alert-danger mb-0">Không thể tải thông số kỹ thuật.</div>`;
        }
        }

        if (componentTypeSelect) {
        componentTypeSelect.addEventListener("change", loadSpecifications);

        if (componentTypeSelect.value) {
        loadSpecifications();
        }
        }
        });
    </script>
}