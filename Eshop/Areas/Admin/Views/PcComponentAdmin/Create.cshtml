@model Eshop.Models.ViewModels.PcComponentCreateViewModel
@using Eshop.Models.Enums
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "Thêm linh kiện PC";
}

<div class="container-fluid">
    <h2 class="mb-3">Thêm linh kiện PC</h2>

    <form asp-area="Admin" asp-controller="PcComponentAdmin" asp-action="Create" method="post" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-3">
            <div class="col-lg-8">
                <div class="card mb-3">
                    <div class="card-header">Thông tin chung</div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="Product.Name" class="form-label"></label>
                            <input asp-for="Product.Name" class="form-control" />
                            <span asp-validation-for="Product.Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Product.Description" class="form-label"></label>
                            <textarea asp-for="Product.Description" rows="4" class="form-control"></textarea>
                            <span asp-validation-for="Product.Description" class="text-danger"></span>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-4">
                                <label asp-for="Product.Price" class="form-label"></label>
                                <input asp-for="Product.Price" class="form-control" />
                                <span asp-validation-for="Product.Price" class="text-danger"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Product.Quantity" class="form-label"></label>
                                <input asp-for="Product.Quantity" class="form-control" />
                                <span asp-validation-for="Product.Quantity" class="text-danger"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Product.ComponentType" class="form-label">Loại linh kiện</label>
                                <select asp-for="Product.ComponentType"
                                        class="form-select"
                                        asp-items="Html.GetEnumSelectList<PcComponentType>()">
                                    <option value="">-- Chọn loại linh kiện --</option>
                                </select>
                                <span asp-validation-for="Product.ComponentType" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row g-3 mt-1">
                            <div class="col-md-6">
                                <label asp-for="Product.PublisherId" class="form-label">Thương hiệu</label>
                                <select asp-for="Product.PublisherId" asp-items="Model.Publishers" class="form-select">
                                    <option value="">-- Chọn thương hiệu --</option>
                                </select>
                                <span asp-validation-for="Product.PublisherId" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Product.CategoryId" class="form-label">Danh mục</label>
                                <select asp-for="Product.CategoryId" asp-items="Model.Categories" class="form-select">
                                    <option value="">-- Chọn danh mục --</option>
                                </select>
                                <span asp-validation-for="Product.CategoryId" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mt-3">
                            <label asp-for="Product.ImageUpload" class="form-label">Ảnh sản phẩm</label>
                            <input asp-for="Product.ImageUpload" type="file" class="form-control" />
                            <span asp-validation-for="Product.ImageUpload" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">Thông số kỹ thuật</div>
                    <div class="card-body">
                        <div class="alert alert-info">
                            Với field JSON, ví dụ nhập:
                            <code>["ATX","M-ATX","ITX"]</code>
                        </div>

                        <div id="specification-container">
                            <div class="text-muted">Vui lòng chọn loại linh kiện để hiển thị thông số kỹ thuật.</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card">
                    <div class="card-header">Thao tác</div>
                    <div class="card-body d-grid gap-2">
                        <button type="submit" class="btn btn-success">Lưu linh kiện</button>
                        <a asp-area="Admin" asp-controller="PcComponentAdmin" asp-action="Index" class="btn btn-outline-secondary">Quay lại</a>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const componentTypeSelect = document.getElementById("Product_ComponentType");
            const specContainer = document.getElementById("specification-container");
            const getDefinitionsUrl = '@Url.Action("GetDefinitions", "PcComponentAdmin", new { area = "Admin" })';

            if (!componentTypeSelect || !specContainer) {
                console.error("Không tìm thấy Product_ComponentType hoặc specification-container");
                return;
            }

            componentTypeSelect.addEventListener("change", loadSpecifications);

            async function loadSpecifications() {
                const componentType = componentTypeSelect.value;
                specContainer.innerHTML = "";

                if (!componentType) {
                    specContainer.innerHTML = `<div class="text-muted">Vui lòng chọn loại linh kiện để hiển thị thông số kỹ thuật.</div>`;
                    return;
                }

                try {
                    const response = await fetch(`${getDefinitionsUrl}?componentType=${encodeURIComponent(componentType)}`, {
                        method: "GET",
                        headers: {
                            "X-Requested-With": "XMLHttpRequest"
                        }
                    });

                    if (!response.ok) {
                        throw new Error(`Lỗi HTTP: ${response.status}`);
                    }

                    const rawText = await response.text();
                    let specs;

                    try {
                        specs = JSON.parse(rawText);
                    } catch (jsonError) {
                        console.error("Response không phải JSON hợp lệ:", rawText);
                        throw new Error("Dữ liệu trả về không hợp lệ.");
                    }

                    if (!Array.isArray(specs) || specs.length === 0) {
                        specContainer.innerHTML = `<div class="alert alert-warning mb-0">Loại linh kiện này chưa có bộ thông số.</div>`;
                        return;
                    }

                    specContainer.innerHTML = specs.map((item, index) => {
                        const spec = {
                            id: item.id ?? item.Id,
                            name: item.name ?? item.Name,
                            code: item.code ?? item.Code,
                            dataType: item.dataType ?? item.DataType,
                            unit: item.unit ?? item.Unit ?? "",
                            isRequired: item.isRequired ?? item.IsRequired ?? false
                        };

                        let inputHtml = "";
                        const dataTypeValue = typeof spec.dataType === "string"
                            ? spec.dataType.toLowerCase()
                            : Number(spec.dataType);

                        if (dataTypeValue === 1 || dataTypeValue === "text") {
                            inputHtml = `<input class="form-control" name="Specifications[${index}].ValueText" />`;
                        }
                        else if (dataTypeValue === 2 || dataTypeValue === "number") {
                            inputHtml = `<input type="number" step="0.01" class="form-control" name="Specifications[${index}].ValueNumber" />`;
                        }
                        else if (dataTypeValue === 3 || dataTypeValue === "boolean" || dataTypeValue === "bool") {
                            inputHtml = `
                                <select class="form-select" name="Specifications[${index}].ValueBool">
                                    <option value="">-- Chọn --</option>
                                    <option value="true">Có</option>
                                    <option value="false">Không</option>
                                </select>
                            `;
                        }
                        else if (dataTypeValue === 4 || dataTypeValue === "json") {
                            inputHtml = `<textarea rows="2" class="form-control" name="Specifications[${index}].ValueJson"></textarea>`;
                        } else {
                            inputHtml = `<input class="form-control" name="Specifications[${index}].ValueText" />`;
                        }

                        return `
                            <div class="mb-3">
                                <label class="form-label">
                                    ${spec.name}${spec.unit ? ` (${spec.unit})` : ""}${spec.isRequired ? ' <span class="text-danger">*</span>' : ''}
                                </label>

                                <input type="hidden" name="Specifications[${index}].SpecificationDefinitionId" value="${spec.id}" />
                                <input type="hidden" name="Specifications[${index}].Name" value="${spec.name}" />
                                <input type="hidden" name="Specifications[${index}].Code" value="${spec.code}" />
                                <input type="hidden" name="Specifications[${index}].DataType" value="${spec.dataType}" />
                                <input type="hidden" name="Specifications[${index}].Unit" value="${spec.unit}" />

                                ${inputHtml}
                            </div>
                        `;
                    }).join("");

                    if (window.jQuery && $.validator && $.validator.unobtrusive) {
                        $.validator.unobtrusive.parse(specContainer);
                    }
                }
                catch (error) {
                    console.error("Lỗi loadSpecifications:", error);
                    specContainer.innerHTML = `<div class="alert alert-danger mb-0">Không thể tải thông số kỹ thuật.</div>`;
                }
            }

            if (componentTypeSelect.value) {
                loadSpecifications();
            }
        });
    </script>
}