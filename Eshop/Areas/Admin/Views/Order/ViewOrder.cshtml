@model Eshop.Models.ViewModels.OrderDetailViewModel

@{
    ViewData["title"] = "Chi tiết đơn hàng";
    var canChangeStatus = Model.StatusList.Count > 1;
}

<div class="row g-3 order-detail-page">
    <div class="col-12">
        <div class="d-flex align-items-start align-items-md-center justify-content-between gap-2 flex-column flex-md-row">
            <div>
                <h4 class="mb-1">Chi tiết đơn hàng</h4>
                <div class="small page-subtitle">Theo dõi khách hàng, thanh toán, tổng tiền và quy trình xử lý đơn</div>
            </div>

            <a asp-action="Index" asp-controller="Order" asp-area="Admin" class="btn btn-outline-secondary">
                <i class="fa fa-arrow-left me-1"></i> Quay lại
            </a>
        </div>
    </div>

    <div class="col-12">
        <div class="card-soft info-card">
            <div class="info-grid">
                <div class="info-item">
                    <div class="info-label">Mã đơn</div>
                    <div class="info-value code-pill">@Model.OrderCode</div>
                </div>

                <div class="info-item">
                    <div class="info-label">Ngày đặt</div>
                    <div class="info-value">@Model.CreatedTime.ToString("dd/MM/yyyy HH:mm")</div>
                </div>

                <div class="info-item">
                    <div class="info-label">Trạng thái hiện tại</div>
                    <div class="info-value">
                        <span class="status-pill @OrderDisplayHelper.GetSoftBadgeClass(Model.Status)">
                            @OrderDisplayHelper.GetStatusLabel(Model.Status)
                        </span>
                    </div>
                </div>

                <div class="info-item">
                    <div class="info-label">Phương thức thanh toán</div>
                    <div class="info-value">
                        <span class="@OrderDisplayHelper.GetPaymentMethodBadgeClass(Model.PaymentMethod)">
                            @OrderDisplayHelper.GetPaymentMethodLabel(Model.PaymentMethod)
                        </span>
                    </div>
                </div>

                <div class="info-item">
                    <div class="info-label">Tài khoản</div>
                    <div class="info-value">@Model.UserName</div>
                </div>

                <div class="info-item">
                    <div class="info-label">Người nhận</div>
                    <div class="info-value">@(string.IsNullOrWhiteSpace(Model.FullName) ? "-" : Model.FullName)</div>
                </div>

                <div class="info-item">
                    <div class="info-label">Số điện thoại</div>
                    <div class="info-value">@(string.IsNullOrWhiteSpace(Model.Phone) ? "-" : Model.Phone)</div>
                </div>

                <div class="info-item">
                    <div class="info-label">Email</div>
                    <div class="info-value">@(string.IsNullOrWhiteSpace(Model.Email) ? "-" : Model.Email)</div>
                </div>

                <div class="info-item full-row">
                    <div class="info-label">Địa chỉ giao hàng</div>
                    <div class="info-value">@(string.IsNullOrWhiteSpace(Model.Address) ? "-" : Model.Address)</div>
                </div>

                <div class="info-item full-row">
                    <div class="info-label">Ghi chú</div>
                    <div class="info-value">@(string.IsNullOrWhiteSpace(Model.Note) ? "Không có ghi chú" : Model.Note)</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card-soft table-card">
            <div class="table-toolbar">
                <div>
                    <div class="section-title mb-0">Sản phẩm trong đơn</div>
                    <div class="section-subtitle">Kiểm tra snapshot sản phẩm, số lượng và các khoản thanh toán của đơn hàng</div>
                </div>
            </div>

            <form id="updateForm">
                @Html.AntiForgeryToken()
                <input type="hidden" id="orderCode" value="@Model.OrderCode" />

                <div class="table-responsive">
                    <table class="table detail-table" id="detail_order">
                        <thead>
                            <tr>
                                <th>Sản phẩm</th>
                                <th class="text-right">Giá</th>
                                <th class="text-center">Số lượng</th>
                                <th class="text-right">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.OrderDetails.Any())
                            {
                                foreach (var item in Model.OrderDetails)
                                {
                                    <tr>
                                        <td>
                                            @{
                                                var imageSrc = ProductImageHelper.ResolveAssetUrl(item.ProductImage)
                                                    ?? ProductImageHelper.ResolveProductImage(item.Product);
                                            }
                                            <div class="order-item-cell">
                                                @if (!string.IsNullOrWhiteSpace(imageSrc))
                                                {
                                                    <img src="@imageSrc"
                                                         alt="@item.ProductName"
                                                         class="order-item-thumb"
                                                         loading="lazy" />
                                                }
                                                else
                                                {
                                                    <div class="order-item-thumb order-item-thumb--placeholder" aria-hidden="true">
                                                        <i class="fa fa-picture-o"></i>
                                                    </div>
                                                }

                                                <div class="order-item-body">
                                                    <div class="cell-main">@item.ProductName</div>
                                                    @if (!string.IsNullOrWhiteSpace(item.BuildName) || !string.IsNullOrWhiteSpace(item.ComponentType))
                                                    {
                                                        <div class="cell-sub">
                                                            @(string.IsNullOrWhiteSpace(item.BuildName) ? item.ComponentType : item.BuildName)
                                                            @if (!string.IsNullOrWhiteSpace(item.BuildName) && !string.IsNullOrWhiteSpace(item.ComponentType))
                                                            {
                                                                <span> - @item.ComponentType</span>
                                                            }
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-right">
                                            <span class="money-text">@item.Price.ToString("N0") đ</span>
                                        </td>
                                        <td class="text-center">
                                            <span class="qty-pill">@item.Quantity</span>
                                        </td>
                                        <td class="text-right">
                                            <span class="money-text">@((item.Price * item.Quantity).ToString("N0")) đ</span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="empty-cell text-center">
                                        <div class="empty-wrap">
                                            <i class="fa fa-folder-open-o empty-icon"></i>
                                            <div>Không có chi tiết đơn hàng.</div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>

                        <tfoot>
                            <tr>
                                <th colspan="3" class="text-right">Tạm tính:</th>
                                <th class="text-right"><span class="total-text">@Model.SubTotal.ToString("N0") đ</span></th>
                            </tr>
                            <tr>
                                <th colspan="3" class="text-right">Giảm giá:</th>
                                <th class="text-right">-@Model.DiscountAmount.ToString("N0") đ</th>
                            </tr>
                            <tr>
                                <th colspan="3" class="text-right">Phí vận chuyển:</th>
                                <th class="text-right">@Model.ShippingCost.ToString("N0") đ</th>
                            </tr>
                            <tr>
                                <th colspan="3" class="text-right">Tổng thanh toán:</th>
                                <th class="text-right"><span class="total-text text-danger">@Model.TotalAmount.ToString("N0") đ</span></th>
                            </tr>
                            <tr>
                                <th colspan="3" class="text-right">Cập nhật trạng thái:</th>
                                <th>
                                    @if (canChangeStatus)
                                    {
                                        <select asp-for="Status"
                                                asp-items="Model.StatusList"
                                                id="orderStatus"
                                                data-current-status="@Model.Status"
                                                class="form-control input-soft status-select">
                                        </select>
                                    }
                                    else
                                    {
                                        <select asp-for="Status"
                                                asp-items="Model.StatusList"
                                                id="orderStatus"
                                                data-current-status="@Model.Status"
                                                class="form-control input-soft status-select"
                                                disabled>
                                        </select>
                                    }
                                    <div class="status-helper">
                                        @(canChangeStatus
                                            ? "Chọn trạng thái mới, xác nhận. Sau đó hệ thống sẽ đồng bộ lại trạng thái."
                                            : "Đơn hàng đang ở trạng thái cuối, không thể cập nhật thêm.")
                                    </div>
                                </th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .info-item.full-row {
        min-width: 100%;
    }

    .order-detail-page .page-subtitle {
        opacity: .75;
    }

    .card-soft {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.05);
    }

    .info-card {
        padding: 20px 22px;
    }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 20px;
    }

    .info-item.full-row {
        grid-column: 1 / -1;
    }

    .info-item {
        min-width: 220px;
    }

    .info-label {
        font-size: 13px;
        color: #6b7280;
        margin-bottom: 6px;
        font-weight: 600;
    }

    .info-value {
        font-size: 16px;
        font-weight: 700;
        color: #111827;
    }

    .code-pill {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 999px;
        background: #111827;
        color: #fff;
        font-size: 12px;
        font-weight: 700;
    }

    .status-pill {
        display: inline-flex;
        align-items: center;
        padding: 6px 12px;
        border-radius: 999px;
        border: 1px solid #dbe3ee;
        background: #f8fafc;
        font-size: 12px;
        font-weight: 700;
    }

    .table-card {
        overflow: hidden;
    }

    .table-toolbar {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 16px;
        padding: 22px 22px 0 22px;
        flex-wrap: wrap;
    }

    .section-title {
        font-size: 20px;
        font-weight: 700;
        color: #111827;
        margin-bottom: 4px;
    }

    .section-subtitle {
        color: #6b7280;
        font-size: 13px;
        margin-bottom: 18px;
    }

    .detail-table {
        margin-bottom: 0;
    }

    .detail-table thead th {
        background: #f8fafc;
        color: #374151;
        font-weight: 700;
        border-bottom: 1px solid #e5e7eb !important;
        vertical-align: middle !important;
        padding: 14px 12px !important;
    }

    .detail-table tbody td,
    .detail-table tfoot th {
        vertical-align: middle !important;
        padding: 14px 12px !important;
        border-top: 1px solid #eef2f7 !important;
    }

    .detail-table tbody tr:hover {
        background: #fafafa;
    }

    .order-item-cell {
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: 0;
    }

    .order-item-body {
        min-width: 0;
    }

    .order-item-thumb {
        width: 64px;
        height: 64px;
        border-radius: 14px;
        object-fit: cover;
        flex-shrink: 0;
        border: 1px solid #e5e7eb;
        background: #fff;
    }

    .order-item-thumb--placeholder {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #f8fafc;
        color: #94a3b8;
        font-size: 20px;
    }

    .cell-main {
        font-weight: 700;
        color: #111827;
    }

    .cell-sub {
        font-size: 12px;
        color: #6b7280;
        margin-top: 4px;
    }

    .money-text {
        font-weight: 700;
        color: #111827;
    }

    .total-text {
        font-weight: 800;
        color: #111827;
        font-size: 16px;
    }

    .qty-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 38px;
        padding: 6px 10px;
        border-radius: 999px;
        background: #111827;
        color: #fff;
        font-size: 12px;
        font-weight: 700;
    }

    .input-soft {
        border-radius: 12px;
        border: 1px solid #d1d5db;
        box-shadow: none;
        min-height: 44px;
        background: #fff;
    }

    .input-soft:focus {
        border-color: #86b7fe;
        box-shadow: 0 0 0 3px rgba(13, 110, 253, .12);
    }

    .status-select {
        min-width: 220px;
    }

    .status-select.is-updating {
        opacity: .7;
        cursor: wait;
    }

    .status-helper {
        margin-top: 8px;
        font-size: 12px;
        color: #6b7280;
        line-height: 1.5;
    }

    .btn-outline-secondary {
        border-radius: 12px;
        padding: 10px 18px;
    }

    .empty-cell {
        padding: 40px 20px !important;
    }

    .empty-wrap {
        color: #6b7280;
    }

    .empty-icon {
        font-size: 28px;
        margin-bottom: 8px;
        display: block;
    }

    .payment-badge {
        display: inline-flex;
        align-items: center;
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
        border: 1px solid transparent;
    }

    .payment-badge-cod {
        background: #ecfdf5;
        color: #047857;
        border-color: #a7f3d0;
    }

    .payment-badge-vnpay {
        background: #eff6ff;
        color: #1d4ed8;
        border-color: #bfdbfe;
    }

    .payment-badge-momo {
        background: #fdf2f8;
        color: #be185d;
        border-color: #fbcfe8;
    }

    .payment-badge-bank {
        background: #eef2ff;
        color: #4338ca;
        border-color: #c7d2fe;
    }

    .payment-badge-default {
        background: #f3f4f6;
        color: #374151;
        border-color: #d1d5db;
    }

    @@media (max-width: 767px) {
        .info-card {
            padding: 16px 18px;
        }

        .table-toolbar {
            padding: 18px 18px 0 18px;
        }

        .status-select {
            min-width: 100%;
        }
    }
</style>

@section Scripts {
    <script>
        let isUpdatingOrderStatus = false;

        $(document).on('change', '#orderStatus', async function () {
            const $statusSelect = $(this);
            const orderCode = $('#orderCode').val();
            const status = $statusSelect.val();
            const selectedText = $('#orderStatus option:selected').text();
            const token = $('input[name="__RequestVerificationToken"]').val();
            const previousValue = $statusSelect.attr('data-current-status') || '@Model.Status';
            const previousText = $statusSelect.find(`option[value="${previousValue}"]`).text() || '@OrderDisplayHelper.GetStatusLabel(Model.Status)';

            if (isUpdatingOrderStatus || !status || status === previousValue) {
                $statusSelect.val(previousValue);
                return;
            }

            const confirmResult = await showAppConfirm({
                title: 'Cập nhật trạng thái đơn hàng?',
                text: `Đơn sẽ chuyển từ "${previousText}" sang "${selectedText}".`,
                confirmButtonText: 'Cập nhật',
                cancelButtonText: 'Hủy'
            });

            if (!confirmResult.isConfirmed) {
                $statusSelect.val(previousValue);
                return;
            }

            isUpdatingOrderStatus = true;
            $statusSelect.prop('disabled', true).addClass('is-updating');

            $.ajax({
                url: '@Url.Action("UpdateOrder", "Order", new { area = "Admin" })',
                type: 'POST',
                data: {
                    __RequestVerificationToken: token,
                    orderCode: orderCode,
                    status: status
                },
                success: async function (res) {
                    if (res.success) {
                        $statusSelect.attr('data-current-status', status);
                        await showAppAlert(res.message || `Đã cập nhật trạng thái sang "${res.statusLabel}".`, 'success');
                        window.location.href = res.reloadUrl || window.location.href;
                    } else {
                        await showAppAlert(res.message || 'Không thể cập nhật trạng thái.', 'error');
                        $statusSelect.val(previousValue);
                        $statusSelect.prop('disabled', false).removeClass('is-updating');
                        isUpdatingOrderStatus = false;
                    }
                },
                error: async function (xhr) {
                    const message = xhr.responseJSON?.message || 'Cập nhật trạng thái thất bại.';
                    await showAppAlert(message, 'error');
                    $statusSelect.val(previousValue);
                    $statusSelect.prop('disabled', false).removeClass('is-updating');
                    isUpdatingOrderStatus = false;
                }
            });
        });
    </script>
}
