@model IEnumerable<Eshop.Models.OrderDetails>
@{
    ViewData["title"] = "Order Detail";
    var orderCode = ViewBag.OrderCode as string;
    var currentStatus = (int)(ViewBag.OrderStatus ?? 1);
    decimal subtotal = 0;
}

<h3>Order Detail View</h3>

@if (!string.IsNullOrEmpty(orderCode))
{
    <p><strong>Order Code:</strong> @orderCode</p>
    <p><strong>User Name:</strong> @(Model?.FirstOrDefault()?.UserName ?? "N/A")</p>
}

@Html.AntiForgeryToken()
<input type="hidden" id="orderCode" value="@ViewBag.OrderCode" />
<input type="hidden" id="userName" value="@(Model?.FirstOrDefault()?.UserName ?? "N/A")" />

<table class="table" id="detail_order">
    <thead>
        <tr>
            <th>Product</th>
            <th>Price</th>
            <th>Quantity</th>
            <th>Line Total</th>
        </tr>
    </thead>

    <tbody>
        @if (Model != null && Model.Any())
        {
            subtotal = Model.Sum(item => item.Price * item.Quantity);

            foreach (var item in Model)
            {
                var lineTotal = item.Price * item.Quantity;
                <tr>
                    <td>@(item.Product != null ? item.Product.Name : "N/A")</td>
                    <td>@item.Price</td>
                    <td>@item.Quantity</td>
                    <td>@lineTotal.ToString("C")</td>
                </tr>
            }
        }
    </tbody>

    @if (Model != null && Model.Any())
    {
        <tfoot>
            <tr>
                <th colspan="3" class="text-end">Total:</th>
                <th>@subtotal.ToString("C")</th>
            </tr>
            <tr>
                <th colspan="3" class="text-end">Status:</th>
                <th>
                    <select id="orderStatus" class="form-select">
                        <option value="1" selected="@(currentStatus == 1)">Pending</option>
                        <option value="2" selected="@(currentStatus == 2)">Processing</option>
                        <option value="3" selected="@(currentStatus == 3)">Shipped</option>
                        <option value="4" selected="@(currentStatus == 4)">Delivered</option>
                        <option value="5" selected="@(currentStatus == 5)">Completed</option>
                        <option value="6" selected="@(currentStatus == 6)">Cancelled</option>
                    </select>
                </th>
            </tr>
        </tfoot>
    }
</table>


<a asp-action="Index" asp-controller="Order" asp-area="Admin" class="btn btn-secondary">Back to Orders</a>

@section Scripts {
    <script>
        function getPrintInfo() {
          const code = $('#orderCode').val() || '';
          const user = $('#userName').val() || '';
          const status = $('#orderStatus option:selected').text() || '';
          return { code, user, status };
        }

        new DataTable('#detail_order', {
          layout: {
            topStart: {
              buttons: [
                {
                  extend: 'print',
                  title: '',
                  customize: function (win) {
                    const { code, user, status } = getPrintInfo();

                    $(win.document.body).prepend(`
                      <div style="margin-bottom:12px;">
                        <h3 style="margin:0 0 6px 0;">Order Detail</h3>
                        <div><strong>Order Code:</strong> ${code}</div>
                        <div><strong>User Name:</strong> ${user}</div>
                        <div><strong>Status:</strong> ${status}</div>
                      </div>
                    `);
                  }
                },
                {
                  extend: 'pdfHtml5',
                  title: 'Order Detail',
                  customize: function (doc) {
                    const { code, user, status } = getPrintInfo();
                    doc.content.unshift({
                      text: `Order Code: ${code}\nUser Name: ${user}\nStatus: ${status}`,
                      margin: [0, 0, 0, 12]
                    });
                  }
                }
              ]
            }
          }
        });
    </script>
}


