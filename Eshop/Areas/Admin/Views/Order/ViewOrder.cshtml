@model Eshop.Models.ViewModels.OrderDetailViewModel

@{
    ViewData["title"] = "Order Detail";
    decimal subtotal = 0;
}

<h3>Order Detail View</h3>

<p><strong>Order Code:</strong> @Model.OrderCode</p>
<p><strong>User Name:</strong> @Model.UserName</p>

<form id="updateForm">
    @Html.AntiForgeryToken()
    <input type="hidden" id="orderCode" value="@Model.OrderCode" />

    <table class="table" id="detail_order">
        <thead>
            <tr>
                <th>Product</th>
                <th class="text-end">Price</th>
                <th class="text-center">Quantity</th>
                <th class="text-end">Line Total</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.OrderDetails.Any())
            {
                subtotal = Model.OrderDetails.Sum(x => x.Price * x.Quantity);

                foreach (var item in Model.OrderDetails)
                {
                    <tr>
                        <td>@item.Product?.Name</td>
                        <td class="text-end">@item.Price.ToString("N0")</td>
                        <td class="text-center">@item.Quantity</td>
                        <td class="text-end">@((item.Price * item.Quantity).ToString("N0"))</td>
                    </tr>
                }
            }
        </tbody>

        <tfoot>
            <tr>
                <th colspan="3" class="text-end">Total:</th>
                <th class="text-end">@subtotal.ToString("N0")</th>
            </tr>
            <tr>
                <th colspan="3" class="text-end">Status:</th>
                <th>
                    <select asp-for="Status"
                            asp-items="Model.StatusList"
                            id="orderStatus"
                            class="form-select">
                    </select>
                </th>
            </tr>
        </tfoot>
    </table>
</form>

<a asp-action="Index" asp-controller="Order" asp-area="Admin" class="btn btn-secondary">
    Back to Orders
</a>

@section Scripts {
    <script>
        $(document).on('change', '#orderStatus', function () {

            const orderCode = $('#orderCode').val();
            const status = $(this).val();
            const token = $('input[name="__RequestVerificationToken"]').val();

            $.ajax({
                url: '@Url.Action("UpdateOrder", "Order", new { area = "Admin" })',
                type: 'POST',
                data: {
                    __RequestVerificationToken: token,
                    orderCode: orderCode,
                    status: status
                },
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert(res.message);
                    }
                },
                error: function () {
                    alert("Update failed!");
                }
            });
        });
    </script>
}
