@model IEnumerable<Eshop.Models.OrderModel>
@{
    ViewData["Title"] = "Orders";
}

<h3>Orders</h3>

<table class="table table-striped table-hover align-middle" id="order_table">
    <thead>
        <tr>
            <th>Order Code</th>
            <th>User Email</th>
            <th>Order Date</th>
            <th>Order Status</th>
            <th style="width: 180px;">Action</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <tr>
                    <td class="fw-semibold">@item.OrderCode</td>
                    <td>@item.UserName</td>
                    <td>@item.CreatedTime.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>
                        @switch (item.Status)
                        {
                            case 1:
                                <span class="badge bg-warning text-dark">Pending</span>
                                break;
                            case 2:
                                <span class="badge bg-info text-dark">Processing</span>
                                break;
                            case 3:
                                <span class="badge bg-success">Shipped</span>
                                break;
                            case 4:
                                <span class="badge bg-danger">Delivered</span>
                                break;
                            case 5:
                                <span class="badge bg-danger">Completed</span>
                                break;
                            case 6:
                                <span class="badge bg-danger">Cancelled</span>
                                break;
                            default:
                                <span class="badge bg-secondary">New</span>
                                break;
                        }
                    </td>
                    <td>
                        <a asp-area="Admin"
                           asp-action="ViewOrder"
                           asp-controller="Order"
                           asp-route-orderCode="@item.OrderCode"
                           class="btn btn-sm btn-primary">
                            View
                        </a>

                        <a asp-area="Admin"
                           asp-action="Delete"
                           asp-controller="Order"
                           asp-route-id="@item.OrderId"
                           class="btn btn-sm btn-danger confirmDeletion">
                            Delete
                        </a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="5" class="text-center text-muted">No orders found.</td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    <script>
        $(document).on('click', '.confirmDeletion', function (e) {
            if (!confirm('Are you sure you want to delete this order?')) {
                e.preventDefault();
            }
        });
    </script>
    <script>
        let table = new DataTable('#order_table');
    </script>
}
