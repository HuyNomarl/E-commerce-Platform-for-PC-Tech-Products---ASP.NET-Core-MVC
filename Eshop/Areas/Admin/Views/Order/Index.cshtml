@using System.Globalization
@using Eshop.Helpers
@using Eshop.Models
@model IEnumerable<OrderModel>
@{
    ViewData["Title"] = "Orders";

    var orderList = Model?.ToList() ?? new List<OrderModel>();
    var pendingCount = orderList.Count(x =>
    {
        var status = OrderDisplayHelper.ToOrderStatus(x.Status);
        return status == OrderStatus.Pending || status == OrderStatus.Processing;
    });
    var completedCount = orderList.Count(x =>
    {
        var status = OrderDisplayHelper.ToOrderStatus(x.Status);
        return status == OrderStatus.Completed || status == OrderStatus.Delivered;
    });
    var totalRevenue = orderList.Sum(x => x.TotalAmount);
    var paymentOptions = new[] { "COD", "VNPAY", "MOMO", "BANK_TRANSFER", "CARD" }
        .Concat(orderList.Select(x => OrderDisplayHelper.NormalizePaymentMethod(x.PaymentMethod)))
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(x => OrderDisplayHelper.GetPaymentMethodLabel(x))
        .ToList();
}

<div class="admin-ui-page admin-ui-page--blue">
    <section class="admin-ui-hero">
        <div class="admin-ui-hero__content">
            <span class="admin-ui-hero__eyebrow">Orders</span>
            <h4>Quản lý đơn hàng</h4>
            <p class="admin-ui-hero__desc">
                Theo dõi toàn bộ vòng đời đơn hàng, tình trạng thanh toán và tiến độ xử lý trong cùng một khu vực quản trị đồng bộ hơn.
            </p>
            <div class="admin-ui-hero__meta">
                <span class="admin-ui-chip">@orderList.Count đơn hàng</span>
                <span class="admin-ui-chip">@pendingCount cần xử lý</span>
                <span class="admin-ui-chip">@completedCount hoàn tất</span>
                <span class="admin-ui-chip">@totalRevenue.ToString("N0") đ</span>
            </div>
        </div>

        <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="admin-ui-back">
            <i class="fa fa-arrow-left"></i>
            Về dashboard
        </a>
    </section>

<div class="row g-3 orders-index-page">
    <div class="col-12">
        <div class="card-soft table-card">
            <div class="table-toolbar">
                <div>
                    <div class="section-title mb-0">Danh sách đơn hàng</div>
                    <div class="section-subtitle">Theo dõi khách hàng, thanh toán, trạng thái vận hành và tổng tiền đơn.</div>
                </div>

                <div class="toolbar-right">
                    <div class="search-box">
                        <span class="search-icon">
                            <i class="fa fa-search"></i>
                        </span>
                        <input type="text" id="tableSearch" class="form-control" placeholder="Tìm theo mã đơn, khách hàng, email..." />
                    </div>

                    <span class="total-badge">
                        Tổng: <span id="totalRows">@orderList.Count</span>
                    </span>
                </div>
            </div>

            <div id="orderLiveBanner" class="live-banner" style="display:none;">
                <div>
                    <strong>Có đơn hàng mới</strong>
                    <span id="orderLiveText" class="live-banner-text"></span>
                </div>
                <button type="button" id="reloadOrdersBtn" class="btn btn-sm btn-primary">
                    Tải lại
                </button>
            </div>

            <div class="filter-card">
                <div class="filter-top">
                    <div>
                        <div class="filter-title">
                            <i class="fa fa-filter"></i>
                            <span>Bộ lọc nâng cao</span>
                        </div>
                        <div class="filter-hint">Kết hợp nhiều điều kiện để thu hẹp nhanh danh sách đơn hàng cần xử lý.</div>
                    </div>

                    <button type="button" id="resetFilters" class="btn-reset-filter">
                        Xóa bộ lọc
                    </button>
                </div>

                <div class="row g-3">
                    <div class="col-12 col-md-6 col-xl-3">
                        <label class="filter-label" for="filterStatus">Trạng thái</label>
                        <select id="filterStatus" class="form-select filter-control">
                            <option value="">Tất cả</option>
                            @foreach (var status in Enum.GetValues<OrderStatus>())
                            {
                                <option value="@((int)status)">@OrderDisplayHelper.GetStatusLabel(status)</option>
                            }
                        </select>
                    </div>

                    <div class="col-12 col-md-6 col-xl-3">
                        <label class="filter-label" for="filterPayment">Thanh toán</label>
                        <select id="filterPayment" class="form-select filter-control">
                            <option value="">Tất cả</option>
                            @foreach (var payment in paymentOptions)
                            {
                                <option value="@payment">@OrderDisplayHelper.GetPaymentMethodLabel(payment)</option>
                            }
                        </select>
                    </div>

                    <div class="col-12 col-md-6 col-xl-3">
                        <label class="filter-label" for="filterDateFrom">Ngày đặt từ</label>
                        <input type="date" id="filterDateFrom" class="form-control filter-control" />
                    </div>

                    <div class="col-12 col-md-6 col-xl-3">
                        <label class="filter-label" for="filterDateTo">Ngày đặt đến</label>
                        <input type="date" id="filterDateTo" class="form-control filter-control" />
                    </div>

                    <div class="col-12 col-md-6 col-xl-3">
                        <label class="filter-label" for="filterMinTotal">Tổng tiền từ</label>
                        <input type="text" id="filterMinTotal" class="form-control filter-control" placeholder="Ví dụ: 500000" />
                    </div>

                    <div class="col-12 col-md-6 col-xl-3">
                        <label class="filter-label" for="filterMaxTotal">Tổng tiền đến</label>
                        <input type="text" id="filterMaxTotal" class="form-control filter-control" placeholder="Ví dụ: 5000000" />
                    </div>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table order-table" id="myTable">
                    <thead>
                        <tr>
                            <th>Mã đơn</th>
                            <th>Khách hàng</th>
                            <th>Ngày đặt</th>
                            <th>Trạng thái</th>
                            <th>Thanh toán</th>
                            <th>Tổng tiền</th>
                            <th style="width: 150px;" class="text-right">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (orderList.Any())
                        {
                            foreach (var item in orderList)
                            {
                                <tr data-order-status="@item.Status"
                                    data-order-payment="@OrderDisplayHelper.NormalizePaymentMethod(item.PaymentMethod)"
                                    data-order-date="@item.CreatedTime.ToString("yyyy-MM-dd")"
                                    data-order-total="@item.TotalAmount.ToString(CultureInfo.InvariantCulture)">
                                    <td>
                                        <span class="code-pill">@item.OrderCode</span>
                                    </td>

                                    <td>
                                        <div class="cell-main">@(string.IsNullOrWhiteSpace(item.FullName) ? item.UserName : item.FullName)</div>
                                        <div class="cell-sub">@item.Email</div>
                                    </td>

                                    <td>
                                        <span class="date-text">@item.CreatedTime.ToString("yyyy-MM-dd HH:mm")</span>
                                    </td>

                                    <td>
                                        <span class="badge-soft @OrderDisplayHelper.GetSoftBadgeClass(item.Status)">
                                            @OrderDisplayHelper.GetStatusLabel(item.Status)
                                        </span>
                                    </td>

                                    <td>
                                        <span class="@OrderDisplayHelper.GetPaymentMethodBadgeClass(item.PaymentMethod)">
                                            @OrderDisplayHelper.GetPaymentMethodLabel(item.PaymentMethod)
                                        </span>
                                    </td>

                                    <td>
                                        <span class="price-pill">@item.TotalAmount.ToString("N0") đ</span>
                                    </td>

                                    <td class="text-right">
                                        <div class="action-group">
                                            <a asp-area="Admin"
                                               asp-action="ViewOrder"
                                               asp-controller="Order"
                                               asp-route-orderCode="@item.OrderCode"
                                               class="icon-btn icon-view"
                                               title="Xem">
                                                <i class="fa fa-eye"></i>
                                            </a>

                                            <a asp-area="Admin"
                                               asp-action="ExportInvoice"
                                               asp-controller="Order"
                                               asp-route-orderCode="@item.OrderCode"
                                               target="_blank"
                                               rel="noopener"
                                               class="icon-btn icon-print"
                                               title="Xuất hóa đơn">
                                                <i class="fa fa-print"></i>
                                            </a>

                                            <a asp-area="Admin"
                                               asp-action="Delete"
                                               asp-controller="Order"
                                               asp-route-id="@item.OrderId"
                                               class="icon-btn icon-delete"
                                               title="Xóa"
                                               data-swal-confirm-link
                                               data-swal-title="Xóa đơn hàng?"
                                               data-swal-text="Thao tác này có thể làm mất dữ liệu đơn hàng đang theo dõi."
                                               data-swal-confirm-text="Xóa"
                                               data-swal-cancel-text="Hủy">
                                                <i class="fa fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="empty-cell text-center">
                                    <div class="empty-wrap">
                                        <i class="fa fa-folder-open-o empty-icon"></i>
                                        <div>Không có đơn hàng nào.</div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
</div>

<style>
    .live-banner {
        margin: 0 22px 16px 22px;
        padding: 12px 14px;
        border: 1px solid #fecaca;
        background: #fef2f2;
        color: #991b1b;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
    }

    .live-banner-text {
        margin-left: 8px;
        font-size: 13px;
    }

    .orders-index-page .page-subtitle {
        opacity: .75;
    }

    .card-soft {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.05);
    }

    .table-card {
        overflow: hidden;
    }

    .filter-card {
        margin: 0 22px 18px 22px;
        padding: 18px;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        background: linear-gradient(180deg, #fcfdff 0%, #f8fafc 100%);
    }

    .table-toolbar {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 16px;
        padding: 22px 22px 0 22px;
        flex-wrap: wrap;
    }

    .section-title {
        font-size: 20px;
        font-weight: 700;
        color: #111827;
        margin-bottom: 4px;
    }

    .section-subtitle {
        color: #6b7280;
        font-size: 13px;
        margin-bottom: 18px;
    }

    .filter-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 16px;
        margin-bottom: 16px;
        flex-wrap: wrap;
    }

    .filter-title {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 15px;
        font-weight: 700;
        color: #111827;
    }

    .filter-hint {
        margin-top: 6px;
        color: #6b7280;
        font-size: 13px;
    }

    .filter-label {
        display: block;
        margin-bottom: 8px;
        font-size: 13px;
        font-weight: 700;
        color: #111827;
    }

    .filter-control {
        min-height: 42px;
        border-radius: 12px;
        border: 1px solid #d1d5db;
        box-shadow: none;
    }

    .filter-control:focus,
    .filter-control:active {
        border-color: #86b7fe;
        box-shadow: 0 0 0 0.2rem rgba(59, 130, 246, 0.12);
    }

    .toolbar-right {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .search-box {
        position: relative;
        min-width: 280px;
    }

    .search-box .form-control {
        height: 42px;
        border-radius: 12px;
        padding-left: 40px;
        border: 1px solid #d1d5db;
        box-shadow: none;
    }

    .search-icon {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: #6b7280;
        z-index: 2;
    }

    .total-badge {
        display: inline-flex;
        align-items: center;
        border: 1px solid #d1d5db;
        background: #f9fafb;
        color: #374151;
        border-radius: 999px;
        padding: 8px 14px;
        font-size: 13px;
        font-weight: 600;
    }

    .btn-reset-filter {
        min-height: 42px;
        border-radius: 12px;
        border: 1px solid #d1d5db;
        background: #fff;
        color: #374151;
        padding: 0 14px;
        font-size: 13px;
        font-weight: 700;
        transition: all .2s ease;
    }

    .btn-reset-filter:hover {
        background: #f3f4f6;
        border-color: #cbd5e1;
    }

    .order-table {
        margin-bottom: 0;
    }

    .order-table thead th {
        background: #f8fafc;
        color: #374151;
        font-weight: 700;
        border-bottom: 1px solid #e5e7eb !important;
        vertical-align: middle !important;
        padding: 14px 12px !important;
    }

    .order-table tbody td {
        vertical-align: middle !important;
        padding: 14px 12px !important;
        border-top: 1px solid #eef2f7 !important;
    }

    .order-table tbody tr:hover {
        background: #fafafa;
    }

    .code-pill {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 999px;
        background: #111827;
        color: #fff;
        font-size: 12px;
        font-weight: 700;
    }

    .cell-main {
        font-weight: 700;
        color: #111827;
    }

    .cell-sub {
        font-size: 12px;
        color: #6b7280;
        margin-top: 4px;
    }

    .date-text {
        font-size: 13px;
        color: #374151;
        font-weight: 600;
        white-space: nowrap;
    }

    .price-pill {
        display: inline-flex;
        align-items: center;
        padding: 6px 12px;
        border-radius: 999px;
        background: #f8fafc;
        border: 1px solid #dbe3ee;
        color: #374151;
        font-size: 12px;
        font-weight: 700;
    }

    .badge-soft {
        display: inline-flex;
        align-items: center;
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
        border: 1px solid #dbe3ee;
        background: #f8fafc;
        white-space: nowrap;
    }

    .badge-warn { color: #b45309; }
    .badge-info { color: #0284c7; }
    .badge-show { color: #15803d; }
    .badge-success { color: #047857; }
    .badge-success-dark { color: #166534; }
    .badge-delete { color: #991b1b; }
    .badge-secondary { color: #6b7280; }

    .action-group {
        display: inline-flex;
        justify-content: flex-end;
        gap: 8px;
        flex-wrap: wrap;
    }

    .icon-btn {
        width: 38px;
        height: 38px;
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid #e5e7eb;
        background: #fff;
        text-decoration: none !important;
        transition: all .2s ease;
    }

    .icon-btn:hover {
        background: #f3f4f6;
        border-color: #d1d5db;
    }

    .icon-view { color: #2563eb; }
    .icon-print { color: #0f766e; }
    .icon-delete { color: #ef4444; }

    .empty-cell {
        padding: 40px 20px !important;
    }

    .empty-wrap {
        color: #6b7280;
    }

    .empty-icon {
        font-size: 28px;
        margin-bottom: 8px;
        display: block;
    }

    .payment-badge {
        display: inline-flex;
        align-items: center;
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
        border: 1px solid transparent;
    }

    .payment-badge-cod {
        background: #ecfdf5;
        color: #047857;
        border-color: #a7f3d0;
    }

    .payment-badge-vnpay {
        background: #eff6ff;
        color: #1d4ed8;
        border-color: #bfdbfe;
    }

    .payment-badge-momo {
        background: #fdf2f8;
        color: #be185d;
        border-color: #fbcfe8;
    }

    .payment-badge-bank {
        background: #eef2ff;
        color: #4338ca;
        border-color: #c7d2fe;
    }

    .payment-badge-default {
        background: #f3f4f6;
        color: #374151;
        border-color: #d1d5db;
    }

    div.dt-container .dt-search {
        display: none;
    }

    div.dt-container .dt-layout-row {
        padding: 12px 16px;
    }

    @@media (max-width: 767px) {
        .table-toolbar {
            padding: 18px 18px 0 18px;
            flex-direction: column;
            align-items: stretch;
        }

        .filter-top {
            flex-direction: column;
            align-items: stretch;
        }

        .filter-card {
            margin: 0 18px 18px 18px;
        }

        .search-box {
            min-width: 100%;
        }

        .toolbar-right {
            width: 100%;
        }

        .btn-reset-filter {
            width: 100%;
        }
    }
</style>

@section Scripts {
    <script>
        const orderBanner = document.getElementById("orderLiveBanner");
        const orderLiveText = document.getElementById("orderLiveText");
        const reloadOrdersBtn = document.getElementById("reloadOrdersBtn");

        window.addEventListener("eshop:new-order", function (e) {
            const data = e.detail || {};

            if (orderBanner) {
                orderBanner.style.display = "flex";
            }

            if (orderLiveText) {
                orderLiveText.textContent = `- ${data.orderCode || ""} / ${data.fullName || ""}`;
            }
        });

        if (reloadOrdersBtn) {
            reloadOrdersBtn.addEventListener("click", function () {
                window.location.reload();
            });
        }

        const table = new DataTable('#myTable', {
            layout: {
                topStart: { buttons: ['copy', 'csv', 'excel', 'pdf', 'print'] },
                topEnd: null
            },
            order: [[2, 'desc']]
        });

        const searchInput = document.getElementById('tableSearch');
        const totalEl = document.getElementById('totalRows');
        const filterStatus = document.getElementById('filterStatus');
        const filterPayment = document.getElementById('filterPayment');
        const filterDateFrom = document.getElementById('filterDateFrom');
        const filterDateTo = document.getElementById('filterDateTo');
        const filterMinTotal = document.getElementById('filterMinTotal');
        const filterMaxTotal = document.getElementById('filterMaxTotal');
        const resetFiltersBtn = document.getElementById('resetFilters');

        function parseAmount(value) {
            if (value === null || value === undefined || value === '') return 0;

            const cleaned = value.toString().replace(/,/g, '').replace(/[^\d.-]/g, '');
            const parsed = Number.parseFloat(cleaned);
            return Number.isNaN(parsed) ? 0 : parsed;
        }

        DataTable.ext.search.push(function (settings, data, dataIndex) {
            if (settings.nTable.id !== 'myTable') return true;

            const rowNode = settings.aoData[dataIndex]?.nTr;
            if (!rowNode) return true;

            const rowStatus = rowNode.dataset.orderStatus || '';
            const rowPayment = rowNode.dataset.orderPayment || '';
            const rowDate = rowNode.dataset.orderDate || '';
            const rowTotal = parseAmount(rowNode.dataset.orderTotal || '');

            const selectedStatus = (filterStatus?.value || '').trim();
            const selectedPayment = (filterPayment?.value || '').trim();
            const selectedDateFrom = (filterDateFrom?.value || '').trim();
            const selectedDateTo = (filterDateTo?.value || '').trim();
            const minTotalRaw = (filterMinTotal?.value || '').trim();
            const maxTotalRaw = (filterMaxTotal?.value || '').trim();
            const minTotal = parseAmount(minTotalRaw);
            const maxTotal = parseAmount(maxTotalRaw);

            if (selectedStatus && rowStatus !== selectedStatus) return false;
            if (selectedPayment && rowPayment !== selectedPayment) return false;
            if (selectedDateFrom && (!rowDate || rowDate < selectedDateFrom)) return false;
            if (selectedDateTo && (!rowDate || rowDate > selectedDateTo)) return false;
            if (minTotalRaw !== '' && rowTotal < minTotal) return false;
            if (maxTotalRaw !== '' && rowTotal > maxTotal) return false;

            return true;
        });

        if (searchInput) {
            searchInput.addEventListener('keyup', function () {
                table.search(this.value).draw();
            });
        }

        [
            filterStatus,
            filterPayment,
            filterDateFrom,
            filterDateTo
        ].forEach(el => {
            if (el) {
                el.addEventListener('change', function () {
                    table.draw();
                });
            }
        });

        [
            filterMinTotal,
            filterMaxTotal
        ].forEach(el => {
            if (el) {
                el.addEventListener('input', function () {
                    table.draw();
                });
            }
        });

        if (resetFiltersBtn) {
            resetFiltersBtn.addEventListener('click', function () {
                if (searchInput) searchInput.value = '';
                if (filterStatus) filterStatus.value = '';
                if (filterPayment) filterPayment.value = '';
                if (filterDateFrom) filterDateFrom.value = '';
                if (filterDateTo) filterDateTo.value = '';
                if (filterMinTotal) filterMinTotal.value = '';
                if (filterMaxTotal) filterMaxTotal.value = '';

                table.search('').draw();
            });
        }

        table.on('draw', function () {
            const info = table.page.info();
            if (totalEl) {
                totalEl.textContent = info.recordsDisplay;
            }
        });
    </script>
}
