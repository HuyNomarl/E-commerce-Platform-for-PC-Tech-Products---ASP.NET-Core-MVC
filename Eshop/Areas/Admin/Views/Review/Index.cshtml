@model IEnumerable<Eshop.Models.RatingModel>
@using System.Linq

@{
    ViewData["Title"] = "Phản hồi đánh giá";
    var reviews = Model?.ToList() ?? new List<Eshop.Models.RatingModel>();
    var repliedCount = reviews.Count(x => !string.IsNullOrWhiteSpace(x.AdminReply));
    var mediaCount = reviews.Sum(x => x.MediaItems?.Count ?? 0);
}

@functions {
    public static string BuildInitial(string? name)
    {
        return string.IsNullOrWhiteSpace(name) ? "?" : name.Trim()[0].ToString().ToUpperInvariant();
    }
}

<div class="admin-ui-page admin-ui-page--amber review-admin-page">
    <section class="admin-ui-hero">
        <div class="admin-ui-hero__content">
            <span class="admin-ui-hero__eyebrow">Reviews</span>
            <h4>Phản hồi đánh giá</h4>
            <p class="admin-ui-hero__desc">
                Theo dõi đánh giá của khách hàng, phản hồi từ admin và media đính kèm trong một khu vực quản trị gọn gàng, dễ quét hơn.
            </p>
            <div class="admin-ui-hero__meta">
                <span class="admin-ui-chip">@reviews.Count review</span>
                <span class="admin-ui-chip">@repliedCount đã phản hồi</span>
                <span class="admin-ui-chip">@mediaCount media đính kèm</span>
            </div>
        </div>

        <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="admin-ui-back">
            <i class="fa fa-arrow-left"></i>
            Về dashboard
        </a>
    </section>

    <div class="review-admin-list">
        @if (reviews.Any())
        {
            @foreach (var review in reviews)
            {
                <article class="review-admin-card">
                    <div class="review-admin-main">
                        <div class="review-admin-avatar">@BuildInitial(review.Name)</div>
                        <div class="review-admin-body">
                            <div class="review-admin-top">
                                <div>
                                    <strong>@(string.IsNullOrWhiteSpace(review.Name) ? "Khách hàng" : review.Name)</strong>
                                    <div class="review-admin-meta">
                                        <span>Sản phẩm: @(review.Product?.Name ?? "Không xác định")</span>
                                        <span>@((review.UpdatedAt ?? review.CreatedAt).ToString("dd/MM/yyyy HH:mm"))</span>
                                    </div>
                                </div>

                                <div class="review-admin-stars">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="fa @(i <= review.Stars ? "fa-star" : "fa-star-o")"></i>
                                    }
                                </div>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(review.Comment))
                            {
                                <p class="review-admin-comment">@review.Comment</p>
                            }

                            @if (review.MediaItems.Any())
                            {
                                <div class="review-admin-media">
                                    @foreach (var media in review.MediaItems.OrderBy(x => x.SortOrder).ThenBy(x => x.Id))
                                    {
                                        <div class="review-admin-media-item">
                                            @if (string.Equals(media.ResourceType, "video", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <video controls preload="metadata"><source src="@media.Url" /></video>
                                            }
                                            else
                                            {
                                                <img src="@media.Url" alt="review-media" />
                                            }
                                        </div>
                                    }
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(review.AdminReply))
                            {
                                <div class="review-admin-replied">
                                    <div class="review-admin-reply-label">
                                        Phản hồi hiện tại
                                        @if (!string.IsNullOrWhiteSpace(review.AdminReplyByName))
                                        {
                                            <span>bởi @review.AdminReplyByName</span>
                                        }
                                    </div>
                                    <div class="review-admin-reply-text">@review.AdminReply</div>
                                    @if (review.AdminReplyAt.HasValue)
                                    {
                                        <div class="review-admin-reply-time">@review.AdminReplyAt.Value.ToString("dd/MM/yyyy HH:mm")</div>
                                    }
                                </div>
                            }

                            <form asp-action="Reply" asp-controller="Review" method="post" class="review-admin-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@review.Id" />
                                <textarea name="adminReply"
                                          rows="4"
                                          placeholder="Nhập phản hồi của admin cho review này...">@review.AdminReply</textarea>
                                <div class="review-admin-actions">
                                    <button type="submit" class="btn btn-dark">
                                        @(string.IsNullOrWhiteSpace(review.AdminReply) ? "Lưu phản hồi" : "Cập nhật phản hồi")
                                    </button>
                                    @if (!string.IsNullOrWhiteSpace(review.AdminReply))
                                    {
                                        <span class="review-admin-hint">Xóa nội dung và lưu lại nếu bạn muốn bỏ phản hồi hiện tại.</span>
                                    }
                                </div>
                            </form>
                        </div>
                    </div>
                </article>
            }
        }
        else
        {
            <div class="review-admin-empty">Chưa có review nào để phản hồi.</div>
        }
    </div>
</div>

<style>
    .review-admin-list {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .review-admin-card {
        padding: 22px;
    }

    .review-admin-main {
        display: flex;
        gap: 14px;
    }

    .review-admin-avatar {
        width: 54px;
        height: 54px;
        border-radius: 18px;
        background: linear-gradient(135deg, #f97316, #fb7185);
        color: #ffffff;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        font-weight: 700;
        flex-shrink: 0;
    }

    .review-admin-body {
        flex: 1;
        min-width: 0;
    }

    .review-admin-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 12px;
    }

    .review-admin-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 6px;
        color: #6b7280;
        font-size: 13px;
    }

    .review-admin-stars {
        color: #f59e0b;
        white-space: nowrap;
        font-size: 16px;
    }

    .review-admin-comment {
        margin: 0 0 14px;
        color: #334155;
        line-height: 1.7;
        white-space: pre-line;
    }

    .review-admin-media {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
        gap: 10px;
        margin-bottom: 14px;
    }

    .review-admin-media-item {
        overflow: hidden;
        border-radius: 16px;
        border: 1px solid #e5e7eb;
        background: #f8fafc;
    }

    .review-admin-media-item img,
    .review-admin-media-item video {
        width: 100%;
        height: 120px;
        object-fit: cover;
        display: block;
    }

    .review-admin-replied {
        border-radius: 16px;
        padding: 14px;
        margin-bottom: 14px;
    }

    .review-admin-reply-label {
        font-size: 13px;
        font-weight: 700;
        color: #1d4ed8;
        margin-bottom: 8px;
    }

    .review-admin-reply-label span {
        margin-left: 8px;
        font-weight: 500;
        color: #64748b;
    }

    .review-admin-reply-text {
        color: #1e293b;
        line-height: 1.7;
        white-space: pre-line;
    }

    .review-admin-reply-time {
        margin-top: 8px;
        font-size: 12px;
        color: #64748b;
    }

    .review-admin-form textarea {
        width: 100%;
        padding: 12px 14px;
    }

    .review-admin-hint {
        font-size: 12px;
        color: #64748b;
    }

    .review-admin-empty {
        min-height: 160px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px dashed #d1d5db;
        border-radius: 20px;
        background: #fafafa;
        color: #6b7280;
        text-align: center;
        padding: 20px;
    }

    @@media (max-width: 767px) {
        .review-admin-main,
        .review-admin-top,
        .review-admin-actions {
            flex-direction: column;
            align-items: stretch;
        }
    }
</style>
