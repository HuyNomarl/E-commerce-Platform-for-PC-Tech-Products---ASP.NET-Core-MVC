@model IEnumerable<Eshop.Models.ContactModel>
@{
    ViewData["title"] = "Contact";
}

<h3>Contact Index View</h3>
<table class="table" id="myTable">
    <thead>
        <tr>
            <th scope="col">Id</th>
            <th scope="col"> Name</th>
            <th scope="col"> Description</th>
            <th scope="col"> Map</th>
            <th scope="col"> Phone</th>
            <th scope="col"> Email</th>
            <th scope="col"> Image</th>
            <th scope="col">Actions</th>
        </tr>
    </thead>
    <tbody>

        @foreach (var item in Model)
        {
            <tr>
                <td>#</td>
                <td>@item.Name</td>
                <td>@Html.Raw(item.Description)</td>
                <td style="min-width:300px">
                    @{
                        var mapUrl = item.Map ?? "";
                        if (!string.IsNullOrWhiteSpace(mapUrl) && mapUrl.Contains("google.com/maps") && !mapUrl.Contains("output=embed"))
                        {
                            mapUrl += mapUrl.Contains("?") ? "&output=embed" : "?output=embed";
                        }
                    }

                    @if (!string.IsNullOrWhiteSpace(mapUrl))
                    {
                        <iframe src="@mapUrl"
                                width="300"
                                height="180"
                                style="border:0;"
                                loading="lazy"
                                allowfullscreen>
                        </iframe>
                    }
                </td>

                <td>@item.Phone</td>
                <td>@item.Email</td>
                <td><img src="~/media/contact/@item.LogoImg" width="100" height="80" /></td>
                <td>
                    <a asp-action="Edit" asp-controller="Contact"  class="btn btn-primary">Edit</a>
                </td>
            </tr>

        }


    </tbody>
</table>
@section Scripts {
    <script>
        new DataTable('#myTable', {
          layout: {
            topStart: { buttons: ['copy', 'csv', 'excel', 'pdf', 'print'] }
          }
        });
    </script>
}
