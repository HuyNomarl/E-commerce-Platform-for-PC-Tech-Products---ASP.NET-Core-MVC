@model ContactModel
@{
    ViewData["Title"] = "Sửa liên hệ";
}

<div class="admin-ui-page admin-ui-page--blue">
    <section class="admin-ui-hero">
        <div class="admin-ui-hero__content">
            <span class="admin-ui-hero__eyebrow">Contact Information</span>
            <h4>Cập nhật thông tin liên hệ</h4>
            <p class="admin-ui-hero__desc">
                Chỉnh sửa nội dung liên hệ, bản đồ và hình ảnh nhận diện trong một giao diện sáng sủa hơn nhưng vẫn giữ nguyên luồng lưu dữ liệu hiện tại.
            </p>
            <div class="admin-ui-hero__meta">
                <span class="admin-ui-chip">@Model.Name</span>
                <span class="admin-ui-chip">@Model.Email</span>
                <span class="admin-ui-chip">Preview ảnh trực quan</span>
            </div>
        </div>

        <a asp-action="Index" class="admin-ui-back">
            <i class="fa fa-arrow-left"></i>
            Quay lại danh sách
        </a>
    </section>

    <section class="admin-ui-panel">
        <div class="admin-ui-panel__head">
            <div>
                <div class="admin-ui-panel__title">
                    <i class="fa fa-pencil-square-o"></i>
                    Nội dung liên hệ
                </div>
                <div class="admin-ui-panel__subtitle">
                    Cập nhật tên, mô tả, thông tin liên lạc và ảnh đại diện trong cùng một biểu mẫu rõ ràng hơn.
                </div>
            </div>
        </div>

        <div class="admin-ui-panel__body">
            <form asp-action="Edit" asp-controller="Contact" enctype="multipart/form-data" method="post">
                <div asp-validation-summary="ModelOnly" class="admin-ui-validation"></div>

                <div class="admin-ui-form-grid">
                    <div class="admin-ui-col-6">
                        <label asp-for="Name" class="admin-ui-label">Tên</label>
                        <input asp-for="Name" class="admin-ui-control" placeholder="Nhập tên liên hệ" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="admin-ui-col-6">
                        <label asp-for="Phone" class="admin-ui-label">Điện thoại</label>
                        <input asp-for="Phone" class="admin-ui-control" placeholder="Nhập số điện thoại" />
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>

                    <div class="admin-ui-col-6">
                        <label asp-for="Email" class="admin-ui-label">Email</label>
                        <input asp-for="Email" class="admin-ui-control" placeholder="Nhập email liên hệ" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="admin-ui-col-6">
                        <label asp-for="LogoImgFile" class="admin-ui-label">Thay ảnh đại diện</label>
                        <input asp-for="LogoImgFile"
                               type="file"
                               class="admin-ui-control admin-ui-file"
                               accept="image/*"
                               id="ImageUpload" />
                        <span asp-validation-for="LogoImgFile" class="text-danger"></span>
                    </div>

                    <div class="admin-ui-col-12">
                        <label asp-for="Description" class="admin-ui-label">Mô tả</label>
                        <textarea asp-for="Description" class="admin-ui-control admin-ui-control--textarea" placeholder="Nhập mô tả liên hệ"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="admin-ui-col-12">
                        <label asp-for="Map" class="admin-ui-label">Bản đồ</label>
                        <textarea asp-for="Map" class="admin-ui-control admin-ui-control--textarea" placeholder="Dán link Google Maps hoặc iframe"></textarea>
                        <span asp-validation-for="Map" class="text-danger"></span>
                    </div>

                    <div class="admin-ui-col-6">
                        <div class="admin-ui-preview-card admin-ui-preview">
                            <div class="admin-ui-preview-card__label">Ảnh hiện tại</div>
                            @if (!string.IsNullOrEmpty(Model.LogoImg))
                            {
                                <img src="~/media/contact/@Model.LogoImg"
                                     alt="Current contact image"
                                     class="admin-ui-thumb admin-ui-thumb--large" />
                            }
                            else
                            {
                                <div class="admin-ui-empty">Chưa có ảnh nào được tải lên.</div>
                            }
                        </div>
                    </div>

                    <div class="admin-ui-col-6">
                        <div class="admin-ui-preview-card admin-ui-preview">
                            <div class="admin-ui-preview-card__label">Preview ảnh mới</div>
                            <div class="admin-ui-muted">Ảnh mới sẽ hiển thị ở đây ngay sau khi chọn file.</div>
                            <img id="imgpreview"
                                 src="#"
                                 alt="New image preview"
                                 class="admin-ui-thumb admin-ui-thumb--large"
                                 style="display: none;" />
                            <div id="imgpreview-empty" class="admin-ui-empty">
                                Chưa chọn ảnh thay thế.
                            </div>
                        </div>
                    </div>
                </div>

                <div class="admin-ui-form-actions">
                    <button type="submit" class="admin-ui-btn admin-ui-btn--primary">
                        <i class="fa fa-save"></i>
                        Cập nhật
                    </button>

                    <a asp-action="Index" class="admin-ui-btn">
                        <i class="fa fa-list"></i>
                        Danh sách liên hệ
                    </a>
                </div>
            </form>
        </div>
    </section>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function readURL(input) {
            const preview = $("#imgpreview");
            const emptyState = $("#imgpreview-empty");

            if (input.files && input.files[0]) {
                let reader = new FileReader();
                reader.onload = function (e) {
                    preview.attr("src", e.target.result).show();
                    emptyState.hide();
                };
                reader.readAsDataURL(input.files[0]);
            } else {
                preview.hide().attr("src", "#");
                emptyState.show();
            }
        }

        $("#ImageUpload").change(function () {
            readURL(this);
        });

        $("form").on("reset", function () {
            setTimeout(function () {
                $("#imgpreview").hide().attr("src", "#");
                $("#imgpreview-empty").show();
            }, 100);
        });
    </script>
}
