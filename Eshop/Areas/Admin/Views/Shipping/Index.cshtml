@using Eshop.Models
@model ShippingModel

@{
    ViewData["Title"] = "Create Shipping";

    var shippingList = ViewBag.ShippingList as List<ShippingModel> ?? new List<ShippingModel>();
}

<div class="row g-3 shipping-page">
    <div class="col-12">
        <div class="d-flex align-items-start align-items-md-center justify-content-between gap-2 flex-column flex-md-row">
            <div>
                <h4 class="mb-1">Thiết lập vận chuyển</h4>
                <div class="small page-subtitle">Tạo khu vực giao hàng và quản lý phí vận chuyển</div>
            </div>

            <a asp-action="Index" asp-controller="Shipping" asp-area="Admin" class="btn btn-outline-secondary">
                <i class="fa fa-arrow-left me-1"></i> Quay lại
            </a>
        </div>
    </div>

    <div class="col-12 col-xl-5">
        <div class="card-soft form-card">
            <div class="card-body-custom">
                <div class="section-title">Tạo phí vận chuyển</div>
                <div class="section-subtitle">Chọn tỉnh/thành, phường/xã và nhập chi phí giao hàng</div>

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                @Html.AntiForgeryToken()

                <div class="row form-grid">
                    <div class="col-xs-12 form-col">
                        <label class="form-label">Tỉnh thành phố</label>
                        <select class="form-control input-soft" id="tinh" name="tinh" title="Chọn Tỉnh Thành">
                            <option value="0">Tỉnh Thành</option>
                        </select>
                    </div>

                    <div class="col-xs-12 form-col" id="district-wrap">
                        <label class="form-label">Quận huyện</label>
                        <select class="form-control input-soft" id="quan" name="quan" title="Chọn Quận Huyện">
                            <option value="0">Quận Huyện</option>
                        </select>
                    </div>

                    <div class="col-xs-12 form-col">
                        <label class="form-label">Phường xã</label>
                        <select class="form-control input-soft" id="phuong" name="phuong" title="Chọn Phường Xã">
                            <option value="0">Phường Xã</option>
                        </select>
                    </div>

                    <div class="col-xs-12 form-col">
                        <label class="form-label">Giá vận chuyển</label>
                        <input type="number"
                               class="form-control input-soft"
                               id="cost"
                               name="cost"
                               placeholder="Nhập giá vận chuyển"
                               min="0"
                               step="1" />
                    </div>
                </div>

                <div class="form-actions mt-3">
                    <button type="button" class="btn btn-accent btn-add-shipping">
                        <i class="fa fa-plus-circle me-1"></i> Tạo vận chuyển
                    </button>

                    <a asp-action="Index" asp-controller="Shipping" asp-area="Admin" class="btn btn-outline-secondary">
                        Danh sách Shipping
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-7">
        <div class="card-soft table-card">
            <div class="table-toolbar">
                <div>
                    <div class="section-title mb-0">Danh sách vận chuyển</div>
                    <div class="section-subtitle">Quản lý các khu vực và mức phí giao hàng hiện có</div>
                </div>

                <div class="toolbar-right">
                    <div class="search-box">
                        <span class="search-icon">
                            <i class="fa fa-search"></i>
                        </span>
                        <input type="text" id="tableSearch" class="form-control" placeholder="Tìm kiếm trong bảng..." />
                    </div>

                    <span class="total-badge">
                        Tổng: <span id="totalRows">@shippingList.Count</span>
                    </span>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table shipping-table" id="myTable">
                    <thead>
                        <tr>
                            <th style="width: 80px;">ID</th>
                            <th>Tỉnh/TP</th>
                            <th>Quận/Huyện</th>
                            <th>Phường/Xã</th>
                            <th style="width: 150px;">Chi phí</th>
                            <th style="width: 170px;" class="text-right">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in shippingList)
                        {
                            <tr>
                                <td>
                                    <span class="code-pill">S@item.Id</span>
                                </td>
                                <td>
                                    <div class="cell-main">@item.City</div>
                                </td>
                                <td>
                                    <div class="cell-sub">@(string.IsNullOrWhiteSpace(item.District) ? "—" : item.District)</div>
                                </td>
                                <td>
                                    <div class="cell-main">@item.Ward</div>
                                </td>
                                <td>
                                    <span class="price-badge">@item.ShippingCost</span>
                                </td>
                                <td class="text-right">
                                    <div class="action-group">
                                        <a asp-area="Admin"
                                               asp-controller="Shipping"
                                               asp-action="Edit"
                                               asp-route-id="@item.Id"
                                               class="icon-btn icon-edit"
                                               title="Chỉnh sửa">
                                            <i class="fa fa-pencil-square-o"></i>
                                        </a>

                                        <form asp-area="Admin"
                                              asp-controller="Shipping"
                                              asp-action="DeleteShipping"
                                              asp-route-id="@item.Id"
                                              method="post"
                                              class="delete-form"
                                              style="display:inline;">
                                            @Html.AntiForgeryToken()

                                            <button type="submit"
                                                    class="icon-btn icon-delete js-delete"
                                                    data-name="@($"{item.City} - {item.District} - {item.Ward}")"
                                                    title="Xóa">
                                                <i class="fa fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .shipping-page .page-subtitle {
        opacity: .75;
    }

    .card-soft {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.05);
    }

    .form-card,
    .table-card {
        overflow: hidden;
    }

    .card-body-custom {
        padding: 24px;
    }

    .section-title {
        font-size: 20px;
        font-weight: 700;
        color: #111827;
        margin-bottom: 4px;
    }

    .section-subtitle {
        color: #6b7280;
        font-size: 13px;
        margin-bottom: 18px;
    }

    .form-grid {
        margin-left: -10px;
        margin-right: -10px;
    }

    .form-col {
        padding-left: 10px;
        padding-right: 10px;
        margin-bottom: 18px;
    }

    .form-label {
        display: block;
        margin-bottom: 8px;
        font-weight: 700;
        color: #111827;
    }

    .input-soft {
        border-radius: 12px;
        border: 1px solid #d1d5db;
        box-shadow: none;
        min-height: 44px;
        background: #fff;
    }

        .input-soft:focus {
            border-color: #86b7fe;
            box-shadow: 0 0 0 3px rgba(13, 110, 253, .12);
        }

    .form-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .btn-accent {
        background: #111827;
        border: 1px solid #111827;
        color: #fff;
        border-radius: 12px;
        padding: 10px 18px;
        font-weight: 600;
    }

        .btn-accent:hover,
        .btn-accent:focus {
            color: #fff;
            background: #0f172a;
            border-color: #0f172a;
        }

    .btn-outline-secondary {
        border-radius: 12px;
        padding: 10px 18px;
    }

    .table-toolbar {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 16px;
        padding: 22px 22px 0 22px;
        flex-wrap: wrap;
    }

    .toolbar-right {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .search-box {
        position: relative;
        min-width: 260px;
    }

        .search-box .form-control {
            height: 42px;
            border-radius: 12px;
            padding-left: 40px;
            border: 1px solid #d1d5db;
            box-shadow: none;
        }

    .search-icon {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: #6b7280;
        z-index: 2;
    }

    .total-badge {
        display: inline-flex;
        align-items: center;
        border: 1px solid #d1d5db;
        background: #f9fafb;
        color: #374151;
        border-radius: 999px;
        padding: 8px 14px;
        font-size: 13px;
        font-weight: 600;
    }

    .shipping-table {
        margin-bottom: 0;
    }

        .shipping-table thead th {
            background: #f8fafc;
            color: #374151;
            font-weight: 700;
            border-bottom: 1px solid #e5e7eb !important;
            vertical-align: middle !important;
            padding: 14px 12px !important;
        }

        .shipping-table tbody td {
            vertical-align: middle !important;
            padding: 14px 12px !important;
            border-top: 1px solid #eef2f7 !important;
        }

        .shipping-table tbody tr:hover {
            background: #fafafa;
        }

    .code-pill {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 999px;
        background: #111827;
        color: #fff;
        font-size: 12px;
        font-weight: 700;
    }

    .cell-main {
        font-weight: 600;
        color: #111827;
    }

    .cell-sub {
        color: #6b7280;
    }

    .price-badge {
        display: inline-flex;
        align-items: center;
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
        border: 1px solid #dbe3ee;
        background: #f8fafc;
        color: #374151;
    }

    .action-group {
        display: inline-flex;
        justify-content: flex-end;
        gap: 8px;
        flex-wrap: wrap;
    }

    .icon-btn {
        width: 38px;
        height: 38px;
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid #e5e7eb;
        background: #fff;
        text-decoration: none !important;
        transition: all .2s ease;
    }

        .icon-btn:hover {
            background: #f3f4f6;
            border-color: #d1d5db;
        }

    .icon-edit {
        color: #f59e0b;
    }

    .icon-delete {
        color: #ef4444;
    }

    div.dt-container .dt-search {
        display: none;
    }

    div.dt-container .dt-layout-row {
        padding: 12px 16px;
    }

    @@media (max-width: 991px) {
        .table-toolbar {
            padding: 18px 18px 0 18px;
        }
    }

    @@media (max-width: 767px) {
        .card-body-custom {
            padding: 16px;
        }

        .search-box {
            min-width: 100%;
        }

        .toolbar-right {
            width: 100%;
        }

        .table-toolbar {
            flex-direction: column;
            align-items: stretch;
        }
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const API = "/Admin/Shipping";

        function getAntiForgeryToken() {
            return $('input[name="__RequestVerificationToken"]').val();
        }

        $(document).ready(function () {

            $("#quan").closest(".form-col").hide();

            $.getJSON(`${API}/GetProvincesV2`)
                .done(function (provinces) {
                    $("#tinh").html('<option value="0">Tỉnh Thành</option>');
                    (provinces || []).forEach(p => {
                        $("#tinh").append(`<option value="${p.code}">${p.name}</option>`);
                    });
                })
                .fail(function (xhr) {
                    console.error("GetProvincesV2 failed:", xhr.status, xhr.responseText);
                    Swal.fire("Không load được danh sách Tỉnh/TP!");
                });

            $("#tinh").on("change", function () {
                const provinceCode = $(this).val();

                $("#phuong").html('<option value="0">Phường Xã</option>');
                if (provinceCode == "0") return;

                $.getJSON(`${API}/GetWardsByProvinceV2?provinceCode=${provinceCode}`)
                    .done(function (pDetail) {
                        const wards = pDetail?.wards || [];

                        if (!wards.length) {
                            console.warn("No wards returned for province:", provinceCode, pDetail);
                        }

                        wards.forEach(w => {
                            $("#phuong").append(`<option value="${w.code}">${w.name}</option>`);
                        });
                    })
                    .fail(function (xhr) {
                        console.error("GetWardsByProvinceV2 failed:", xhr.status, xhr.responseText);
                        Swal.fire("Không load được danh sách Phường/Xã!");
                    });
            });

            $(".btn-add-shipping").on("click", function () {
                const cityCode = $("#tinh").val();
                const wardCode = $("#phuong").val();

                const cityName = $("#tinh option:selected").text();
                const wardName = $("#phuong option:selected").text();

                const cost = $("#cost").val();

                if (cityCode === "0" || wardCode === "0" || cost === "" || Number(cost) <= 0) {
                    Swal.fire("Vui lòng nhập đầy đủ thông tin hợp lệ!");
                    return;
                }

                $.ajax({
                    url: '@Url.Action("StoreShippingV2", "Shipping", new { area = "Admin" })',
                    type: "POST",
                    headers: {
                        "RequestVerificationToken": getAntiForgeryToken()
                    },
                    data: {
                        cityCode: cityCode,
                        wardCode: wardCode,
                        cityName: cityName,
                        wardName: wardName,
                        cost: cost
                    },
                    success: function (result) {
                        if (result.duplicate) {
                            Swal.fire(result.message);
                            return;
                        }
                        if (result.success) {
                            Swal.fire(result.message).then(() => location.reload());
                            return;
                        }
                        Swal.fire(result.message || "Không xác định được kết quả!");
                    },
                    error: function () {
                        Swal.fire("Đã xảy ra lỗi khi thêm thông tin vận chuyển!");
                    }
                });
            });
        });

        $(document).on("click", ".js-delete", function (e) {
            e.preventDefault();

            const btn = this;
            const form = btn.closest("form");
            const name = btn.getAttribute("data-name") || "";

            const swalWithBootstrapButtons = Swal.mixin({
                customClass: {
                    confirmButton: "btn btn-success",
                    cancelButton: "btn btn-danger"
                },
                buttonsStyling: false
            });

            swalWithBootstrapButtons.fire({
                title: "Are you sure?",
                text: name ? `Bạn chắc chắn muốn xóa "${name}"? Bạn không thể hoàn tác!` : "Bạn không thể hoàn tác!",
                icon: "warning",
                showCancelButton: true,
                confirmButtonText: "Yes, delete it!",
                cancelButtonText: "No, cancel!",
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    form.submit();
                }
            });
        });

        const table = new DataTable('#myTable', {
            layout: {
                topStart: { buttons: ['copy', 'csv', 'excel', 'pdf', 'print'] },
                topEnd: null
            }
        });

        const searchInput = document.getElementById('tableSearch');
        if (searchInput) {
            searchInput.addEventListener('keyup', function () {
                table.search(this.value).draw();
            });
        }

        table.on('draw', function () {
            const info = table.page.info();
            const totalEl = document.getElementById('totalRows');
            if (totalEl) {
                totalEl.textContent = info.recordsDisplay;
            }
        });
    </script>
}