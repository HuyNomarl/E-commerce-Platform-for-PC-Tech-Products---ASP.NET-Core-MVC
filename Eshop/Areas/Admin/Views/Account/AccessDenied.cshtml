@{
    ViewData["Title"] = "Không có quyền truy cập";
    var returnUrl = ViewBag.ReturnUrl as string;
}

<div class="admin-ui-page admin-ui-page--rose">
    <section class="admin-ui-hero">
        <div class="admin-ui-hero__content">
            <span class="admin-ui-hero__eyebrow">Access Control</span>
            <h4>Không có quyền truy cập</h4>
            <p class="admin-ui-hero__desc">
                Tài khoản hiện tại không có quyền mở khu vực này. Bạn có thể quay lại trang chủ, thử lại bằng tài khoản khác hoặc đăng xuất để đăng nhập lại.
            </p>
            <div class="admin-ui-hero__meta">
                <span class="admin-ui-chip">Yêu cầu phân quyền phù hợp</span>
                <span class="admin-ui-chip">Không thay đổi logic auth</span>
            </div>
        </div>
    </section>

    <section class="admin-ui-panel">
        <div class="admin-ui-panel__head">
            <div>
                <div class="admin-ui-panel__title">
                    <i class="fa fa-shield"></i>
                    Truy cập bị từ chối
                </div>
                <div class="admin-ui-panel__subtitle">
                    Liên hệ quản trị viên nếu bạn tin rằng mình cần quyền truy cập vào khu vực này.
                </div>
            </div>
        </div>

        <div class="admin-ui-panel__body">
            <div class="admin-ui-note">
                Hệ thống đã chặn truy cập để đảm bảo an toàn dữ liệu và đúng phạm vi phân quyền của tài khoản.
            </div>

            <div class="admin-ui-form-actions">
                <a class="admin-ui-btn admin-ui-btn--primary" href="/">
                    <i class="fa fa-home"></i>
                    Về trang chủ
                </a>

                @if (!string.IsNullOrEmpty(returnUrl))
                {
                    <a class="admin-ui-btn" href="@returnUrl">
                        <i class="fa fa-rotate-left"></i>
                        Thử lại
                    </a>
                }

                <form asp-controller="Account" asp-action="Logout" asp-area="" method="post" class="admin-ui-inline-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnURL" value="/Account/Login" />
                    <button type="submit" class="admin-ui-btn admin-ui-btn--danger">
                        <i class="fa fa-sign-out"></i>
                        Đăng xuất
                    </button>
                </form>
            </div>
        </div>
    </section>
</div>
