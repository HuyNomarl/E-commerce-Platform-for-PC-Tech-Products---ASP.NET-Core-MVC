@model Eshop.Models.WarehouseModel

@{
    ViewData["Title"] = "Sửa kho";
}

<div class="admin-ui-page admin-ui-page--emerald">
    <section class="admin-ui-hero">
        <div class="admin-ui-hero__content">
            <span class="admin-ui-hero__eyebrow">Warehouse</span>
            <h4>Cập nhật kho</h4>
            <p class="admin-ui-hero__desc">
                Tinh chỉnh nhanh thông tin kho để dữ liệu hiển thị gọn gàng, rõ ràng và đồng bộ với toàn bộ giao diện quản trị.
            </p>
            <div class="admin-ui-hero__meta">
                <span class="admin-ui-chip">Kho #@Model.Id</span>
                <span class="admin-ui-chip">Mã: @Model.Code</span>
                <span class="admin-ui-chip">Không thay đổi logic</span>
            </div>
        </div>

        <a asp-action="Index" class="admin-ui-back">
            <i class="fa fa-arrow-left"></i>
            Quay lại danh sách
        </a>
    </section>

    <section class="admin-ui-panel">
        <div class="admin-ui-panel__head">
            <div>
                <div class="admin-ui-panel__title">
                    <i class="fa fa-pencil-square-o"></i>
                    Chỉnh sửa thông tin kho
                </div>
                <div class="admin-ui-panel__subtitle">
                    Cập nhật tên kho, địa chỉ và trạng thái hiển thị mà không ảnh hưởng đến luồng xử lý dữ liệu hiện tại.
                </div>
            </div>
        </div>

        <div class="admin-ui-panel__body">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="admin-ui-validation"></div>

                <div class="admin-ui-form-grid">
                    <div class="admin-ui-col-6">
                        <label asp-for="Code" class="admin-ui-label">Mã kho</label>
                        <input asp-for="Code" class="admin-ui-control" placeholder="Ví dụ: HCM-01" />
                        <span asp-validation-for="Code" class="text-danger"></span>
                    </div>

                    <div class="admin-ui-col-6">
                        <label asp-for="Name" class="admin-ui-label">Tên kho</label>
                        <input asp-for="Name" class="admin-ui-control" placeholder="Nhập tên kho" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="admin-ui-col-12">
                        <label asp-for="Address" class="admin-ui-label">Địa chỉ</label>
                        <input asp-for="Address" class="admin-ui-control" placeholder="Cập nhật địa chỉ kho" />
                        <span asp-validation-for="Address" class="text-danger"></span>
                    </div>

                    <div class="admin-ui-col-12">
                        <div class="admin-ui-check-grid">
                            <label class="admin-ui-check-card">
                                <input asp-for="IsDefault" class="form-check-input" />
                                <span>
                                    <span class="admin-ui-check-title">Kho mặc định</span>
                                    <span class="admin-ui-check-desc">Giữ tùy chọn này khi kho cần được ưu tiên làm điểm nhận tồn mặc định.</span>
                                </span>
                            </label>

                            <label class="admin-ui-check-card">
                                <input asp-for="IsActive" class="form-check-input" />
                                <span>
                                    <span class="admin-ui-check-title">Kho đang hoạt động</span>
                                    <span class="admin-ui-check-desc">Tắt khi cần ẩn kho khỏi các thao tác tạo mới nhưng vẫn giữ dữ liệu tồn kho hiện có.</span>
                                </span>
                            </label>
                        </div>
                    </div>
                </div>

                <div class="admin-ui-form-actions">
                    <button type="submit" class="admin-ui-btn admin-ui-btn--primary">
                        <i class="fa fa-save"></i>
                        Cập nhật
                    </button>

                    <a asp-action="Index" class="admin-ui-btn">
                        <i class="fa fa-list"></i>
                        Danh sách kho
                    </a>
                </div>
            </form>
        </div>
    </section>
</div>
