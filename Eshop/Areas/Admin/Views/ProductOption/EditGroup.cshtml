@model Eshop.Models.ProductOptionGroupModel

@{
    ViewData["Title"] = "Sửa nhóm tùy chọn";
}

<h3>Sửa nhóm tùy chọn</h3>

<form asp-action="EditGroup" asp-route-id="@Model.Id" method="post">
    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="ProductId" />

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-group mb-3">
        <label asp-for="Name">Tên nhóm</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-check mb-2">
        <input asp-for="IsRequired" class="form-check-input" />
        <label asp-for="IsRequired" class="form-check-label">Bắt buộc phải chọn</label>
    </div>

    <div class="form-check mb-3">
        <input asp-for="AllowMultiple" class="form-check-input" />
        <label asp-for="AllowMultiple" class="form-check-label">Cho chọn nhiều giá trị</label>
    </div>

    <button type="submit" class="btn btn-primary">Cập nhật</button>
    <a asp-action="Index" asp-route-productId="@Model.ProductId" class="btn btn-secondary">Quay lại</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}