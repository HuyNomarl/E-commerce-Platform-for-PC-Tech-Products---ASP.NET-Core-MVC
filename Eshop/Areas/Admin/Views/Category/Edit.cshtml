@model CategoryModel

@{
    ViewData["Title"] = "Edit Category";
}

<div class="row g-3 category-edit-page">
    <div class="col-12">
        <div class="d-flex align-items-start align-items-md-center justify-content-between gap-2 flex-column flex-md-row">
            <div>
                <h4 class="mb-1">Chỉnh sửa danh mục</h4>
                <div class="small page-subtitle">Cập nhật tên, mô tả, danh mục cha và trạng thái hiển thị</div>
            </div>

            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="fa fa-arrow-left me-1"></i> Quay lại
            </a>
        </div>
    </div>

    <div class="col-12 col-xl-8">
        <div class="card-soft form-card">
            <div class="card-body-custom">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row form-grid">
                        <div class="col-xs-12 form-col">
                            <label asp-for="Name" class="form-label">Tên danh mục</label>
                            <input asp-for="Name" class="form-control input-soft" placeholder="Nhập tên danh mục" />
                            <span asp-validation-for="Name" class="text-danger small d-block mt-1"></span>
                        </div>

                        <div class="col-xs-12 form-col">
                            <label asp-for="Description" class="form-label">Mô tả</label>
                            <textarea asp-for="Description"
                                      class="form-control input-soft textarea-soft"
                                      rows="5"
                                      placeholder="Nhập mô tả danh mục"></textarea>
                            <span asp-validation-for="Description" class="text-danger small d-block mt-1"></span>
                        </div>

                        <div class="col-xs-12 col-md-6 form-col">
                            <label asp-for="ParentCategoryId" class="form-label">Danh mục cha</label>
                            <select asp-for="ParentCategoryId" class="form-control input-soft" asp-items="ViewBag.ParentCategories">
                                <option value="">-- Danh mục gốc --</option>
                            </select>
                            <span asp-validation-for="ParentCategoryId" class="text-danger small d-block mt-1"></span>
                        </div>

                        <div class="col-xs-12 col-md-6 form-col">
                            <label asp-for="Status" class="form-label">Trạng thái</label>
                            <select asp-for="Status" class="form-control input-soft">
                                <option value="1">Hiển thị</option>
                                <option value="0">Ẩn</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger small d-block mt-1"></span>
                        </div>
                    </div>

                    <div class="form-actions mt-3">
                        <button type="submit" class="btn btn-accent">
                            <i class="fa fa-floppy-o me-1"></i> Cập nhật
                        </button>

                        <a asp-action="Index" class="btn btn-outline-secondary">
                            Quay lại danh sách
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .category-edit-page .page-subtitle {
        opacity: .75;
    }

    .card-soft {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.05);
    }

    .form-card {
        overflow: hidden;
    }

    .card-body-custom {
        padding: 24px;
    }

    .form-grid {
        margin-left: -10px;
        margin-right: -10px;
    }

    .form-col {
        padding-left: 10px;
        padding-right: 10px;
        margin-bottom: 20px;
    }

    .form-label {
        display: block;
        margin-bottom: 8px;
        font-weight: 700;
        color: #111827;
    }

    .input-soft {
        border-radius: 12px;
        border: 1px solid #d1d5db;
        box-shadow: none;
        min-height: 44px;
        background: #fff;
    }

        .input-soft:focus {
            border-color: #86b7fe;
            box-shadow: 0 0 0 3px rgba(13, 110, 253, .12);
        }

    .textarea-soft {
        min-height: 120px;
        resize: vertical;
    }

    .form-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .btn-accent {
        background: #111827;
        border: 1px solid #111827;
        color: #fff;
        border-radius: 12px;
        padding: 10px 18px;
        font-weight: 600;
    }

        .btn-accent:hover,
        .btn-accent:focus {
            color: #fff;
            background: #0f172a;
            border-color: #0f172a;
        }

    .btn-outline-secondary {
        border-radius: 12px;
        padding: 10px 18px;
    }

    .text-danger.small {
        font-size: 12px;
    }

    @@media (max-width: 767px) {
        .card-body-custom {
            padding: 16px;
        }
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}