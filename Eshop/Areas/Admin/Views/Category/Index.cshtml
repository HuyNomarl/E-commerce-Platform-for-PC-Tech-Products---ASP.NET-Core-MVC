@model IEnumerable<Eshop.Models.CategoryModel>
@{
    ViewData["title"] = "Category Index";

    Paginate pager = new Paginate();
    int pageNo = 0;
    if (ViewBag.Pager != null)
    {
        pager = ViewBag.Pager;
        pageNo = pager.CurrentPage;
    }

}

<h3>Category Index View</h3>
<a asp-area="Admin" asp-action="Create" asp-controller="Category">Add Category</a>
<table class="table">
    <thead>
        <tr>
            <th scope="col">Id</th>
            <th scope="col">Category Name</th>
            <th scope="col">Category Description</th>
            <th scope="col">Category Slug</th>
            <th scope="col">Status</th>
        </tr>
    </thead>
    <tbody>

        @foreach (var item in Model)
        {
            <tr>
                <th scope="row">@item.Id</th>
                <td>@item.Name</td>
                <td>@item.Description</td>
                <td>@item.Slug</td>
                <td>
                    @if (item.Status == 1)
                    {
                        <span>Hiển thị</span>
                    }
                    else
                    {
                        <span>Ẩn</span>
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-controller="Category" asp-route-id="@item.Id" class="btn btn-primary">Edit</a>
                    <a asp-action="Delete" asp-controller="Category" asp-route-id="@item.Id" class="btn btn-primary confirmDeletion">Delete</a>
                </td>
            </tr>

        }
    </tbody>
</table>
<partial name="../Shared/_Paging" model="pager" />
