@model ProductQuantityModel
@using System.Linq

@{
    ViewData["Title"] = "Create Quantity";
    var key = 1;

    // tránh null ViewBag
    var logs = ViewBag.ProductQuantityLogs as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    var totalQuantities = logs.Sum(x => (int)x.Quantity);
}

<h4>Create Quantity</h4>

<form asp-area="Admin"
      asp-controller="Product"
      asp-action="StoreProductQuantity"
      asp-route-id="@ViewBag.Id"
      method="post">
    @Html.AntiForgeryToken()

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <label asp-for="Quantity"></label>
    <input asp-for="Quantity" type="number" min="1" step="1" class="form-control" />
    <span asp-validation-for="Quantity" class="text-danger"></span>

    <button type="submit" class="btn btn-primary">Create</button>
</form>

<h3>Existing Product Quantities:</h3>

@if (!logs.Any())
{
    <div class="text-muted">No quantity logs yet.</div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>#</th>
                <th>Quantity</th>
                <th>Created At</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var qty in logs)
            {
                <tr>
                    <td>@key</td>
                    <td>@qty.Quantity</td>
                    <td>@qty.DateCreate.ToString("g")</td>
                </tr>
                key++;
            }
        </tbody>
        <tfoot>
            <tr>
                <th colspan="1">Total</th>
                <th>@totalQuantities</th>
                <th></th>
            </tr>
        </tfoot>
    </table>
}

<a asp-area="Admin" asp-controller="Product" asp-action="Index">Back to Product Index</a>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
