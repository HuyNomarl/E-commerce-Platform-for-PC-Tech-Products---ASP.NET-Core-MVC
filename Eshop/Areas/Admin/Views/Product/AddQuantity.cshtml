@model ProductQuantityModel
@{
    ViewData["Title"] = "Create Quantity";
}
<h4>Create Quantity</h4>
<div>
    <form asp-area="Admin"
          asp-controller="Product"
          asp-action="StoreProductQuantity"
          asp-route-id="@ViewBag.Id"
          method="post">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label>Quantity</label>
            <input min="1" value="1" asp-for="Quantity" class="form-control" />
            <span asp-validation-for="Quantity" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary">Create</button>
    </form>

    <a asp-action="Index" asp-controller="Product">Back to Product Index</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}