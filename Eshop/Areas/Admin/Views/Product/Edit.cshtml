@model Eshop.Models.ViewModels.ProductUpsertViewModel

@{
    ViewData["Title"] = "Sửa sản phẩm";
    var hasProductImages = Model.Product.ProductImages != null && Model.Product.ProductImages.Any();
}

<div class="admin-ui-page admin-ui-page--blue">
    <section class="admin-ui-hero">
        <div class="admin-ui-hero__content">
            <span class="admin-ui-hero__eyebrow">Products</span>
            <h4>Sửa sản phẩm</h4>
            <p class="admin-ui-hero__desc">
                Cập nhật thông tin, ảnh sản phẩm và tài liệu kỹ thuật trong một bố cục nhất quán hơn để rà soát nhanh hơn trước khi lưu.
            </p>
            <div class="admin-ui-hero__meta">
                <span class="admin-ui-chip">Thông tin và media cùng một form</span>
                <span class="admin-ui-chip">@(hasProductImages ? "Đã có thư viện ảnh" : "Chưa có ảnh phụ")</span>
                <span class="admin-ui-chip">Không đổi logic cập nhật</span>
            </div>
        </div>

        <a asp-action="Index" class="admin-ui-back">
            <i class="fa fa-arrow-left"></i>
            Quay lại danh sách
        </a>
    </section>

    <div class="row g-3 product-edit-page">
    <div class="col-12">
        <div class="d-flex align-items-start align-items-md-center justify-content-between gap-2 flex-column flex-md-row">
            <div>
                <h4 class="mb-1">Sửa sản phẩm</h4>
                <div class="small page-subtitle">Cập nhật thông tin, ảnh sản phẩm và tài liệu kỹ thuật</div>
            </div>

            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="fa fa-arrow-left me-1"></i> Quay lại
            </a>
        </div>
    </div>

    <form asp-action="Edit"
          asp-route-id="@Model.Product.Id"
          method="post"
          enctype="multipart/form-data"
          class="col-12">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="Product.Id" />
        <input type="hidden" asp-for="Product.Image" />
        <input type="hidden" asp-for="Product.Slug" />

        <input asp-for="PrimaryImageSource" type="hidden" id="PrimaryImageSource" />
        <input asp-for="PrimaryExistingImageId" type="hidden" id="PrimaryExistingImageId" />
        <input asp-for="PrimaryNewImageIndex" type="hidden" id="PrimaryNewImageIndex" />
        <input asp-for="DeleteLegacyImage" type="hidden" id="DeleteLegacyImage" />
        <input asp-for="WidgetImagesJson" type="hidden" id="WidgetImagesJson" />

        <div id="deleted-image-ids-box"></div>

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-3">
            <div class="col-12 col-xl-8">
                <div class="card-soft form-card mb-3">
                    <div class="card-body-custom">
                        <div class="section-heading mb-3">Thông tin chung</div>

                        <div class="row form-grid">
                            <div class="col-12 col-md-8 form-col">
                                <label asp-for="Product.Name" class="form-label">Tên sản phẩm</label>
                                <input asp-for="Product.Name" class="form-control input-soft" placeholder="Nhập tên sản phẩm" />
                                <span asp-validation-for="Product.Name" class="text-danger small d-block mt-1"></span>
                            </div>

                            <div class="col-12 col-md-4 form-col">
                                <label asp-for="Product.Price" class="form-label">Giá</label>
                                <input asp-for="Product.Price" class="form-control input-soft" placeholder="Nhập giá sản phẩm" />
                                <span asp-validation-for="Product.Price" class="text-danger small d-block mt-1"></span>
                            </div>

                            <div class="col-12 form-col">
                                <label asp-for="Product.Description" class="form-label">Mô tả</label>
                                <textarea asp-for="Product.Description"
                                          rows="5"
                                          class="form-control input-soft textarea-soft"
                                          placeholder="Nhập mô tả sản phẩm"></textarea>
                                <span asp-validation-for="Product.Description" class="text-danger small d-block mt-1"></span>
                            </div>

                            <div class="col-12 col-md-6 form-col">
                                <label asp-for="Product.CategoryId" class="form-label">Danh mục sản phẩm</label>
                                <select asp-for="Product.CategoryId" class="form-select input-soft" asp-items="ViewBag.Categories">
                                    <option value="">-- Chọn danh mục --</option>
                                </select>
                                <span asp-validation-for="Product.CategoryId" class="text-danger small d-block mt-1"></span>
                            </div>

                            <div class="col-12 col-md-6 form-col">
                                <label asp-for="Product.PublisherId" class="form-label">Thương hiệu</label>
                                <select asp-for="Product.PublisherId" class="form-select input-soft" asp-items="ViewBag.Publishers">
                                    <option value="">-- Chọn thương hiệu --</option>
                                </select>
                                <span asp-validation-for="Product.PublisherId" class="text-danger small d-block mt-1"></span>
                            </div>

                            <div class="col-12 col-md-6 form-col">
                                <label asp-for="Product.Status" class="form-label">Trạng thái hiển thị</label>
                                <select asp-for="Product.Status" class="form-select input-soft">
                                    <option value="1">Hiển thị</option>
                                    <option value="0">Ẩn tạm</option>
                                </select>
                                <span asp-validation-for="Product.Status" class="text-danger small d-block mt-1"></span>
                            </div>

                            <div class="col-12 form-col">
                                <label asp-for="Product.IsPcBuild" class="form-label">Loại sản phẩm</label>

                                <div class="feature-box">
                                    <div class="checkbox-wrap">
                                        <input asp-for="Product.IsPcBuild" class="form-check-input-custom" />
                                        <label asp-for="Product.IsPcBuild" class="form-check-label-custom mb-0">
                                            Đây là PC có cấu hình nâng cấp
                                        </label>
                                    </div>
                                    <div class="small helper-text mt-2">
                                        Bật tùy chọn này nếu sản phẩm là bộ PC có thể nâng cấp cấu hình.
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-soft form-card mb-3">
                    <div class="card-body-custom">
                        <div class="section-heading mb-3">Ảnh sản phẩm</div>

                        <div class="d-flex gap-2 flex-wrap mb-2">
                            <button type="button" class="btn btn-outline-primary" id="btnAddEditImages">
                                <i class="fa fa-image me-1"></i> Thêm ảnh mới
                            </button>
                        </div>

                        <span asp-validation-for="WidgetImagesJson" class="text-danger small d-block mt-1"></span>

                        <div class="small helper-text mt-2">
                            Ảnh bị xóa ở đây chỉ mờ đi. Chỉ khi bấm <strong>Lưu thay đổi</strong> thì mới xóa thật.
                        </div>

                        <div id="edit-image-list" class="image-row mt-3"></div>

                        <div id="existing-image-source" class="d-none">
                            @if (hasProductImages)
                            {
                                foreach (var img in Model.Product.ProductImages.OrderBy(x => x.SortOrder))
                                {
                                    <div class="js-existing-image"
                                         data-key="e-@img.Id"
                                         data-id="@img.Id"
                                         data-url="@img.Url"
                                         data-legacy="false"></div>
                                }
                            }
                            else if (!string.IsNullOrWhiteSpace(Model.Product.Image))
                            {
                                <div class="js-existing-image"
                                     data-key="legacy"
                                     data-id=""
                                     data-url="@Model.Product.Image"
                                     data-legacy="true"></div>
                            }
                        </div>
                    </div>
                </div>

                <div class="card-soft form-card">
                    <div class="card-body-custom">
                        <div class="section-heading mb-3">Tài liệu kỹ thuật</div>

                        <div class="form-col p-0 mb-3">
                            <label class="form-label">Tài liệu kỹ thuật hiện tại</label>

                            @if (Model.Product.TechnicalAsset != null)
                            {
                                <div class="technical-file-box">
                                    <div class="technical-file-title">Đã có tài liệu kỹ thuật</div>
                                    <div class="technical-file-note">
                                        Bạn có thể mở tài liệu hiện tại hoặc tải file mới để thay thế.
                                    </div>
                                    <div class="mt-3">
                                        <a href="@Model.Product.TechnicalAsset.Url" target="_blank" class="btn btn-outline-primary">
                                            Xem tài liệu hiện tại
                                        </a>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="technical-empty">
                                    Chưa có tài liệu kỹ thuật cho sản phẩm này.
                                </div>
                            }
                        </div>

                        <div class="form-col p-0 mb-0">
                            <label asp-for="TechnicalFileUpload" class="form-label">Thay file / ảnh thông số kỹ thuật</label>
                            <input asp-for="TechnicalFileUpload"
                                   type="file"
                                   class="form-control input-soft"
                                   accept=".jpg,.jpeg,.png,.pdf,.doc,.docx,.xls,.xlsx" />
                            <span asp-validation-for="TechnicalFileUpload" class="text-danger small d-block mt-1"></span>
                            <div class="small helper-text mt-2">
                                Hỗ trợ ảnh, PDF, Word và Excel cho tài liệu kỹ thuật.
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-4">
                <div class="card-soft form-card sticky-action-card">
                    <div class="card-body-custom">
                        <div class="section-heading mb-3">Thao tác</div>

                        <div class="action-box">
                            <button type="submit" class="btn btn-accent w-100">
                                <i class="fa fa-save me-1"></i> Lưu thay đổi
                            </button>

                            <a asp-action="Index" class="btn btn-outline-secondary w-100">
                                Quay lại danh sách
                            </a>
                        </div>

                        <div class="action-note mt-3">
                            Hãy kiểm tra lại thông tin, ảnh đại diện và tài liệu kỹ thuật trước khi lưu.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>
</div>

<style>
    .product-edit-page .page-subtitle {
        opacity: .75;
    }

    .card-soft {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.05);
    }

    .form-card {
        overflow: hidden;
    }

    .card-body-custom {
        padding: 24px;
    }

    .section-heading {
        font-size: 16px;
        font-weight: 700;
        color: #111827;
        padding-bottom: 10px;
        border-bottom: 1px solid #eef2f7;
    }

    .form-grid {
        margin-left: -10px;
        margin-right: -10px;
    }

    .form-col {
        padding-left: 10px;
        padding-right: 10px;
        margin-bottom: 20px;
    }

    .form-label {
        display: block;
        margin-bottom: 8px;
        font-weight: 700;
        color: #111827;
    }

    .input-soft {
        border-radius: 12px;
        border: 1px solid #d1d5db;
        box-shadow: none;
        min-height: 44px;
        background: #fff;
    }

        .input-soft:focus {
            border-color: #86b7fe;
            box-shadow: 0 0 0 3px rgba(13, 110, 253, .12);
        }

    .textarea-soft {
        min-height: 120px;
        resize: vertical;
    }

    .helper-text {
        color: #6b7280;
    }

    .text-danger.small {
        font-size: 12px;
    }

    .btn-accent {
        background: #111827;
        border: 1px solid #111827;
        color: #fff;
        border-radius: 12px;
        padding: 10px 18px;
        font-weight: 600;
    }

        .btn-accent:hover,
        .btn-accent:focus {
            color: #fff;
            background: #0f172a;
            border-color: #0f172a;
        }

    .btn-outline-secondary,
    .btn-outline-primary {
        border-radius: 12px;
        padding: 10px 18px;
    }

    .action-box {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .action-note {
        font-size: 13px;
        color: #6b7280;
        line-height: 1.6;
    }

    .sticky-action-card {
        position: sticky;
        top: 20px;
    }

    .feature-box {
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        background: #f8fafc;
        padding: 14px 16px;
    }

    .checkbox-wrap {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .form-check-input-custom {
        width: 18px;
        height: 18px;
        margin-top: 0;
        accent-color: #111827;
    }

    .form-check-label-custom {
        font-weight: 600;
        color: #111827;
        cursor: pointer;
    }

    .technical-file-box {
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 16px;
        background: #fff;
    }

    .technical-file-title {
        font-size: 14px;
        font-weight: 700;
        color: #111827;
    }

    .technical-file-note {
        margin-top: 6px;
        font-size: 13px;
        color: #6b7280;
        line-height: 1.6;
    }

    .technical-empty {
        padding: 16px;
        border: 1px dashed #ced4da;
        border-radius: 12px;
        color: #6c757d;
        background: #fafafa;
    }

    .image-row {
        display: flex;
        flex-wrap: nowrap;
        gap: 16px;
        overflow-x: auto;
        padding-bottom: 8px;
    }

    .image-card {
        min-width: 220px;
        max-width: 220px;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        background: #fff;
        padding: 12px;
        flex: 0 0 auto;
        transition: .2s ease;
        box-shadow: 0 4px 16px rgba(15, 23, 42, 0.04);
    }

        .image-card.is-deleted {
            opacity: .45;
            filter: grayscale(1);
        }

    .image-thumb-wrap {
        width: 100%;
        height: 180px;
        border-radius: 12px;
        overflow: hidden;
        background: #f8f9fa;
        border: 1px solid #edf0f2;
    }

    .image-thumb {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .image-meta {
        margin-top: 10px;
    }

    .image-title {
        font-weight: 600;
        font-size: 14px;
        margin-bottom: 4px;
        color: #111827;
    }

    .image-note {
        font-size: 12px;
        color: #6c757d;
        min-height: 18px;
        line-height: 1.5;
    }

    .image-actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
        margin-top: 10px;
    }

    .image-empty {
        padding: 16px;
        border: 1px dashed #ced4da;
        border-radius: 12px;
        color: #6c757d;
        background: #fafafa;
        min-width: 320px;
    }

    @@media (max-width: 1199px) {
        .sticky-action-card {
            position: static;
            top: unset;
        }
    }

    @@media (max-width: 767px) {
        .card-body-custom {
            padding: 16px;
        }

        .checkbox-wrap {
            align-items: flex-start;
        }

        .image-card {
            min-width: 200px;
            max-width: 200px;
        }

        .image-empty {
            min-width: 260px;
        }
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="https://upload-widget.cloudinary.com/latest/global/all.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
        const list = document.getElementById("edit-image-list");
        const btnAdd = document.getElementById("btnAddEditImages");

        const primarySourceInput = document.getElementById("PrimaryImageSource");
        const primaryExistingIdInput = document.getElementById("PrimaryExistingImageId");
        const primaryNewImageIndexInput = document.getElementById("PrimaryNewImageIndex");
        const deleteLegacyImageInput = document.getElementById("DeleteLegacyImage");
        const deletedIdsBox = document.getElementById("deleted-image-ids-box");
        const widgetImagesInput = document.getElementById("WidgetImagesJson");

        const existingImages = Array.from(document.querySelectorAll(".js-existing-image")).map(el => ({
        key: el.dataset.key,
        id: el.dataset.id ? Number(el.dataset.id) : null,
        url: el.dataset.url,
        isLegacy: el.dataset.legacy === "true"
        }));

        let newImages = [];
        let deletedExistingIds = new Set();
        let deleteLegacy = false;
        let replacementMap = new Map();
        let replaceContext = null;
        let primary = null;

        function uid() {
        if (window.crypto && crypto.randomUUID) return crypto.randomUUID();
        return "img_" + Date.now() + "_" + Math.random().toString(36).substring(2, 10);
        }

        function getExistingByKey(key) {
        return existingImages.find(x => x.key === key);
        }

        function getExistingDeleted(item) {
        return item.isLegacy ? deleteLegacy : deletedExistingIds.has(item.id);
        }

        function getExistingReplaced(item) {
        return replacementMap.has(item.key);
        }

        function getSelectableItems() {
        const result = [];

        existingImages.forEach(item => {
        if (!getExistingDeleted(item) && !getExistingReplaced(item)) {
        result.push({
        type: item.isLegacy ? "legacy" : "existing",
        key: item.key,
        existingId: item.id
        });
        }
        });

        newImages.forEach(item => {
        result.push({
        type: "new",
        key: item.tempId
        });
        });

        return result;
        }

        function ensurePrimary() {
        const selectable = getSelectableItems();

        if (!selectable.length) {
        primary = null;
        return;
        }

        const valid = primary && selectable.some(x => x.type === primary.type && x.key === primary.key);
        if (!valid) {
        primary = {
        type: selectable[0].type,
        key: selectable[0].key
        };
        }
        }

        function syncHiddenFields() {
        deletedIdsBox.innerHTML = "";

        Array.from(deletedExistingIds).forEach(id => {
        deletedIdsBox.insertAdjacentHTML(
        "beforeend",
        `<input type="hidden" name="DeletedImageIds" value="${id}" />`
        );
        });

        widgetImagesInput.value = JSON.stringify(
        newImages.map(x => ({
        tempId: x.tempId,
        publicId: x.publicId,
        url: x.url,
        resourceType: x.resourceType,
        originalFileName: x.originalFileName,
        replacedExistingKey: x.replacedExistingKey
        }))
        );

        deleteLegacyImageInput.value = deleteLegacy ? "true" : "false";

        ensurePrimary();

        primarySourceInput.value = "";
        primaryExistingIdInput.value = "";
        primaryNewImageIndexInput.value = "";

        if (!primary) return;

        if (primary.type === "existing") {
        const current = getExistingByKey(primary.key);
        primarySourceInput.value = "existing";
        primaryExistingIdInput.value = current && current.id ? current.id : "";
        }
        else if (primary.type === "legacy") {
        primarySourceInput.value = "legacy";
        }
        else if (primary.type === "new") {
        const idx = newImages.findIndex(x => x.tempId === primary.key);
        primarySourceInput.value = "new";
        primaryNewImageIndexInput.value = idx >= 0 ? idx : "";
        }
        }

        function addUploadedImage(uploaded) {
        newImages.push({
        tempId: uid(),
        publicId: uploaded.publicId,
        url: uploaded.url,
        resourceType: uploaded.resourceType,
        originalFileName: uploaded.originalFileName,
        replacedExistingKey: null
        });

        if (!primary && newImages.length) {
        primary = { type: "new", key: newImages[0].tempId };
        }

        render();
        }

        function updateNewImage(tempId, uploaded) {
        const item = newImages.find(x => x.tempId === tempId);
        if (!item) return;

        item.publicId = uploaded.publicId;
        item.url = uploaded.url;
        item.resourceType = uploaded.resourceType;
        item.originalFileName = uploaded.originalFileName;

        render();
        }

        function removeNewImage(tempId) {
        const index = newImages.findIndex(x => x.tempId === tempId);
        if (index === -1) return;

        const item = newImages[index];

        if (item.replacedExistingKey) {
        replacementMap.delete(item.replacedExistingKey);

        const oldItem = getExistingByKey(item.replacedExistingKey);
        if (oldItem) {
        if (oldItem.isLegacy) {
        deleteLegacy = false;
        } else if (oldItem.id) {
        deletedExistingIds.delete(oldItem.id);
        }
        }
        }

        newImages.splice(index, 1);

        if (primary && primary.type === "new" && primary.key === tempId) {
        primary = null;
        }

        render();
        }

        function replaceExistingImage(existingKey, uploaded) {
        const oldItem = getExistingByKey(existingKey);
        if (!oldItem) return;

        const currentReplacementId = replacementMap.get(existingKey);

        if (currentReplacementId) {
        updateNewImage(currentReplacementId, uploaded);

        if (primary && (primary.type === "existing" || primary.type === "legacy") && primary.key === existingKey) {
        primary = { type: "new", key: currentReplacementId };
        }

        return;
        }

        const tempId = uid();

        newImages.push({
        tempId: tempId,
        publicId: uploaded.publicId,
        url: uploaded.url,
        resourceType: uploaded.resourceType,
        originalFileName: uploaded.originalFileName,
        replacedExistingKey: existingKey
        });

        replacementMap.set(existingKey, tempId);

        if (oldItem.isLegacy) {
        deleteLegacy = true;
        } else if (oldItem.id) {
        deletedExistingIds.add(oldItem.id);
        }

        if (primary && (primary.type === "existing" || primary.type === "legacy") && primary.key === existingKey) {
        primary = { type: "new", key: tempId };
        } else if (!primary) {
        primary = { type: "new", key: tempId };
        }

        render();
        }

        function toggleExistingDelete(existingKey) {
        const item = getExistingByKey(existingKey);
        if (!item) return;

        if (getExistingReplaced(item)) {
        const replacementId = replacementMap.get(existingKey);
        if (replacementId) {
        removeNewImage(replacementId);
        }
        return;
        }

        if (item.isLegacy) {
        deleteLegacy = !deleteLegacy;
        } else if (item.id) {
        if (deletedExistingIds.has(item.id)) {
        deletedExistingIds.delete(item.id);
        } else {
        deletedExistingIds.add(item.id);
        }
        }

        if (primary && primary.key === existingKey) {
        primary = null;
        }

        render();
        }

        function render() {
        syncHiddenFields();

        const cards = [];

        existingImages.forEach((item, index) => {
        const isDeleted = getExistingDeleted(item);
        const isReplaced = getExistingReplaced(item);
        const canSelectPrimary = !isDeleted && !isReplaced;

        let note = "Ảnh hiện tại";
        if (item.isLegacy) note = "Ảnh hiện tại (kiểu cũ)";
        if (isDeleted) note = "Sẽ xóa khi lưu";
        if (isReplaced) note = "Ảnh cũ sẽ bị thay khi lưu";

        cards.push(`
        <div class="image-card ${!canSelectPrimary ? "is-deleted" : ""}">
        <div class="image-thumb-wrap">
        <img src="${item.url}" class="image-thumb" alt="existing-${index}" />
        </div>

        <div class="image-meta">
        <div class="image-title">Ảnh hiện tại ${index + 1}</div>
        <div class="image-note">${note}</div>

        <div class="form-check mt-2">
        <input class="form-check-input js-edit-primary"
        type="radio"
        name="editPrimaryPreview"
        data-type="${item.isLegacy ? "legacy" : "existing"}"
        data-key="${item.key}"
        ${primary && primary.key === item.key && primary.type === (item.isLegacy ? "legacy" : "existing") ? "checked" : ""}
        ${canSelectPrimary ? "" : "disabled"}>
        <label class="form-check-label">Đặt làm ảnh đại diện</label>
        </div>

        <div class="image-actions">
        <button type="button"
        class="btn btn-sm ${canSelectPrimary ? "btn-outline-danger" : "btn-outline-secondary"} js-existing-toggle-delete"
        data-key="${item.key}">
        ${canSelectPrimary ? "Xóa" : "Hoàn tác"}
        </button>

        <button type="button"
        class="btn btn-outline-secondary btn-sm js-existing-replace"
        data-key="${item.key}">
        ${isReplaced ? "Thay ảnh khác" : "Thay ảnh"}
        </button>
        </div>
        </div>
        </div>
        `);
        });

        newImages.forEach((item, index) => {
        const isReplacement = !!item.replacedExistingKey;
        let title = `Ảnh mới ${index + 1}`;
        let note = "Ảnh sẽ được thêm khi lưu";

        if (isReplacement) {
        const target = getExistingByKey(item.replacedExistingKey);
        title = "Ảnh thay thế";
        note = target && target.isLegacy
        ? "Ảnh này sẽ thay cho ảnh cũ"
        : `Ảnh này sẽ thay cho ảnh ID ${target?.id ?? ""}`;
        }

        cards.push(`
        <div class="image-card">
        <div class="image-thumb-wrap">
        <img src="${item.url}" class="image-thumb" alt="new-${index}" />
        </div>

        <div class="image-meta">
        <div class="image-title">${title}</div>
        <div class="image-note">${note}</div>

        <div class="form-check mt-2">
        <input class="form-check-input js-edit-primary"
        type="radio"
        name="editPrimaryPreview"
        data-type="new"
        data-key="${item.tempId}"
        ${primary && primary.type === "new" && primary.key === item.tempId ? "checked" : ""}>
        <label class="form-check-label">Đặt làm ảnh đại diện</label>
        </div>

        <div class="image-actions">
        <button type="button"
        class="btn btn-outline-danger btn-sm js-new-delete"
        data-id="${item.tempId}">
        Xóa
        </button>

        <button type="button"
        class="btn btn-outline-secondary btn-sm js-new-replace"
        data-id="${item.tempId}">
        Thay ảnh
        </button>
        </div>
        </div>
        </div>
        `);
        });

        list.innerHTML = cards.length
        ? cards.join("")
        : `<div class="image-empty">Chưa có ảnh nào. Bấm <strong>Thêm ảnh mới</strong> để mở Cloudinary Widget.</div>`;
        }

        function openCloudinaryWidget(isMultiple, onUploaded) {
        if (!window.cloudinary) {
        console.error("Cloudinary widget chưa load.");
        return;
        }

        const widget = cloudinary.createUploadWidget(
        {
        cloudName: "dd120zgwr",
        uploadPreset: "ml_default",
        multiple: isMultiple,
        maxFiles: isMultiple ? 20 : 1,
        resourceType: "image",
        clientAllowedFormats: ["jpg", "jpeg", "png", "webp"],
        sources: ["url", "camera", "google_drive", "dropbox", "local"],
        defaultSource: "url"
        },
        function (error, result) {
        if (error) {
        console.error(error);
        return;
        }

        if (result && result.event === "success") {
        const uploaded = {
        publicId: result.info.public_id,
        url: result.info.secure_url,
        resourceType: result.info.resource_type || "image",
        originalFileName: result.info.original_filename || ""
        };

        onUploaded(uploaded);
        }
        }
        );

        widget.open();
        }

        btnAdd.addEventListener("click", function () {
        replaceContext = null;

        openCloudinaryWidget(true, function (uploaded) {
        addUploadedImage(uploaded);
        });
        });

        list.addEventListener("click", function (e) {
        const existingDeleteBtn = e.target.closest(".js-existing-toggle-delete");
        const existingReplaceBtn = e.target.closest(".js-existing-replace");
        const newDeleteBtn = e.target.closest(".js-new-delete");
        const newReplaceBtn = e.target.closest(".js-new-replace");

        if (existingDeleteBtn) {
        toggleExistingDelete(existingDeleteBtn.dataset.key);
        return;
        }

        if (existingReplaceBtn) {
        replaceContext = {
        mode: "existing",
        key: existingReplaceBtn.dataset.key
        };

        openCloudinaryWidget(false, function (uploaded) {
        if (!replaceContext) return;

        if (replaceContext.mode === "existing") {
        replaceExistingImage(replaceContext.key, uploaded);
        }

        replaceContext = null;
        });

        return;
        }

        if (newDeleteBtn) {
        removeNewImage(newDeleteBtn.dataset.id);
        return;
        }

        if (newReplaceBtn) {
        replaceContext = {
        mode: "new",
        key: newReplaceBtn.dataset.id
        };

        openCloudinaryWidget(false, function (uploaded) {
        if (!replaceContext) return;

        if (replaceContext.mode === "new") {
        updateNewImage(replaceContext.key, uploaded);
        }

        replaceContext = null;
        });
        }
        });

        list.addEventListener("change", function (e) {
        if (e.target.classList.contains("js-edit-primary")) {
        primary = {
        type: e.target.dataset.type,
        key: e.target.dataset.key
        };
        render();
        }
        });

        if (existingImages.length) {
        const first = existingImages[0];
        primary = {
        type: first.isLegacy ? "legacy" : "existing",
        key: first.key
        };
        }

        render();
        });
    </script>
}
