@model IEnumerable<Eshop.Models.ProductModel>
@{
    ViewData["title"] = "Product Index";
}

<h3>Product Index View</h3>
<a asp-area="Admin" asp-action="Create" asp-controller="Product">Add Product</a>

<table class="table" id="myTable">
    <thead>
        <tr>
            <th scope="col">Id</th>
            <th scope="col">Product Name</th>
            <th scope="col">Product Quantity</th>
            <th scope="col">Product Sold</th>
            <th scope="col">Product Description</th>
            <th scope="col">Product Price</th>
            <th scope="col">Product Image</th>
            <th scope="col">Product Slug</th>
            <th scope="col">Product Category</th>
            <th scope="col">Product Brand</th>
            <th scope="col">Actions</th>
        </tr>
    </thead>
    <tbody>

        @foreach (var item in Model)
        {
            <tr>
                <th scope="row">@item.Id</th>
                <td>@item.Name</td>
                <td><b>@item.Quantity</b><a asp-controller="Product" asp-action="AddQuantity" asp-route-id="@item.Id">Add Quantity</a></td>
                <td>@item.Sold</td>
                <td>@item.Description</td>
                <td>@item.Price</td>
                <td><img src="~/media/products/@item.Image" width="100" height="80" /></td>
                <td>@item.Slug</td>
                <td>@item.Category.Name</td>
                <td>@item.Publisher.Name</td>
                <td>
                    <a asp-action="Edit" asp-controller="Product" asp-route-id="@item.Id" class="btn btn-primary">Edit</a>
                    <a asp-area="Admin"
                           asp-controller="ProductOption"
                           asp-action="Index"
                           asp-route-productId="@item.Id"
                           class="btn btn-info btn-sm">
                        Option
                    </a>
                    <a asp-action="Delete" asp-controller="Product" asp-route-id="@item.Id" class="btn btn-primary confirmDeletion">Delete</a>
                </td>
            </tr>
        
        }


    </tbody>
</table>
@section Scripts {
    <script>
        new DataTable('#myTable', {
          layout: {
            topStart: { buttons: ['copy', 'csv', 'excel', 'pdf', 'print'] }
          }
        });
    </script>
}
