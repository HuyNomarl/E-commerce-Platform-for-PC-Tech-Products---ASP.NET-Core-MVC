@using System.Globalization
@model IEnumerable<Eshop.Models.ProductModel>
@using Eshop.Helpers
@using Eshop.Models.Enums

@{
    ViewData["Title"] = "Product Index";

    var productList = Model?.ToList() ?? new List<Eshop.Models.ProductModel>();

    var categories = productList
        .Where(x => x.Category != null && !string.IsNullOrWhiteSpace(x.Category.Name))
        .Select(x => x.Category!.Name)
        .Distinct()
        .OrderBy(x => x)
        .ToList();

    var publishers = productList
        .Where(x => x.Publisher != null && !string.IsNullOrWhiteSpace(x.Publisher.Name))
        .Select(x => x.Publisher!.Name)
        .Distinct()
        .OrderBy(x => x)
        .ToList();

    var productTypes = productList
        .Select(x => ProductCatalogAdminRules.GetAdminProductTypeLabel(x.ProductType))
        .Distinct()
        .OrderBy(x => x)
        .ToList();

    var normalCount = productList.Count(x => x.ProductType == ProductType.Normal);
    var prebuiltCount = productList.Count(x => x.ProductType == ProductType.PcPrebuilt);
}

<div class="admin-ui-page admin-ui-page--blue">
    <section class="admin-ui-hero">
        <div class="admin-ui-hero__content">
            <span class="admin-ui-hero__eyebrow">Products</span>
            <h4>Quản lý sản phẩm</h4>
            <p class="admin-ui-hero__desc">
                Theo dõi danh mục sản phẩm, thương hiệu, mức giá và tình trạng tồn kho trong cùng một bố cục gọn hơn để vận hành nhanh hơn.
            </p>
            <div class="admin-ui-hero__meta">
                <span class="admin-ui-chip">@productList.Count sản phẩm</span>
                <span class="admin-ui-chip">@normalCount sản phẩm thường</span>
                <span class="admin-ui-chip">@prebuiltCount PC dựng sẵn</span>
                <span class="admin-ui-chip">@categories.Count danh mục</span>
                <span class="admin-ui-chip">@publishers.Count thương hiệu</span>
            </div>
        </div>

        <div class="admin-ui-actions">
            <form asp-area="Admin" asp-controller="Recommendation" asp-action="Train" method="post" class="m-0">
                @Html.AntiForgeryToken()
                <button type="submit" class="admin-ui-btn admin-ui-btn--soft">
                    <i class="fa fa-line-chart"></i>
                    Train recommendation
                </button>
            </form>

            <a asp-area="Admin"
               asp-action="Create"
               asp-controller="Product"
               class="admin-ui-btn admin-ui-btn--primary">
                <i class="fa fa-plus-circle"></i>
                Tạo sản phẩm
            </a>
        </div>
    </section>

    <div class="row g-3 product-index-page">

    <div class="col-12">
        <div class="card-soft toolbar-card">
            <div class="toolbar-inner">
                <div class="toolbar-left">
                    <div class="search-box">
                        <span class="search-icon">
                            <i class="fa fa-search"></i>
                        </span>
                        <input type="text" id="tableSearch" class="form-control" placeholder="Tìm theo tên sản phẩm..." />
                    </div>
                </div>

                <div class="toolbar-right">
                    <span class="total-badge">
                        Tổng: <span id="totalRows">@productList.Count</span>
                    </span>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card-soft filter-card">
            <div class="filter-top">
                <div class="filter-title">
                    <i class="fa fa-filter"></i>
                    <span>Bộ lọc nâng cao</span>
                </div>

                <button type="button" id="resetFilters" class="btn-reset-filter">
                    Xóa bộ lọc
                </button>
            </div>

            <div class="row g-3">
                <div class="col-12 col-md-6 col-lg-3">
                    <label class="filter-label">Danh mục</label>
                    <select id="filterCategory" class="form-select filter-control">
                        <option value="">Tất cả</option>
                        @foreach (var category in categories)
                        {
                            <option value="@category">@category</option>
                        }
                    </select>
                </div>

                <div class="col-12 col-md-6 col-lg-3">
                    <label class="filter-label">Loại catalog</label>
                    <select id="filterProductType" class="form-select filter-control">
                        <option value="">Tất cả</option>
                        @foreach (var productType in productTypes)
                        {
                            <option value="@productType">@productType</option>
                        }
                    </select>
                </div>

                <div class="col-12 col-md-6 col-lg-3">
                    <label class="filter-label">Thương hiệu</label>
                    <select id="filterPublisher" class="form-select filter-control">
                        <option value="">Tất cả</option>
                        @foreach (var publisher in publishers)
                        {
                            <option value="@publisher">@publisher</option>
                        }
                    </select>
                </div>

                <div class="col-12 col-md-6 col-lg-2">
                    <label class="filter-label">Tồn kho</label>
                    <select id="filterStock" class="form-select filter-control">
                        <option value="">Tất cả</option>
                        <option value="in">Còn hàng</option>
                        <option value="out">Hết hàng</option>
                    </select>
                </div>

                <div class="col-12 col-md-6 col-lg-2">
                    <label class="filter-label">Đã bán</label>
                    <select id="filterSold" class="form-select filter-control">
                        <option value="">Tất cả</option>
                        <option value="sold">Đã có bán</option>
                        <option value="unsold">Chưa bán</option>
                    </select>
                </div>

                <div class="col-12 col-md-6 col-lg-2">
                    <label class="filter-label">Giá từ</label>
                    <input type="text" id="filterMinPrice" class="form-control filter-control" placeholder="Ví dụ: 100000" />
                </div>

                <div class="col-12 col-md-6 col-lg-2">
                    <label class="filter-label">Giá đến</label>
                    <input type="text" id="filterMaxPrice" class="form-control filter-control" placeholder="Ví dụ: 5000000" />
                </div>
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card-soft table-card">
            <div class="table-responsive">
                <table class="table product-table" id="myTable">
                    <thead>
                        <tr>
                            <th style="width: 100px;">Mã SP</th>
                            <th style="width: 110px;">Ảnh</th>
                            <th>Tên sản phẩm</th>
                            <th style="width: 120px;">Tồn kho</th>
                            <th style="width: 120px;">Đã bán</th>
                            <th style="width: 150px;">Giá</th>
                            <th style="width: 150px;">Slug</th>
                            <th style="width: 140px;">Danh mục</th>
                            <th style="width: 140px;">Thương hiệu</th>
                            <th style="width: 130px;">Trạng thái</th>
                            <th style="width: 280px;" class="text-right">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in productList)
                        {
                            var productTypeLabel = ProductCatalogAdminRules.GetAdminProductTypeLabel(item.ProductType);
                            var canOpenOptionManagement = ProductCatalogAdminRules.CanAccessOptionManagement(item);
                            var hasLegacyOptions = ProductCatalogAdminRules.HasLegacyOptions(item);

                            <tr data-product-type="@productTypeLabel">
                                <td>
                                    <span class="code-pill">P@item.Id</span>
                                </td>

                                <td>
                                    <div class="thumb-wrap">
                                        @{
                                            var imageSrc = ProductImageHelper.ResolveProductImage(item);
                                        }

                                        @if (!string.IsNullOrWhiteSpace(imageSrc))
                                        {
                                            <img src="@imageSrc" alt="@item.Name" class="thumb" />
                                        }
                                        else
                                        {
                                            <div class="thumb thumb-placeholder">
                                                <i class="fa fa-image"></i>
                                            </div>
                                        }
                                    </div>
                                </td>

                                <td>
                                    <div class="name-cell">
                                        <div class="name-main">@item.Name</div>
                                        <div class="name-tags">
                                            <span class="type-badge @(item.ProductType == ProductType.PcPrebuilt ? "type-badge--prebuilt" : "type-badge--normal")">
                                                @productTypeLabel
                                            </span>
                                            @if (hasLegacyOptions)
                                            {
                                                <span class="type-badge type-badge--legacy">Option cũ</span>
                                            }
                                        </div>
                                        <div class="name-sub text-muted">
                                            @item.Description
                                        </div>
                                    </div>
                                </td>

                                <td>
                                    <div class="qty-cell">
                                        <span class="qty-badge">@item.Quantity</span>
                                        @if (User.CanAccessWarehouse())
                                        {
                                            <div class="mt-1">
                                                <a asp-area="Admin"
                                                       asp-controller="Inventory"
                                                       asp-action="ProductStock"
                                                       asp-route-productId="@item.Id"
                                                       class="mini-link">
                                                    Quản lý kho
                                                </a>
                                            </div>
                                        }
                                    </div>
                                </td>

                                <td>
                                    <span class="sold-badge">@item.Sold</span>
                                </td>

                                <td>
                                    <span class="price-text">@string.Format(new CultureInfo("vi-VN"), "{0:N0} ₫", item.Price)</span>
                                </td>

                                <td>
                                    <span class="slug-text">@item.Slug</span>
                                </td>

                                <td>
                                    <span class="unit-badge">@(item.Category?.Name ?? "-")</span>
                                </td>

                                <td>
                                    <span class="unit-badge">@(item.Publisher?.Name ?? "-")</span>
                                </td>

                                <td>
                                    @if (item.Status == 1)
                                    {
                                        <span class="status-badge status-badge--show">Hiển thị</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge status-badge--hide">Ẩn tạm</span>
                                    }
                                </td>

                                <td class="text-right">
                                    <div class="action-group">
                                        <a asp-action="Edit"
                                               asp-controller="Product"
                                               asp-route-id="@item.Id"
                                               class="icon-btn icon-edit"
                                               title="Chỉnh sửa">
                                            <i class="fa fa-pencil-square-o"></i>
                                        </a>

                                        @if (canOpenOptionManagement)
                                        {
                                            <a asp-area="Admin"
                                               asp-controller="ProductOption"
                                               asp-action="Index"
                                               asp-route-productId="@item.Id"
                                               class="icon-btn icon-option"
                                               title="@(item.ProductType == ProductType.PcPrebuilt ? "Option nâng cấp" : "Rà soát option cũ")">
                                                <i class="fa fa-sliders"></i>
                                            </a>
                                        }

                                        <form asp-action="ToggleVisibility"
                                              asp-controller="Product"
                                              method="post"
                                              style="display:inline-block;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit"
                                                    class="icon-btn @(item.Status == 1 ? "icon-hide" : "icon-show")"
                                                    title="@(item.Status == 1 ? "Ẩn sản phẩm" : "Hiển thị sản phẩm")">
                                                <i class="fa @(item.Status == 1 ? "fa-eye-slash" : "fa-eye")"></i>
                                            </button>
                                        </form>

                                        <form asp-action="Delete"
                                              asp-controller="Product"
                                              method="post"
                                              style="display:inline-block;"
                                              data-swal-confirm
                                              data-swal-title="Xóa sản phẩm?"
                                              data-swal-text="Sản phẩm sẽ bị xóa nếu không còn ràng buộc dữ liệu."
                                              data-swal-confirm-text="Xóa"
                                              data-swal-cancel-text="Hủy">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="icon-btn icon-delete" title="Xóa">
                                                <i class="fa fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
</div>

<style>
    .product-index-page .page-subtitle {
        opacity: .75;
    }

    .card-soft {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.05);
    }

    .toolbar-card,
    .filter-card {
        padding: 16px 18px;
    }

    .toolbar-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
    }

    .toolbar-left {
        flex: 1;
        min-width: 260px;
    }

    .toolbar-right {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .search-box {
        position: relative;
        max-width: 420px;
    }

        .search-box .form-control {
            height: 42px;
            border-radius: 12px;
            padding-left: 40px;
            border: 1px solid #d1d5db;
            box-shadow: none;
        }

    .search-icon {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: #6b7280;
        z-index: 2;
    }

    .total-badge {
        display: inline-flex;
        align-items: center;
        border: 1px solid #d1d5db;
        background: #f9fafb;
        color: #374151;
        border-radius: 999px;
        padding: 8px 14px;
        font-size: 13px;
        font-weight: 600;
    }

    .filter-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 14px;
        flex-wrap: wrap;
    }

    .filter-title {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 15px;
        font-weight: 700;
        color: #111827;
    }

    .filter-label {
        display: block;
        margin-bottom: 6px;
        font-size: 12px;
        font-weight: 700;
        color: #374151;
    }

    .filter-control {
        height: 42px;
        border-radius: 12px;
        border: 1px solid #d1d5db;
        box-shadow: none;
    }

        .filter-control:focus,
        .search-box .form-control:focus {
            border-color: #9ca3af;
            box-shadow: none;
        }

    .btn-reset-filter {
        border: 1px solid #d1d5db;
        background: #fff;
        color: #374151;
        border-radius: 12px;
        height: 42px;
        padding: 0 14px;
        font-size: 13px;
        font-weight: 600;
        transition: all .2s ease;
    }

        .btn-reset-filter:hover {
            background: #f3f4f6;
            border-color: #cbd5e1;
        }

    .table-card {
        overflow: hidden;
    }

    .product-table {
        margin-bottom: 0;
    }

        .product-table thead th {
            background: #f8fafc;
            color: #374151;
            font-weight: 700;
            border-bottom: 1px solid #e5e7eb !important;
            vertical-align: middle !important;
            padding: 14px 12px !important;
        }

        .product-table tbody td {
            vertical-align: middle !important;
            padding: 14px 12px !important;
            border-top: 1px solid #eef2f7 !important;
        }

        .product-table tbody tr:hover {
            background: #fafafa;
        }

    .code-pill {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 999px;
        background: #111827;
        color: #fff;
        font-size: 12px;
        font-weight: 700;
    }

    .thumb-wrap {
        display: flex;
        align-items: center;
    }

    .thumb {
        width: 84px;
        height: 64px;
        object-fit: cover;
        border-radius: 12px;
        border: 1px solid #e5e7eb;
        background: #f9fafb;
    }

    .thumb-placeholder {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #9ca3af;
        font-size: 20px;
    }

    .name-main {
        font-weight: 700;
        color: #111827;
        margin-bottom: 4px;
    }

    .name-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-bottom: 6px;
    }

    .type-badge {
        display: inline-flex;
        align-items: center;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 11px;
        font-weight: 700;
        border: 1px solid transparent;
    }

    .type-badge--normal {
        background: #eff6ff;
        border-color: #bfdbfe;
        color: #1d4ed8;
    }

    .type-badge--prebuilt {
        background: #ecfdf5;
        border-color: #bbf7d0;
        color: #15803d;
    }

    .type-badge--legacy {
        background: #fff7ed;
        border-color: #fed7aa;
        color: #c2410c;
    }

    .name-sub {
        font-size: 12px;
        line-height: 1.45;
        max-width: 280px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .qty-badge,
    .sold-badge,
    .unit-badge,
    .status-badge {
        display: inline-flex;
        align-items: center;
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 600;
        border: 1px solid #dbe3ee;
        background: #f8fafc;
        color: #374151;
    }

    .status-badge--show {
        color: #15803d;
    }

    .status-badge--hide {
        color: #b91c1c;
    }

    .price-text {
        font-weight: 700;
        color: #111827;
        white-space: nowrap;
    }

    .slug-text {
        font-size: 12px;
        color: #6b7280;
        word-break: break-word;
    }

    .mini-link {
        font-size: 12px;
        font-weight: 600;
        text-decoration: none;
    }

        .mini-link:hover {
            text-decoration: underline;
        }

    .action-group {
        display: inline-flex;
        justify-content: flex-end;
        gap: 8px;
        flex-wrap: wrap;
    }

    .icon-btn {
        width: 38px;
        height: 38px;
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid #e5e7eb;
        background: #fff;
        text-decoration: none !important;
        transition: all .2s ease;
    }

        .icon-btn:hover {
            background: #f3f4f6;
            border-color: #d1d5db;
        }

    .icon-add {
        width: 44px;
        height: 44px;
        border-radius: 14px;
        color: #16a34a;
    }

    .icon-edit {
        color: #f59e0b;
    }

    .icon-option {
        color: #2563eb;
    }

    .icon-show {
        color: #15803d;
    }

    .icon-hide {
        color: #b91c1c;
    }

    .icon-delete {
        color: #ef4444;
    }

    div.dt-container .dt-layout-row {
        padding: 12px 16px;
    }

    @@media (max-width: 991px) {
        .name-sub {
            max-width: 180px;
        }
    }

    @@media (max-width: 767px) {
        .toolbar-inner,
        .filter-top {
            flex-direction: column;
            align-items: stretch;
        }

        .toolbar-left,
        .search-box {
            max-width: 100%;
        }

        .btn-reset-filter {
            width: 100%;
        }
    }
</style>

@section Scripts {
    <script>
        const table = new DataTable('#myTable', {
            layout: {
                topStart: { buttons: ['copy', 'csv', 'excel', 'pdf', 'print'] }
            }
        });

        const searchInput = document.getElementById('tableSearch');
        const totalEl = document.getElementById('totalRows');

        const filterCategory = document.getElementById('filterCategory');
        const filterProductType = document.getElementById('filterProductType');
        const filterPublisher = document.getElementById('filterPublisher');
        const filterStock = document.getElementById('filterStock');
        const filterSold = document.getElementById('filterSold');
        const filterMinPrice = document.getElementById('filterMinPrice');
        const filterMaxPrice = document.getElementById('filterMaxPrice');
        const resetFiltersBtn = document.getElementById('resetFilters');

        function parseNumber(value) {
            if (!value) return 0;
            const cleaned = value.toString().replace(/[^\d\-]/g, '');
            return cleaned ? parseInt(cleaned, 10) : 0;
        }

        DataTable.ext.search.push(function (settings, data, dataIndex) {
            if (settings.nTable.id !== 'myTable') return true;

            const rowStock = parseNumber(data[3]);
            const rowSold = parseNumber(data[4]);
            const rowPrice = parseNumber(data[5]);
            const rowNode = table.row(dataIndex).node();
            const rowProductType = (rowNode?.getAttribute('data-product-type') || '').trim();
            const rowCategory = (data[7] || '').trim();
            const rowPublisher = (data[8] || '').trim();

            const selectedCategory = (filterCategory?.value || '').trim();
            const selectedProductType = (filterProductType?.value || '').trim();
            const selectedPublisher = (filterPublisher?.value || '').trim();
            const selectedStock = (filterStock?.value || '').trim();
            const selectedSold = (filterSold?.value || '').trim();
            const minPriceRaw = (filterMinPrice?.value || '').trim();
            const maxPriceRaw = (filterMaxPrice?.value || '').trim();
            const minPrice = parseNumber(minPriceRaw);
            const maxPrice = parseNumber(maxPriceRaw);

            if (selectedCategory && rowCategory !== selectedCategory) return false;
            if (selectedProductType && rowProductType !== selectedProductType) return false;
            if (selectedPublisher && rowPublisher !== selectedPublisher) return false;

            if (selectedStock === 'in' && rowStock <= 0) return false;
            if (selectedStock === 'out' && rowStock > 0) return false;

            if (selectedSold === 'sold' && rowSold <= 0) return false;
            if (selectedSold === 'unsold' && rowSold > 0) return false;

            if (minPriceRaw !== '' && rowPrice < minPrice) return false;
            if (maxPriceRaw !== '' && rowPrice > maxPrice) return false;

            return true;
        });

        if (searchInput) {
            searchInput.addEventListener('keyup', function () {
                table.search(this.value).draw();
            });
        }

        [
            filterCategory,
            filterProductType,
            filterPublisher,
            filterStock,
            filterSold
        ].forEach(el => {
            if (el) {
                el.addEventListener('change', function () {
                    table.draw();
                });
            }
        });

        [
            filterMinPrice,
            filterMaxPrice
        ].forEach(el => {
            if (el) {
                el.addEventListener('input', function () {
                    table.draw();
                });
            }
        });

        if (resetFiltersBtn) {
            resetFiltersBtn.addEventListener('click', function () {
                if (searchInput) searchInput.value = '';
                if (filterCategory) filterCategory.value = '';
                if (filterProductType) filterProductType.value = '';
                if (filterPublisher) filterPublisher.value = '';
                if (filterStock) filterStock.value = '';
                if (filterSold) filterSold.value = '';
                if (filterMinPrice) filterMinPrice.value = '';
                if (filterMaxPrice) filterMaxPrice.value = '';

                table.search('').draw();
            });
        }

        table.on('draw', function () {
            const info = table.page.info();
            if (totalEl) {
                totalEl.textContent = info.recordsDisplay;
            }
        });
    </script>
}
