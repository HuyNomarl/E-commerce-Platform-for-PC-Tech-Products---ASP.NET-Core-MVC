@model Eshop.Models.ProductModel

@{
    ViewData["Title"] = "Create Product";
}

<h4>Create Product</h4>

<div class="row">
    <div class="col-md-8">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="Name" class="control-label">Tên sản phẩm</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Description" class="control-label">Mô tả</label>
                <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Price" class="control-label">Giá</label>
                <input asp-for="Price" class="form-control" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="CategoryId" class="control-label">Danh mục</label>
                <select asp-for="CategoryId" class="form-control" asp-items="ViewBag.Categories">
                    <option value="">-- Select Category --</option>
                </select>
                <span asp-validation-for="CategoryId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="PublisherId" class="control-label">Thương hiệu</label>
                <select asp-for="PublisherId" class="form-control" asp-items="ViewBag.Publishers">
                    <option value="">-- Select Brand --</option>
                </select>
                <span asp-validation-for="PublisherId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="IsPcBuild" class="control-label">Loại sản phẩm</label>
                <div class="form-check">
                    <input asp-for="IsPcBuild" class="form-check-input" />
                    <label asp-for="IsPcBuild" class="form-check-label">Đây là PC có cấu hình nâng cấp</label>
                </div>
                <span asp-validation-for="IsPcBuild" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ImageUpload" class="control-label">Ảnh sản phẩm</label>
                <input asp-for="ImageUpload" type="file" class="form-control" accept="image/*" />
                <span asp-validation-for="ImageUpload" class="text-danger"></span>

                <div class="mt-3">
                    <img id="imgpreview" src="#" alt="Preview" style="display:none; max-width:300px; max-height:300px;" class="img-thumbnail" />
                </div>
            </div>

            <div class="form-group mb-3">
                <button type="submit" class="btn btn-primary">Create</button>
                <a asp-action="Index" class="btn btn-secondary">Back to Index</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function readURL(input) {
            if (input.files && input.files[0]) {
                let reader = new FileReader();
                reader.onload = function (e) {
                    $("#imgpreview")
                        .attr("src", e.target.result)
                        .show();
                };
                reader.readAsDataURL(input.files[0]);
            } else {
                $("#imgpreview").attr("src", "#").hide();
            }
        }

        $("#ImageUpload").change(function () {
            readURL(this);
        });
    </script>
}