@model List<Eshop.Models.ViewModels.DashboardWarehouseStockViewModel>

<div class="dash-card">
    <div class="dash-card__head">
        <div>
            <h4>Tồn kho theo kho</h4>
            <p>Phân bổ tồn theo từng kho</p>
        </div>
    </div>

    <div class="dash-table-wrap custom-scroll">
        <table class="table dash-table">
            <thead>
                <tr>
                    <th>Kho</th>
                    <th>On-hand</th>
                    <th>Reserved</th>
                    <th>Khả dụng</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-semibold">@item.WarehouseName</td>
                            <td>@item.OnHandQuantity</td>
                            <td>@item.ReservedQuantity</td>
                            <td class="text-strong">@item.AvailableQuantity</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted">Chưa có dữ liệu kho.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>