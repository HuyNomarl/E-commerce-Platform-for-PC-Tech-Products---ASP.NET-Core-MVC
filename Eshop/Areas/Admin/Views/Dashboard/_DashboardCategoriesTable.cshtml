@model List<Eshop.Models.ViewModels.DashboardCategoryPerformanceViewModel>

<div class="dash-card">
    <div class="dash-card__head">
        <div>
            <h4>Hiệu quả danh mục</h4>
            <p>Doanh thu theo nhóm sản phẩm</p>
        </div>
    </div>

    <div class="dash-table-wrap custom-scroll">
        <table class="table dash-table">
            <thead>
                <tr>
                    <th>Danh mục</th>
                    <th>Số lượng bán</th>
                    <th>Doanh thu</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-semibold">@item.CategoryName</td>
                            <td>@item.QuantitySold</td>
                            <td class="text-strong">@item.Revenue.ToString("N0") đ</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="text-center text-muted">Chưa có dữ liệu danh mục.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>