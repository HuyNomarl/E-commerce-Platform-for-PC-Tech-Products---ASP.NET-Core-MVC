@model List<Eshop.Models.ViewModels.DashboardCustomerViewModel>

<div class="dash-card">
    <div class="dash-card__head">
        <div>
            <h4>Khách hàng nổi bật</h4>
            <p>Nhóm khách hàng có giá trị giao dịch cao</p>
        </div>
    </div>

    <div class="dash-table-wrap custom-scroll">
        <table class="table dash-table">
            <thead>
                <tr>
                    <th>Khách hàng</th>
                    <th>Email</th>
                    <th>Số đơn</th>
                    <th>Doanh thu</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-semibold">@item.CustomerName</td>
                            <td>@item.Email</td>
                            <td>@item.OrderCount</td>
                            <td class="text-strong">@item.Revenue.ToString("N0") đ</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted">Chưa có dữ liệu khách hàng.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>