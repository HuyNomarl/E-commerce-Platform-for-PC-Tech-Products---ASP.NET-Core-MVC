@model IEnumerable<Eshop.Models.SliderModel>
@using System.Linq

@{
    ViewData["Title"] = "Slider";
    var sliders = Model?.ToList() ?? new List<Eshop.Models.SliderModel>();
    var activeCount = sliders.Count(x => x.Status == 1);
    var hiddenCount = sliders.Count - activeCount;
}

<div class="admin-ui-page admin-ui-page--rose">
    <section class="admin-ui-hero">
        <div class="admin-ui-hero__content">
            <span class="admin-ui-hero__eyebrow">Homepage Slider</span>
            <h4>Quản lý slider</h4>
            <p class="admin-ui-hero__desc">
                Theo dõi nhanh các banner đang hiển thị trên trang chủ, tối ưu ảnh minh họa và giữ phần quản trị đồng bộ với ngôn ngữ giao diện mới.
            </p>
            <div class="admin-ui-hero__meta">
                <span class="admin-ui-chip">@sliders.Count slider</span>
                <span class="admin-ui-chip">@activeCount đang hiển thị</span>
                <span class="admin-ui-chip">@hiddenCount đang ẩn</span>
            </div>
        </div>

        <a asp-area="Admin" asp-action="Create" asp-controller="Slider" class="admin-ui-back">
            <i class="fa fa-plus"></i>
            Thêm slider
        </a>
    </section>

    <div class="admin-ui-stats">
        <article class="admin-ui-stat">
            <div class="admin-ui-stat__label"><i class="fa fa-photo"></i>Tổng slider</div>
            <div class="admin-ui-stat__value">@sliders.Count</div>
            <div class="admin-ui-stat__hint">Tất cả banner đang được quản lý trong hệ thống.</div>
        </article>

        <article class="admin-ui-stat">
            <div class="admin-ui-stat__label"><i class="fa fa-eye"></i>Đang hiển thị</div>
            <div class="admin-ui-stat__value">@activeCount</div>
            <div class="admin-ui-stat__hint">Những slider đang xuất hiện ở giao diện người dùng.</div>
        </article>

        <article class="admin-ui-stat">
            <div class="admin-ui-stat__label"><i class="fa fa-eye-slash"></i>Đang ẩn</div>
            <div class="admin-ui-stat__value">@hiddenCount</div>
            <div class="admin-ui-stat__hint">Slider đã lưu nhưng chưa được bật hiển thị.</div>
        </article>
    </div>

    <section class="admin-ui-panel">
        <div class="admin-ui-panel__head">
            <div>
                <div class="admin-ui-panel__title">
                    <i class="fa fa-clone"></i>
                    Danh sách slider
                </div>
                <div class="admin-ui-panel__subtitle">
                    Chỉnh sửa nội dung, hình ảnh và trạng thái của từng slider trực tiếp từ một bảng quản lý gọn gàng hơn.
                </div>
            </div>
            <span class="admin-ui-total">Tổng: @sliders.Count</span>
        </div>

        <div class="admin-ui-panel__body">
            @if (sliders.Any())
            {
                <div class="admin-ui-table-shell">
                    <div class="admin-ui-table-responsive">
                        <table class="table admin-ui-table" id="myTable">
                            <thead>
                                <tr>
                                    <th style="width: 80px;">ID</th>
                                    <th>Tên slider</th>
                                    <th>Mô tả</th>
                                    <th style="width: 170px;">Hình ảnh</th>
                                    <th style="width: 140px;">Trạng thái</th>
                                    <th style="width: 220px;">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in sliders)
                                {
                                    <tr>
                                        <td>#@item.Id</td>
                                        <td>
                                            <div class="admin-ui-stack">
                                                <div class="admin-ui-stack__title">@item.Name</div>
                                                <div class="admin-ui-stack__line">Slider trang chủ</div>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="admin-ui-html">@item.Description</div>
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(item.Image))
                                            {
                                                <img src="~/media/sliders/@item.Image" alt="@item.Name" class="admin-ui-thumb admin-ui-thumb--wide" />
                                            }
                                            else
                                            {
                                                <span class="admin-ui-muted">Chưa có ảnh</span>
                                            }
                                        </td>
                                        <td>
                                            @if (item.Status == 1)
                                            {
                                                <span class="admin-ui-status admin-ui-status--success">Hiển thị</span>
                                            }
                                            else
                                            {
                                                <span class="admin-ui-status">Ẩn</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="admin-ui-table-actions">
                                                <a asp-area="Admin"
                                                   asp-action="Edit"
                                                   asp-controller="Slider"
                                                   asp-route-id="@item.Id"
                                                   class="admin-ui-btn admin-ui-btn--soft">
                                                    <i class="fa fa-pencil"></i>
                                                    Sửa
                                                </a>

                                                <form asp-area="Admin"
                                                      asp-controller="Slider"
                                                      asp-action="Delete"
                                                      asp-route-id="@item.Id"
                                                      method="post"
                                                      class="admin-ui-inline-form">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="admin-ui-btn admin-ui-btn--danger confirmDeletion">
                                                        <i class="fa fa-trash"></i>
                                                        Xóa
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
            else
            {
                <div class="admin-ui-empty">
                    Chưa có slider nào. Hãy thêm slider đầu tiên để hoàn thiện phần hiển thị trang chủ.
                </div>
            }
        </div>
    </section>
</div>

@section Scripts {
    @if (sliders.Any())
    {
        <script>
            new DataTable('#myTable', {
              layout: {
                topStart: { buttons: ['copy', 'csv', 'excel', 'pdf', 'print'] }
              }
            });
        </script>
    }
}
