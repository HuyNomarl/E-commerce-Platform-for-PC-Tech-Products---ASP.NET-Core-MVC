@model IEnumerable<Eshop.Models.PublisherModel>
@{
    ViewData["title"] = "Brand Index";
}

<h3>Brand Index View</h3>
<a asp-area="Admin" asp-action="Create" asp-controller="Publisher">Add Brand</a>
<table class="table" id="myTable">
    <thead>
        <tr>
            <th scope="col">Id</th>
            <th scope="col">Brand Name</th>
            <th scope="col">Brand Description</th>
            <th scope="col">Brand Slug</th>
            <th scope="col">Status</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>

        @foreach (var item in Model)
        {
            <tr>
                <th scope="row">@item.Id</th>
                <td>@item.Name</td>
                <td>@item.Description</td>
                <td>@item.Slug</td>
                <td>
                    @if (item.status == 1)
                    {
                        <span>Hiển thị</span>
                    }
                    else
                    {
                        <span>Ẩn</span>
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-controller="Publisher" asp-route-id="@item.Id" class="btn btn-primary">Edit</a>
                    <a asp-action="Delete" asp-controller="Publisher" asp-route-id="@item.Id" class="btn btn-primary confirmDeletion">Delete</a>
                </td>
            </tr>

        }


    </tbody>
</table>
@section Scripts {
    <script>
        new DataTable('#myTable', {
          layout: {
            topStart: { buttons: ['copy', 'csv', 'excel', 'pdf', 'print'] }
          }
        });
    </script>
}
