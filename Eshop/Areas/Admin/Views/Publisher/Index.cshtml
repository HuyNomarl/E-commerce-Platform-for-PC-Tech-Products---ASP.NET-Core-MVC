@model IEnumerable<Eshop.Models.PublisherModel>

@{
    ViewData["title"] = "Brand Index";
}

<div class="row g-3 publisher-index-page">
    <div class="col-12">
        <div class="d-flex align-items-start align-items-md-center justify-content-between gap-2 flex-column flex-md-row">
            <div>
                <h4 class="mb-1">Thương hiệu</h4>
                <div class="small page-subtitle">Quản lý danh sách thương hiệu sản phẩm</div>
            </div>

            <a asp-area="Admin"
                   asp-action="Create"
                   asp-controller="Publisher"
                   class="icon-btn icon-add"
                   title="Thêm thương hiệu">
                <i class="fa fa-plus-circle"></i>
            </a>
        </div>
    </div>

    <div class="col-12">
        <div class="card-soft table-card">
            <div class="table-toolbar">
                <div>
                    <div class="section-title mb-0">Danh sách thương hiệu</div>
                    <div class="section-subtitle">Xem, chỉnh sửa và quản lý trạng thái hiển thị của thương hiệu</div>
                </div>

                <div class="toolbar-right">
                    <div class="search-box">
                        <span class="search-icon">
                            <i class="fa fa-search"></i>
                        </span>
                        <input type="text" id="tableSearch" class="form-control" placeholder="Tìm kiếm thương hiệu..." />
                    </div>

                    <span class="total-badge">
                        Tổng: <span id="totalRows">@Model.Count()</span>
                    </span>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table publisher-table" id="myTable">
                    <thead>
                        <tr>
                            <th style="width: 80px;">ID</th>
                            <th>Tên thương hiệu</th>
                            <th>Mô tả</th>
                            <th>Slug</th>
                            <th style="width: 130px;">Trạng thái</th>
                            <th style="width: 150px;" class="text-right">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <span class="code-pill">B@item.Id</span>
                                    </td>

                                    <td>
                                        <div class="cell-main">@item.Name</div>
                                    </td>

                                    <td>
                                        <div class="desc-text">@item.Description</div>
                                    </td>

                                    <td>
                                        <span class="slug-text">@item.Slug</span>
                                    </td>

                                    <td>
                                        @if (item.status == 1)
                                        {
                                            <span class="badge-soft badge-show">Hiển thị</span>
                                        }
                                        else
                                        {
                                            <span class="badge-soft badge-hide">Ẩn</span>
                                        }
                                    </td>

                                    <td class="text-right">
                                        <div class="action-group">
                                            <a asp-action="Edit"
                                                   asp-controller="Publisher"
                                                   asp-route-id="@item.Id"
                                                   class="icon-btn icon-edit"
                                                   title="Sửa">
                                                <i class="fa fa-pencil-square-o"></i>
                                            </a>

                                            <form asp-action="Delete"
                                                  asp-controller="Publisher"
                                                  method="post"
                                                  style="display:inline-block;"
                                                  data-swal-confirm
                                                  data-swal-title="Xóa thương hiệu?"
                                                  data-swal-text="Thao tác này không thể hoàn tác."
                                                  data-swal-confirm-text="Xóa"
                                                  data-swal-cancel-text="Hủy">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <button type="submit" class="icon-btn icon-delete" title="Xóa">
                                                    <i class="fa fa-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="empty-cell text-center">
                                    <div class="empty-wrap">
                                        <i class="fa fa-folder-open-o empty-icon"></i>
                                        <div>Chưa có thương hiệu nào.</div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .publisher-index-page .page-subtitle {
        opacity: .75;
    }

    .card-soft {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.05);
    }

    .table-card {
        overflow: hidden;
    }

    .table-toolbar {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 16px;
        padding: 22px 22px 0 22px;
        flex-wrap: wrap;
    }

    .section-title {
        font-size: 20px;
        font-weight: 700;
        color: #111827;
        margin-bottom: 4px;
    }

    .section-subtitle {
        color: #6b7280;
        font-size: 13px;
        margin-bottom: 18px;
    }

    .toolbar-right {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .search-box {
        position: relative;
        min-width: 260px;
    }

        .search-box .form-control {
            height: 42px;
            border-radius: 12px;
            padding-left: 40px;
            border: 1px solid #d1d5db;
            box-shadow: none;
        }

    .search-icon {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: #6b7280;
        z-index: 2;
    }

    .total-badge {
        display: inline-flex;
        align-items: center;
        border: 1px solid #d1d5db;
        background: #f9fafb;
        color: #374151;
        border-radius: 999px;
        padding: 8px 14px;
        font-size: 13px;
        font-weight: 600;
    }

    .publisher-table {
        margin-bottom: 0;
    }

        .publisher-table thead th {
            background: #f8fafc;
            color: #374151;
            font-weight: 700;
            border-bottom: 1px solid #e5e7eb !important;
            vertical-align: middle !important;
            padding: 14px 12px !important;
        }

        .publisher-table tbody td {
            vertical-align: middle !important;
            padding: 14px 12px !important;
            border-top: 1px solid #eef2f7 !important;
        }

        .publisher-table tbody tr:hover {
            background: #fafafa;
        }

    .code-pill {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 999px;
        background: #111827;
        color: #fff;
        font-size: 12px;
        font-weight: 700;
    }

    .cell-main {
        font-weight: 700;
        color: #111827;
    }

    .desc-text {
        color: #4b5563;
        max-width: 320px;
        line-height: 1.45;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .slug-text {
        color: #6b7280;
        font-size: 12px;
        word-break: break-word;
    }

    .badge-soft {
        display: inline-flex;
        align-items: center;
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
        border: 1px solid #dbe3ee;
        background: #f8fafc;
    }

    .badge-show {
        color: #15803d;
    }

    .badge-hide {
        color: #dc2626;
    }

    .action-group {
        display: inline-flex;
        justify-content: flex-end;
        gap: 8px;
        flex-wrap: wrap;
    }

    .icon-btn {
        width: 38px;
        height: 38px;
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid #e5e7eb;
        background: #fff;
        text-decoration: none !important;
        transition: all .2s ease;
    }

        .icon-btn:hover {
            background: #f3f4f6;
            border-color: #d1d5db;
        }

    .icon-add {
        width: 44px;
        height: 44px;
        border-radius: 14px;
        color: #16a34a;
    }

    .icon-edit {
        color: #f59e0b;
    }

    .icon-delete {
        color: #ef4444;
    }

    .empty-cell {
        padding: 40px 20px !important;
    }

    .empty-wrap {
        color: #6b7280;
    }

    .empty-icon {
        font-size: 28px;
        margin-bottom: 8px;
        display: block;
    }

    div.dt-container .dt-search {
        display: none;
    }

    div.dt-container .dt-layout-row {
        padding: 12px 16px;
    }

    @@media (max-width: 767px) {
        .table-toolbar {
            padding: 18px 18px 0 18px;
            flex-direction: column;
            align-items: stretch;
        }

        .search-box {
            min-width: 100%;
        }

        .toolbar-right {
            width: 100%;
        }
    }
</style>

@section Scripts {
    <script>
        const table = new DataTable('#myTable', {
            layout: {
                topStart: { buttons: ['copy', 'csv', 'excel', 'pdf', 'print'] },
                topEnd: null
            }
        });

        const searchInput = document.getElementById('tableSearch');
        if (searchInput) {
            searchInput.addEventListener('keyup', function () {
                table.search(this.value).draw();
            });
        }

        table.on('draw', function () {
            const info = table.page.info();
            const totalEl = document.getElementById('totalRows');
            if (totalEl) {
                totalEl.textContent = info.recordsDisplay;
            }
        });
    </script>
}
