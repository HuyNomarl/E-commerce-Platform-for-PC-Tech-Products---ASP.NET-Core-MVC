@using Eshop.Models.Enums
@using Eshop.Models.ViewModels
@using System.Text.Json
@model AdminInventoryReceiveViewModel

@{
    ViewData["Title"] = "Phiếu nhập kho";
    var items = Model.Items != null && Model.Items.Count > 0
        ? Model.Items
        : new List<AdminInventoryReceiveItemViewModel> { new() };
    var productOptionsJson = JsonSerializer.Serialize(Model.ProductOptions);

    string GetStatusText(InventoryReceiptStatus status) => status switch
    {
        InventoryReceiptStatus.Pending => "Chờ duyệt",
        InventoryReceiptStatus.Approved => "Đã duyệt",
        InventoryReceiptStatus.Cancelled => "Đã hủy",
        _ => status.ToString()
    };

    string GetStatusClass(InventoryReceiptStatus status) => status switch
    {
        InventoryReceiptStatus.Pending => "status-badge status-warning",
        InventoryReceiptStatus.Approved => "status-badge status-success",
        InventoryReceiptStatus.Cancelled => "status-badge status-danger",
        _ => "status-badge status-muted"
    };
}

<div class="row g-3 inventory-receive-page inv-page">
    <div class="col-12">
        <section class="inv-hero">
            <div class="inv-hero__content">
                <div class="inv-hero__eyebrow">
                    <i class="fa fa-download"></i>
                    <span>Inventory Intake</span>
                </div>
                <h4>Phiếu nhập kho</h4>
                <p class="inv-hero__desc">Tạo phiếu nhập theo brand, thêm nhiều sản phẩm trong một lần và duyệt sau để cập nhật tồn kho chính xác hơn.</p>
                <div class="inv-hero__meta">
                    <span class="inv-chip">Chọn kho và brand</span>
                    <span class="inv-chip">Thêm nhiều sản phẩm</span>
                    <span class="inv-chip">Duyệt sau khi kiểm tra</span>
                </div>
            </div>

            <a asp-action="Index" class="inv-btn-back">
                <i class="fa fa-arrow-left"></i>
                <span>Quay lại tổng quan kho</span>
            </a>
        </section>
    </div>

    <div class="col-12">
        <div class="card-soft inv-panel">
            <div class="section-head">
                <div>
                    <div class="section-title">
                        <i class="fa fa-plus-circle"></i>
                        <span>Tạo phiếu nhập mới</span>
                    </div>
                    <div class="section-subtitle">Điền thông tin đợt nhập và thêm danh sách sản phẩm theo brand đã chọn.</div>
                </div>
            </div>

            <div class="section-body">
                <form asp-action="Receive" method="post" id="receipt-form">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger inv-validation-summary"></div>

                    <div class="inv-step-row">
                        <span class="inv-step-chip">1. Chọn kho</span>
                        <span class="inv-step-chip">2. Chọn brand</span>
                        <span class="inv-step-chip">3. Thêm sản phẩm và giá nhập</span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-12 col-md-4">
                            <label asp-for="WarehouseId" class="field-label">Kho</label>
                            <select asp-for="WarehouseId" asp-items="Model.Warehouses" class="form-select field-control">
                                <option value="">-- Chọn kho --</option>
                            </select>
                            <span asp-validation-for="WarehouseId" class="text-danger small"></span>
                        </div>

                        <div class="col-12 col-md-4">
                            <label asp-for="PublisherId" class="field-label">Brand</label>
                            <select asp-for="PublisherId"
                                    asp-items="Model.Publishers"
                                    class="form-select field-control js-filterable-select"
                                    id="PublisherId"
                                    data-search-placeholder="Tìm brand theo tên...">
                                <option value="">-- Chọn brand --</option>
                            </select>
                            <span asp-validation-for="PublisherId" class="text-danger small"></span>
                        </div>

                        <div class="col-12 col-md-4">
                            <label asp-for="ReferenceCode" class="field-label">Mã tham chiếu</label>
                            <input asp-for="ReferenceCode" class="form-control field-control" placeholder="Ví dụ: PO-20260325-01" />
                            <span asp-validation-for="ReferenceCode" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Note" class="field-label">Ghi chú</label>
                            <textarea asp-for="Note" class="form-control field-control textarea-control" rows="3" placeholder="Thông tin thêm về đợt nhập này"></textarea>
                            <span asp-validation-for="Note" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="sub-toolbar">
                        <div class="sub-toolbar-title">
                            <i class="fa fa-cubes"></i>
                            <span>Danh sách sản phẩm</span>
                        </div>

                        <button type="button" class="btn-add-soft" id="add-receipt-row">
                            <i class="fa fa-plus"></i>
                            <span>Thêm sản phẩm</span>
                        </button>
                    </div>

                    <div class="table-responsive inv-table-shell">
                        <table class="table modern-table receipt-items-table">
                            <thead>
                                <tr>
                                    <th style="min-width: 280px;">Sản phẩm</th>
                                    <th style="width: 140px;">Số lượng</th>
                                    <th style="width: 180px;">Giá nhập</th>
                                    <th style="width: 100px;" class="text-center">Xóa</th>
                                </tr>
                            </thead>
                            <tbody id="receipt-items">
                                @for (int i = 0; i < items.Count; i++)
                                {
                                    <tr class="receipt-row">
                                        <td>
                                            <select name="Items[@i].ProductId"
                                                    class="form-select field-control js-product-select js-filterable-select"
                                                    data-search-placeholder="Tìm sản phẩm trong brand đã chọn...">
                                                <option value="">-- Chọn sản phẩm --</option>
                                                @foreach (var option in Model.ProductOptions)
                                                {
                                                    if (option.ProductId == items[i].ProductId)
                                                    {
                                                        <option value="@option.ProductId" data-publisher-id="@option.PublisherId" selected>@option.ProductName</option>
                                                    }
                                                    else
                                                    {
                                                        <option value="@option.ProductId" data-publisher-id="@option.PublisherId">@option.ProductName</option>
                                                    }
                                                }
                                            </select>
                                        </td>
                                        <td>
                                            <input name="Items[@i].Quantity"
                                                   value="@(items[i].Quantity > 0 ? items[i].Quantity : null)"
                                                   class="form-control field-control"
                                                   type="number"
                                                   min="1"
                                                   step="1" />
                                        </td>
                                        <td>
                                            <input name="Items[@i].UnitCost"
                                                   value="@(items[i].UnitCost?.ToString("0.##"))"
                                                   class="form-control field-control"
                                                   type="number"
                                                   min="0"
                                                   step="0.01" />
                                        </td>
                                        <td class="text-center">
                                            <button type="button" class="icon-btn icon-delete js-remove-row" title="Xóa dòng">
                                                <i class="fa fa-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="form-footer">
                        <button type="submit" class="btn-submit-soft">
                            <i class="fa fa-check-circle"></i>
                            <span>Tạo phiếu nhập</span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card-soft inv-panel">
            <div class="section-head">
                <div>
                    <div class="section-title">
                        <i class="fa fa-history"></i>
                        <span>Phiếu nhập gần đây</span>
                    </div>
                    <div class="section-subtitle">Theo dõi nhanh các phiếu mới tạo, trạng thái duyệt và danh sách sản phẩm liên quan.</div>
                </div>
            </div>

            <div class="section-body">
                @if (Model.RecentReceipts.Any())
                {
                    <div class="table-responsive inv-table-shell">
                        <table class="table modern-table recent-receipts-table">
                            <thead>
                                <tr>
                                    <th style="min-width: 180px;">Mã phiếu</th>
                                    <th style="min-width: 120px;">Brand</th>
                                    <th style="min-width: 120px;">Kho</th>
                                    <th style="min-width: 120px;">Trạng thái</th>
                                    <th style="min-width: 220px;">Sản phẩm</th>
                                    <th style="min-width: 180px;">Ghi chú</th>
                                    <th style="min-width: 170px;">Ngày tạo</th>
                                    <th style="min-width: 190px;">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var receipt in Model.RecentReceipts)
                                {
                                    <tr>
                                        <td>
                                            <div class="code-main">@receipt.ReceiptCode</div>
                                            @if (!string.IsNullOrWhiteSpace(receipt.ReferenceCode))
                                            {
                                                <div class="code-sub">Ref: @receipt.ReferenceCode</div>
                                            }
                                        </td>
                                        <td><span class="info-pill">@receipt.PublisherName</span></td>
                                        <td><span class="info-pill">@receipt.WarehouseName</span></td>
                                        <td><span class="@GetStatusClass(receipt.Status)">@GetStatusText(receipt.Status)</span></td>
                                        <td>
                                            <div class="stack-list">
                                                @foreach (var item in receipt.Items)
                                                {
                                                    <div class="stack-item">@item.ProductName x @item.Quantity</div>
                                                }
                                            </div>
                                        </td>
                                        <td>
                                            @if (string.IsNullOrWhiteSpace(receipt.Note))
                                            {
                                                <span class="muted-text">Không có</span>
                                            }
                                            else
                                            {
                                                <div class="note-text">@receipt.Note</div>
                                            }
                                        </td>
                                        <td>
                                            <div class="date-main">@receipt.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                                            @if (receipt.ApprovedAt.HasValue)
                                            {
                                                <div class="date-sub text-success">Duyệt: @receipt.ApprovedAt.Value.ToString("dd/MM/yyyy HH:mm")</div>
                                            }
                                            @if (receipt.CancelledAt.HasValue)
                                            {
                                                <div class="date-sub text-danger">Hủy: @receipt.CancelledAt.Value.ToString("dd/MM/yyyy HH:mm")</div>
                                            }
                                        </td>
                                        <td>
                                            @if (receipt.Status == InventoryReceiptStatus.Pending)
                                            {
                                                <div class="action-group">
                                                    <form asp-action="ApproveReceipt"
                                                          method="post"
                                                          class="d-inline"
                                                          data-swal-confirm
                                                          data-swal-title="Duyệt phiếu nhập?"
                                                          data-swal-text="Phiếu nhập sẽ được ghi nhận vào tồn kho."
                                                          data-swal-confirm-text="Duyệt"
                                                          data-swal-cancel-text="Hủy">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@receipt.Id" />
                                                        <button type="submit" class="btn-action-success">Duyệt</button>
                                                    </form>
                                                    <form asp-action="CancelReceipt"
                                                          method="post"
                                                          class="d-inline"
                                                          data-swal-confirm
                                                          data-swal-title="Hủy phiếu nhập?"
                                                          data-swal-text="Phiếu nhập bị hủy sẽ không thể duyệt lại."
                                                          data-swal-confirm-text="Hủy phiếu"
                                                          data-swal-cancel-text="Đóng">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@receipt.Id" />
                                                        <button type="submit" class="btn-action-danger">Hủy</button>
                                                    </form>
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="muted-text small">Không còn thao tác</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-box">
                        <i class="fa fa-inbox"></i>
                        <span>Chưa có phiếu nhập nào.</span>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        (function () {
            const productOptions = @Html.Raw(productOptionsJson);
            const $publisher = $('#PublisherId');
            const $tbody = $('#receipt-items');
            const selectFilter = window.EshopAdminSelectFilter;

            function escapeHtml(value) {
                return (value ?? '')
                    .toString()
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#39;');
            }

            function enhanceSelectFilters(root) {
                if (selectFilter) {
                    selectFilter.enhance(root || document);
                }
            }

            function refreshSelectFilter(selectElement) {
                if (selectFilter) {
                    selectFilter.refresh(selectElement);
                }
            }

            function resetSelectFilter(selectElement) {
                if (selectFilter) {
                    selectFilter.reset(selectElement);
                }
            }

            function getSelectedPublisherId() {
                return ($publisher.val() || '').toString();
            }

            function buildProductOptions(selectedValue) {
                const publisherId = getSelectedPublisherId();
                if (!publisherId) {
                    return '<option value="">-- Chọn brand trước --</option>';
                }

                let html = '<option value="">-- Chọn sản phẩm --</option>';

                productOptions
                    .filter(option => !publisherId || option.PublisherId.toString() === publisherId)
                    .forEach(option => {
                        const selected = option.ProductId.toString() === (selectedValue || '').toString() ? ' selected' : '';
                        html += `<option value="${option.ProductId}" data-publisher-id="${option.PublisherId}"${selected}>${escapeHtml(option.ProductName)}</option>`;
                    });

                return html;
            }

            function buildRow(index, selectedProductId, quantity, unitCost) {
                return `
                    <tr class="receipt-row">
                        <td>
                            <select name="Items[${index}].ProductId"
                                    class="form-select field-control js-product-select js-filterable-select"
                                    data-search-placeholder="Tìm sản phẩm trong brand đã chọn...">
                                ${buildProductOptions(selectedProductId)}
                            </select>
                        </td>
                        <td>
                            <input name="Items[${index}].Quantity" class="form-control field-control" type="number" min="1" step="1" value="${escapeHtml(quantity)}" />
                        </td>
                        <td>
                            <input name="Items[${index}].UnitCost" class="form-control field-control" type="number" min="0" step="0.01" value="${escapeHtml(unitCost)}" />
                        </td>
                        <td class="text-center">
                            <button type="button" class="icon-btn icon-delete js-remove-row" title="Xóa dòng">
                                <i class="fa fa-trash"></i>
                            </button>
                        </td>
                    </tr>`;
            }

            function refreshProductSelect($select) {
                const selectedValue = ($select.val() || '').toString();
                $select.html(buildProductOptions(selectedValue));

                if (!$select.find(`option[value="${selectedValue}"]`).length) {
                    $select.val('');
                }

                refreshSelectFilter($select[0]);
            }

            function reindexRows() {
                const rows = $tbody.find('.receipt-row');

                rows.each(function (index) {
                    $(this).find('select, input').each(function () {
                        const currentName = $(this).attr('name');
                        if (!currentName) return;

                        const newName = currentName.replace(/Items\[\d+\]/, `Items[${index}]`);
                        $(this).attr('name', newName);
                    });

                    refreshProductSelect($(this).find('.js-product-select'));
                });

                const disableRemove = rows.length === 1;
                rows.find('.js-remove-row').prop('disabled', disableRemove);
            }

            $('#add-receipt-row').on('click', function () {
                const nextIndex = $tbody.find('.receipt-row').length;
                $tbody.append(buildRow(nextIndex, '', '', ''));
                reindexRows();
            });

            $tbody.on('click', '.js-remove-row', function () {
                const rows = $tbody.find('.receipt-row');

                if (rows.length === 1) {
                    const $row = $(this).closest('.receipt-row');
                    $row.find('select').val('');
                    $row.find('input[type="number"]').val('');
                    resetSelectFilter($row.find('.js-product-select')[0]);
                    return;
                }

                $(this).closest('.receipt-row').remove();
                reindexRows();
            });

            $publisher.on('change', function () {
                $tbody.find('.js-product-select').each(function () {
                    refreshProductSelect($(this));
                });
            });

            enhanceSelectFilters(document);
            reindexRows();
        })();
    </script>
}
