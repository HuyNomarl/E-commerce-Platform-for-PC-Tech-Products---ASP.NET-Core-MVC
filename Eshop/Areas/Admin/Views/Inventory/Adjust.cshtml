@model Eshop.Models.ViewModels.AdminInventoryAdjustViewModel

@{
    ViewData["Title"] = "Điều chỉnh kho";
}

<div class="row g-3 inventory-adjust-page inv-page">
    <div class="col-12">
        <section class="inv-hero">
            <div class="inv-hero__content">
                <div class="inv-hero__eyebrow">
                    <i class="fa fa-sliders"></i>
                    <span>Inventory Adjustment</span>
                </div>
                <h4>Điều chỉnh kho</h4>
                <p class="inv-hero__desc">Cập nhật lại số lượng tồn kho thực tế sau kiểm kê với giao diện gọn hơn, dễ tập trung vào đúng kho và đúng sản phẩm cần chỉnh.</p>
                <div class="inv-hero__meta">
                    <span class="inv-chip">Chọn đúng kho</span>
                    <span class="inv-chip">Tìm nhanh sản phẩm</span>
                    <span class="inv-chip">Lưu rõ lý do điều chỉnh</span>
                </div>
            </div>

            <a asp-action="Index" class="inv-btn-back">
                <i class="fa fa-arrow-left"></i>
                <span>Quay lại tổng quan kho</span>
            </a>
        </section>
    </div>

    <div class="col-12 col-xl-8">
        <div class="card-soft inv-panel">
            <div class="section-head">
                <div>
                    <div class="section-title">
                        <i class="fa fa-sliders"></i>
                        <span>Phiếu điều chỉnh kho</span>
                    </div>
                    <div class="section-subtitle">Chỉ cập nhật sau khi đã kiểm đếm thực tế để tránh chênh lệch tồn.</div>
                </div>
            </div>

            <div class="section-body">
                <form asp-action="Adjust" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger inv-validation-summary"></div>

                    <div class="inv-step-row">
                        <span class="inv-step-chip">1. Chọn kho</span>
                        <span class="inv-step-chip">2. Chọn sản phẩm</span>
                        <span class="inv-step-chip">3. Nhập số lượng mới và lý do</span>
                    </div>

                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label asp-for="WarehouseId" class="field-label">Kho</label>
                            <select asp-for="WarehouseId" asp-items="Model.Warehouses" class="form-select field-control">
                                <option value="">-- Chọn kho --</option>
                            </select>
                            <span asp-validation-for="WarehouseId" class="text-danger small"></span>
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="ProductId" class="field-label">Sản phẩm</label>
                            <select asp-for="ProductId"
                                    asp-items="Model.Products"
                                    class="form-select field-control js-filterable-select"
                                    data-search-placeholder="Tìm sản phẩm cần điều chỉnh...">
                                <option value="">-- Chọn sản phẩm --</option>
                            </select>
                            <span asp-validation-for="ProductId" class="text-danger small"></span>
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="NewQuantity" class="field-label">Số lượng mới</label>
                            <input asp-for="NewQuantity" class="form-control field-control" type="number" min="0" step="1" placeholder="Nhập số lượng mới" />
                            <span asp-validation-for="NewQuantity" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Note" class="field-label">Lý do</label>
                            <textarea asp-for="Note" class="form-control field-control textarea-control" rows="4" placeholder="Ví dụ: kiểm kê lại kho, cập nhật chênh lệch thực tế..."></textarea>
                            <span asp-validation-for="Note" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="form-footer">
                        <button type="submit" class="btn-submit-warning">
                            <i class="fa fa-check-circle"></i>
                            <span>Điều chỉnh kho</span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-4">
        <div class="card-soft inv-panel info-card">
            <div class="section-head">
                <div>
                    <div class="section-title">
                        <i class="fa fa-info-circle"></i>
                        <span>Lưu ý thao tác</span>
                    </div>
                    <div class="section-subtitle">Một thay đổi nhỏ cũng ảnh hưởng trực tiếp đến số lượng đang bán.</div>
                </div>
            </div>

            <div class="section-body">
                <span class="inv-note-badge">Ảnh hưởng trực tiếp tới tồn kho hiện tại</span>

                <ul class="info-list">
                    <li>Chọn đúng kho đang kiểm kê trước khi cập nhật số lượng.</li>
                    <li>Dùng ô tìm kiếm sản phẩm để tránh chọn nhầm mã tương tự.</li>
                    <li>Nhập số lượng tồn mới sau khi đã đối chiếu thực tế.</li>
                    <li>Ghi rõ lý do để dễ tra lại khi xem lịch sử điều chỉnh.</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        (function () {
            if (window.EshopAdminSelectFilter) {
                window.EshopAdminSelectFilter.enhance(document);
            }
        })();
    </script>
}
