@model IEnumerable<Eshop.Models.InventoryReservationModel>

<h2>Reservation kho</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Mã reservation</th>
            <th>Payment</th>
            <th>Trạng thái</th>
            <th>OrderCode</th>
            <th>Hết hạn</th>
            <th>Chi tiết</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.ReservationCode</td>
                <td>@item.PaymentMethod</td>
                <td>@item.Status</td>
                <td>@item.OrderCode</td>
                <td>@item.ExpiresAt.ToString("dd/MM/yyyy HH:mm:ss")</td>
                <td>
                    @foreach (var d in item.Details)
                    {
                        <div>@d.Product?.Name - SL: @d.Quantity - KhoId: @d.WarehouseId</div>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
