                                        flex-direction: column;
                                        align-items: stretch;
                                    }

                                    .admin-topbar-right {
                                        width: 100%;
                                        justify-content: space-between;
                                    }

                                    .admin-alert-btn {
                                        min-width: 0;
                                        flex: 1 1 210px;
                                    }

                                    .admin-account-card {
                                        flex: 1 1 300px;
                                        max-width: none;
                                    }
                                }

                                @@media (max-width: 767px) {
                                    .admin-main {
                                        padding: 16px 0;
                                    }

                                    .content-card {
                                        padding: 16px;
                                    }

                                    .page-head {
                                        flex-direction: column;
                                        align-items: flex-start;
                                    }

                                    .admin-topbar-right {
                                        flex-direction: column;
                                        align-items: stretch;
                                    }

                                    .admin-alerts {
                                        width: 100%;
                                        display: grid;
                                        grid-template-columns: 1fr;
                                    }

                                    .admin-account-card {
                                        width: 100%;
                                        min-width: 0;
                                        max-width: none;
                                        flex-wrap: wrap;
                                    }

                                    .admin-account-side {
                                        width: 100%;
                                        flex-direction: row;
                                        align-items: center;
                                        justify-content: space-between;
                                        margin-left: 0;
                                        padding-top: 8px;
                                        border-top: 1px solid #eef2f7;
                                    }
                                }
                        </style>
                    </head>
                    <body>
                        <div class="admin-shell">
                            <header class="admin-topbar">
                                <div class="container-fluid">
                                    <div class="admin-topbar-inner">
                                        <div class="admin-brand">
                                            <a asp-controller="Home" asp-action="Index">
                                                <img src="~/images/Logo/bfe68383-fed2-4775-954a-a5ac3c1d5291.png" alt="E-Shopper Logo" />
                                            </a>
                                            <div class="admin-brand-text">
                                                <h4>E-Shopper Admin</h4>
                                                <div class="small">Quản trị hệ thống cửa hàng</div>
                                            </div>
                                        </div>

                                        <div class="admin-topbar-right">
                                            @if (canManageOrders || canManageSupport)
                                            {
                                                <div class="admin-alerts">
                                                    @if (canManageOrders)
                                                    {
                                                        <a asp-controller="Order"
                                                           asp-action="Index"
                                                           id="orderAlertButton"
                                                           class="admin-alert-btn order @(currentController == "Order" ? "active" : "")"
                                                           title="Xem thông báo đơn hàng mới"
                                                           aria-label="Xem thông báo đơn hàng mới">
                                                            <span class="admin-alert-icon">
                                                                <i class="fa fa-bell"></i>
                                                                <span class="admin-alert-type">
                                                                    <i class="fa fa-shopping-bag"></i>
                                                                </span>
                                                                <span id="orderBadge" class="admin-alert-badge">0</span>
                                                            </span>
                                                            <span class="admin-alert-meta">
                                                                <strong>Đơn hàng mới</strong>
                                                                <small>Theo dõi đơn phát sinh realtime</small>
                                                            </span>
                                                        </a>
                                                    }

                                                    @if (canManageSupport)
                                                    {
                                                        <a asp-controller="Chat"
                                                           asp-action="Index"
                                                           id="chatAlertButton"
                                                           class="admin-alert-btn chat @(currentController == "Chat" ? "active" : "")"
                                                           title="Xem thông báo chat mới"
                                                           aria-label="Xem thông báo chat mới">
                                                            <span class="admin-alert-icon">
                                                                <i class="fa fa-bell"></i>
                                                                <span class="admin-alert-type">
                                                                    <i class="fa fa-comments"></i>
                                                                </span>
                                                                <span id="chatBadge" class="admin-alert-badge">0</span>
                                                            </span>
                                                            <span class="admin-alert-meta">
                                                                <strong>Tin nhắn mới</strong>
                                                                <small>Không bỏ lỡ hội thoại hỗ trợ</small>
                                                            </span>
                                                        </a>
                                                    }
                                                </div>
                                            }

                                            <div class="admin-account-card">
                                                <div class="admin-account-avatar">@adminInitials</div>

                                                <div class="admin-account-meta">
                                                    <span class="admin-account-status">Đang đăng nhập</span>
                                                    <strong class="admin-account-name">@adminDisplayName</strong>
                                                    <span class="admin-account-sub">@adminSubtitle</span>
                                                </div>

                                                <div class="admin-account-side">
                                                    <span class="admin-role-pill">@adminRoleLabel</span>
                                                    <form asp-area=""
                                                          asp-controller="Account"
                                                          asp-action="Logout"
                                                          method="post"
                                                          style="display:inline-flex;">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="returnURL" value="/Account/Login" />
                                                        <button type="submit"
                                                                class="admin-logout"
                                                                title="Đăng xuất"
                                                                aria-label="Đăng xuất">
                                                            <i class="fa fa-sign-out"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </header>

                            <main class="admin-main">
                                <div class="container-fluid">
                                    <div class="admin-grid">
                                        <aside class="admin-sidebar">
                                            <div class="card-soft sidebar-card">
                                                <div class="sidebar-title">Điều hướng quản trị</div>

                                                <ul class="sidebar-menu">
                                                    @* <li>
                                                        <a asp-area="" asp-controller="Home" asp-action="Index">
                                                            <i class="fa fa-home"></i> <span>Home</span>
                                                        </a>
                                                    </li> *@
                                                    @if (canManageAdmin)
                                                    {
                                                        <li>
                                                            <a asp-controller="Dashboard" asp-action="Index" class="@(currentController == "Dashboard" ? "active" : "")">
                                                                <i class="fa fa-dashboard"></i> <span>Dashboard</span>
                                                            </a>
                                                        </li>
                                                    }
                                                    @if (canManageCatalog)
                                                    {
                                                        <li>
                                                            <a asp-controller="Slider" asp-action="Index" class="@(currentController == "Slider" ? "active" : "")">
                                                                <i class="fa fa-image"></i> <span>Slider</span>
                                                            </a>
                                                        </li>
                                                    }
                                                    @if (canManageAdmin)
                                                    {
                                                        <li>
                                                            <a asp-controller="Shipping" asp-action="Index" class="@(currentController == "Shipping" ? "active" : "")">
                                                                <i class="fa fa-truck"></i> <span>Shipping</span>
                                                            </a>
                                                        </li>
                                                    }
                                                    @if (canManageWarehouse)
                                                    {
                                                        <li>
                                                            <a asp-controller="Warehouse" asp-action="Index" class="@(currentController == "Warehouse" ? "active" : "")">
                                                                <i class="fa fa-cube"></i> <span>Warehouse</span>
                                                            </a>
                                                        </li>
                                                        <li>
                                                            <a asp-controller="Inventory" asp-action="Index" class="@(currentController == "Inventory" ? "active" : "")">
                                                                <i class="fa fa-cubes"></i> <span>Inventory</span>
                                                            </a>
                                                        </li>
                                                    }
                                                    @if (canManageCatalog)
                                                    {
                                                        <li>
                                                            <a asp-controller="Product" asp-action="Index" class="@(currentController == "Product" ? "active" : "")">
                                                                <i class="fa fa-cube"></i> <span>Product</span>
                                                            </a>
                                                        </li>
                                                        <li>
                                                            <a asp-controller="PcComponentAdmin" asp-action="Index" class="@(currentController == "PcComponentAdmin" ? "active" : "")">
                                                                <i class="fa fa-desktop"></i> <span>PC Builder</span>
                                                            </a>
                                                        </li>
                                                        <li>
                                                            <a asp-controller="Category" asp-action="Index" class="@(currentController == "Category" ? "active" : "")">
                                                                <i class="fa fa-list"></i> <span>Categories</span>
