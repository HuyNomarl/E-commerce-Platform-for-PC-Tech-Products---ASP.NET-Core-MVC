@using System.Text.Json
@using System.Security.Claims
@{
    string BuildInitials(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "AD";
        }

        var parts = value.Split(new[] { ' ', '.', '-', '_', '@' }, StringSplitOptions.RemoveEmptyEntries);

        if (parts.Length == 0)
        {
            return "AD";
        }

        if (parts.Length == 1)
        {
            var part = parts[0];
            return part.Length >= 2
                ? part[..2].ToUpperInvariant()
                : part.ToUpperInvariant();
        }

        return $"{char.ToUpperInvariant(parts[0][0])}{char.ToUpperInvariant(parts[1][0])}";
    }

    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var adminName = User.Identity?.Name;
    var adminEmail = User.FindFirst(ClaimTypes.Email)?.Value;
    var adminDisplayName = !string.IsNullOrWhiteSpace(adminName)
        ? adminName
        : !string.IsNullOrWhiteSpace(adminEmail)
            ? adminEmail
            : "Admin";
    var adminSubtitle = !string.IsNullOrWhiteSpace(adminEmail) && adminEmail != adminDisplayName
        ? adminEmail
        : "Tài khoản đang hoạt động";
    var adminRoleLabel = User.GetRoleDisplayLabel();
    var canManageAdmin = User.IsInRole(RoleNames.Admin);
    var canManageCatalog = User.CanAccessCatalog();
    var canManageBrands = User.CanManageBrands();
    var canManageOrders = User.CanAccessOrders();
    var canManageWarehouse = User.CanAccessWarehouse();
    var canManageSupport = User.CanAccessSupport();
    var adminInitials = BuildInitials(adminDisplayName);
}

