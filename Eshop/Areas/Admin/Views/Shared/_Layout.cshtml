                                    }

                                .admin-footer {
                                    padding: 18px 0 24px;
                                    color: #6b7280;
                                    font-size: 13px;
                                }

                                    .admin-footer .footer-card {
                                        padding: 14px 18px;
                                    }

                                .render-body-wrap > .row {
                                    margin-left: 0;
                                    margin-right: 0;
                                }

                                    .render-body-wrap > .row > [class*="col-"] {
                                        padding-left: 0;
                                        padding-right: 0;
                                    }
                                .notify-dot {
                                    width: 10px;
                                    height: 10px;
                                    min-width: 10px;
                                    border-radius: 50%;
                                    background: #ef4444;
                                    margin-left: auto;
                                    box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.15);
                                    animation: notifyPulse 1.4s infinite;
                                }

                                @@keyframes notifyPulse {
                                    0% {
                                        transform: scale(1);
                                        box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.35);
                                    }
                                    70% {
                                        transform: scale(1.08);
                                        box-shadow: 0 0 0 8px rgba(239, 68, 68, 0);
                                    }
                                    100% {
                                        transform: scale(1);
                                        box-shadow: 0 0 0 0 rgba(239, 68, 68, 0);
                                    }
                                }

                                @@media (max-width: 991px) {
                                    .admin-grid {
                                        flex-direction: column;
                                    }

                                    .admin-sidebar {
                                        width: 100%;
                                        flex: unset;
                                    }

                                    .sidebar-card {
