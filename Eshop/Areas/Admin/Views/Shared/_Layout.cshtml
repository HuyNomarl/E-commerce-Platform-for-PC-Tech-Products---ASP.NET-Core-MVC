                        </div>



                        <script src="~/js/jquery.js"></script>
                        <script src="~/js/bootstrap.min.js"></script>
                        <script src="~/js/jquery.scrollUp.min.js"></script>
                        <script src="~/js/price-range.js"></script>
                        <script src="~/js/jquery.prettyPhoto.js"></script>
                        <script src="~/js/main.js"></script>
                        <script src="~/backend/js/site.js"></script>

                        <script src="https://cdn.datatables.net/2.3.6/js/dataTables.min.js"></script>
                        <script src="https://cdn.datatables.net/buttons/3.2.6/js/dataTables.buttons.min.js"></script>
                        <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
                        <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
                        <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
                        <script src="https://cdn.datatables.net/buttons/3.2.6/js/buttons.html5.min.js"></script>
                        <script src="https://cdn.datatables.net/buttons/3.2.6/js/buttons.print.min.js"></script>

                        <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
                        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.26.17/dist/sweetalert2.all.min.js"></script>
                        <script src="~/js/swal-helpers.js"></script>

                        <script>
                            $(function () {
                                $(document).on('submit', 'form.js-confirm-save', function (e) {
                                    e.preventDefault();

                                    const form = this;

                                    showAppConfirm({
                                        title: "Lưu thay đổi?",
                                        text: "Bạn có muốn lưu nội dung vừa chỉnh sửa không?",
                                        confirmButtonText: "Lưu",
                                        cancelButtonText: "Hủy"
                                    }).then((result) => {
                                        if (result.isConfirmed) {
                                            form.submit();
                                        }
                                    });
                                });

                                const ORDER_KEY = "admin_order_notify_count";
                                const CHAT_KEY = "admin_chat_notify_count";
                                const ORDER_LEGACY_KEY = "admin_has_new_order";
                                const CHAT_LEGACY_KEY = "admin_has_new_chat";
                                const CURRENT_CONTROLLER = "@currentController".toLowerCase();

                                function getStoredCount(key, legacyKey) {
                                    const raw = localStorage.getItem(key);

                                    if (raw !== null) {
                                        const parsed = parseInt(raw, 10);
                                        return Number.isNaN(parsed) ? 0 : Math.max(parsed, 0);
                                    }

                                    return localStorage.getItem(legacyKey) === "1" ? 1 : 0;
                                }

                                function setStoredCount(key, legacyKey, count) {
                                    if (count > 0) {
                                        localStorage.setItem(key, String(count));
                                        localStorage.setItem(legacyKey, "1");
                                        return;
                                    }

                                    localStorage.removeItem(key);
                                    localStorage.removeItem(legacyKey);
                                }

                                function setIndicatorState(dotId, badgeId, count) {
                                    const dot = document.getElementById(dotId);
                                    const badge = document.getElementById(badgeId);
                                    const hasUnread = count > 0;

                                    if (dot) {
                                        dot.style.display = hasUnread ? "inline-block" : "none";
                                    }

                                    if (badge) {
                                        badge.style.display = hasUnread ? "inline-flex" : "none";
                                        badge.textContent = count > 99 ? "99+" : String(count);
                                    }
                                }

                                function syncOrderIndicators() {
                                    setIndicatorState("orderDot", "orderBadge", getStoredCount(ORDER_KEY, ORDER_LEGACY_KEY));
                                }

                                function syncChatIndicators() {
                                    setIndicatorState("chatDot", "chatBadge", getStoredCount(CHAT_KEY, CHAT_LEGACY_KEY));
                                }

                                function restoreIndicators() {
                                    syncOrderIndicators();
                                    syncChatIndicators();
                                }

                                function incrementOrderCount() {
                                    if (CURRENT_CONTROLLER === "order") {
                                        clearOrderMark();
                                        return;
                                    }

                                    setStoredCount(ORDER_KEY, ORDER_LEGACY_KEY, getStoredCount(ORDER_KEY, ORDER_LEGACY_KEY) + 1);
                                    syncOrderIndicators();
                                }

                                function incrementChatCount() {
                                    if (CURRENT_CONTROLLER === "chat") {
                                        clearChatMark();
                                        return;
                                    }

                                    setStoredCount(CHAT_KEY, CHAT_LEGACY_KEY, getStoredCount(CHAT_KEY, CHAT_LEGACY_KEY) + 1);
                                    syncChatIndicators();
                                }

                                function clearOrderMark() {
                                    setStoredCount(ORDER_KEY, ORDER_LEGACY_KEY, 0);
                                    syncOrderIndicators();
                                }

                                function clearChatMark() {
                                    setStoredCount(CHAT_KEY, CHAT_LEGACY_KEY, 0);
                                    syncChatIndicators();
                                }

                                function attachClearHandler(id, clearFn) {
                                    const el = document.getElementById(id);
                                    if (!el) return;

                                    el.addEventListener("click", function () {
                                        clearFn();
                                    });
                                }

                                function showRealtimeToast(icon, title, text, url) {
                                    Swal.fire({
                                        toast: true,
                                        position: 'top-end',
                                        icon: icon,
                                        title: title,
                                        text: text,
                                        showConfirmButton: false,
                                        timer: 5000,
                                        timerProgressBar: true,
                                        didOpen: (toast) => {
                                            if (!url) return;

                                            toast.style.cursor = "pointer";
                                            toast.addEventListener("click", function () {
                                                window.location.href = url;
                                            }, { once: true });
                                        }
                                    });
                                }

                                restoreIndicators();

                                if (CURRENT_CONTROLLER === "order") {
                                    clearOrderMark();
                                }

                                if (CURRENT_CONTROLLER === "chat") {
                                    clearChatMark();
                                }

                                attachClearHandler("menuOrders", clearOrderMark);
                                attachClearHandler("orderAlertButton", clearOrderMark);
                                attachClearHandler("menuChat", clearChatMark);
                                attachClearHandler("chatAlertButton", clearChatMark);

                                if (typeof signalR !== "undefined") {
                                    const notificationConnection = new signalR.HubConnectionBuilder()
                                        .withUrl("/hubs/notification")
                                        .withAutomaticReconnect()
                                        .build();

                                    notificationConnection.on("NewOrderCreated", function (data) {
                                        incrementOrderCount();

                                        const orderCode = data && data.orderCode ? data.orderCode : "chưa có mã";
                                        const orderCustomer = data && data.fullName ? data.fullName : "";
                                        const orderText = orderCustomer
                                            ? "Mã đơn: " + orderCode + " - " + orderCustomer
                                            : "Mã đơn: " + orderCode;

                                        showRealtimeToast(
                                            "info",
                                            "Đơn hàng mới",
                                            orderText,
                                            data && data.url ? data.url : "/Admin/Order"
                                        );

                                        window.dispatchEvent(new CustomEvent("eshop:new-order", {
                                            detail: data
                                        }));
                                    });

                                    notificationConnection.on("NewChatNotification", function (data) {
                                        incrementChatCount();

                                        const chatSender = data && data.fromUserName ? data.fromUserName : "Khách hàng";
                                        const chatText = data && data.preview
                                            ? chatSender + ": " + data.preview
                                            : "Có đoạn chat mới cần phản hồi.";

                                        showRealtimeToast(
                                            "info",
                                            "Chat mới",
                                            chatText,
                                            data && data.url ? data.url : "/Admin/Chat"
                                        );

                                        window.dispatchEvent(new CustomEvent("eshop:new-chat", {
                                            detail: data
                                        }));
                                    });

                                    async function startNotificationHub() {
                                        try {
                                            await notificationConnection.start();
                                        } catch (err) {
                                            console.error(err);
                                            setTimeout(startNotificationHub, 5000);
                                        }
                                    }

                                    startNotificationHub();
                                }
                            });
                        </script>

                        @await RenderSectionAsync("Scripts", required: false)
                    </body>
                </html>
